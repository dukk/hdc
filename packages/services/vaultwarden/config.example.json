{
  "schema_version": 2,
  "defaults": {
    "mode": "proxmox-lxc",
    "proxmox": {
      "lxc": {
        "ostemplate": "local:vztmpl/ubuntu-22.04-standard_22.04-1_amd64.tar.zst",
        "storage": "local-lvm",
        "rootfs_gb": 16,
        "memory_mb": 1024,
        "cores": 1,
        "bridge": "vmbr0",
        "ip_config": "dhcp",
        "unprivileged": 0,
        "features": "nesting=1,keyctl=1",
        "onboot": 1
      }
    },
    "vaultwarden": {
      "image_tag": "1.34.0",
      "host_port": 80,
      "domain": "https://vault.example.invalid",
      "signups_allowed": false,
      "invitations_allowed": false,
      "websocket_enabled": true,
      "admin_token_vault_key": "HDC_VAULTWARDEN_ADMIN_TOKEN"
    },
    "install": {
      "enabled": true,
      "compose_dir": "/opt/vaultwarden"
    }
  },
  "deployments": [
    {
      "system_id": "vaultwarden-a",
      "proxmox": {
        "host_id": "REPLACE_PVE_NODE",
        "lxc": {
          "vmid": 0,
          "hostname": "vaultwarden-a"
        }
      }
    }
  ]
}
