{
  "schema_version": 2,
  "defaults": {
    "mode": "proxmox-lxc",
    "proxmox": {
      "lxc": {
        "ostemplate": "local:vztmpl/ubuntu-22.04-standard_22.04-1_amd64.tar.zst",
        "storage": "local-lvm",
        "rootfs_gb": 4,
        "memory_mb": 1024,
        "cores": 1,
        "bridge": "vmbr0",
        "ip_config": "dhcp",
        "unprivileged": 1,
        "onboot": 1
      }
    },
    "uptime_kuma": {
      "port": 3001,
      "node_version": "22",
      "release": "latest"
    },
    "install": {
      "enabled": true
    }
  },
  "deployments": [
    {
      "system_id": "uptime-kuma-a",
      "proxmox": {
        "host_id": "hypervisor-a",
        "lxc": {
          "vmid": 115,
          "hostname": "uptime-kuma-a"
        }
      }
    }
  ]
}
