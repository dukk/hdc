{
  "schema_version": 3,
  "uptime_kuma_auth": {
    "api_url": "http://10.0.0.105:3001",
    "username_env": "HDC_UPTIME_KUMA_USERNAME",
    "password_vault_key": "HDC_UPTIME_KUMA_PASSWORD"
  },
  "monitors": [
    {
      "id": "pi-hole-a",
      "name": "Pi-hole A",
      "type": "http",
      "url": "http://10.0.0.4/admin",
      "group": "Infrastructure",
      "interval": 60,
      "managed": true
    },
    {
      "id": "bind-a",
      "name": "BIND A",
      "type": "ping",
      "hostname": "10.0.0.2",
      "group": "Infrastructure",
      "interval": 60,
      "managed": true
    }
  ],
  "defaults": {
    "mode": "proxmox-lxc",
    "proxmox": {
      "network": {
        "gateway": "10.0.0.1"
      },
      "lxc": {
        "ostemplate": "local:vztmpl/ubuntu-22.04-standard_22.04-1_amd64.tar.zst",
        "storage": "local-lvm",
        "rootfs_gb": 4,
        "memory_mb": 1024,
        "cores": 1,
        "bridge": "vmbr0",
        "ip_config": "dhcp",
        "unprivileged": 1,
        "onboot": 1
      }
    },
    "uptime_kuma": {
      "port": 3001,
      "node_version": "22",
      "release": "latest"
    },
    "install": {
      "enabled": true
    }
  },
  "deployments": [
    {
      "system_id": "uptime-kuma-a",
      "proxmox": {
        "host_id": "pve-c",
        "lxc": {
          "vmid": 153,
          "hostname": "uptime-kuma-a",
          "ip_config": "10.0.0.105/24,gw=10.0.0.1"
        }
      }
    }
  ]
}
