{
  "schema_version": 2,
  "defaults": {
    "mode": "proxmox-lxc",
    "proxmox": {
      "network": {
        "gateway": "10.0.0.1"
      },
      "lxc": {
        "ostemplate": "local:vztmpl/ubuntu-22.04-standard_22.04-1_amd64.tar.zst",
        "storage": "local-lvm",
        "rootfs_gb": 8,
        "memory_mb": 1024,
        "cores": 1,
        "bridge": "vmbr0",
        "ip_config": "dhcp",
        "unprivileged": 0,
        "features": "nesting=1,keyctl=1",
        "onboot": 1
      }
    },
    "draw_io": {
      "image_tag": "latest",
      "host_port": 8080,
      "public_url": "https://draw.example.invalid"
    },
    "install": {
      "enabled": true,
      "compose_dir": "/opt/draw-io"
    }
  },
  "deployments": [
    {
      "system_id": "draw-io-a",
      "proxmox": {
        "host_id": "REPLACE_PVE_NODE",
        "lxc": {
          "vmid": 0,
          "hostname": "draw-io-a"
        }
      }
    }
  ]
}
