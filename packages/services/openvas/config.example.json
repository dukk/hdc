{
  "schema_version": 2,
  "defaults": {
    "mode": "proxmox-lxc",
    "proxmox": {
      "network": {
        "gateway": "10.0.0.1"
      },
      "lxc": {
        "ostemplate": "local:vztmpl/ubuntu-22.04-standard_22.04-1_amd64.tar.zst",
        "storage": "local-lvm",
        "rootfs_gb": 64,
        "memory_mb": 8192,
        "cores": 4,
        "bridge": "vmbr0",
        "ip_config": "dhcp",
        "unprivileged": 0,
        "features": "nesting=1,keyctl=1",
        "onboot": 1
      }
    },
    "openvas": {
      "image_tag": "stable",
      "host_port": 3000,
      "admin_user": "admin",
      "admin_password_vault_key": "HDC_OPENVAS_ADMIN_PASSWORD"
    },
    "install": {
      "enabled": true,
      "compose_dir": "/opt/openvas"
    }
  },
  "deployments": [
    {
      "system_id": "openvas-a",
      "proxmox": {
        "host_id": "REPLACE_PVE_NODE",
        "lxc": {
          "vmid": 0,
          "hostname": "openvas-a"
        }
      }
    }
  ]
}
