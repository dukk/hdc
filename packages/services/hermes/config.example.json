{
  "schema_version": 2,
  "defaults": {
    "mode": "proxmox-lxc",
    "proxmox": {
      "network": {
        "gateway": "10.0.0.1"
      },
      "lxc": {
        "ostemplate": "local:vztmpl/ubuntu-22.04-standard_22.04-1_amd64.tar.zst",
        "storage": "local-lvm",
        "rootfs_gb": 32,
        "memory_mb": 8192,
        "cores": 4,
        "bridge": "vmbr0",
        "ip_config": "10.0.0.113/24,gw=10.0.0.1",
        "unprivileged": 0,
        "features": "nesting=1,keyctl=1",
        "onboot": 1
      }
    },
    "hermes": {
      "image_tag": "v2026.6.5",
      "api_port": 8642,
      "dashboard_port": 9119,
      "dashboard_enabled": true,
      "dashboard_username": "admin",
      "openrouter_api_key_vault_key": "HDC_HERMES_OPENROUTER_API_KEY",
      "dashboard_password_vault_key": "HDC_HERMES_DASHBOARD_PASSWORD",
      "dashboard_auth_secret_vault_key": "HDC_HERMES_DASHBOARD_AUTH_SECRET",
      "searxng_url": "http://10.0.0.135:8080",
      "env_extra": {}
    },
    "install": {
      "enabled": true,
      "compose_dir": "/opt/hermes",
      "data_subdir": "data"
    }
  },
  "deployments": [
    {
      "system_id": "hermes-a",
      "proxmox": {
        "host_id": "pve-a",
        "lxc": {
          "vmid": 501,
          "hostname": "hermes-a",
          "ip_config": "10.0.0.113/24,gw=10.0.0.1"
        }
      }
    }
  ]
}
