{
  "schema_version": 2,
  "defaults": {
    "mode": "proxmox-lxc",
    "proxmox": {
      "lxc": {
        "ostemplate": "local:vztmpl/ubuntu-22.04-standard_22.04-1_amd64.tar.zst",
        "storage": "local-lvm",
        "rootfs_gb": 20,
        "memory_mb": 2048,
        "cores": 2,
        "bridge": "vmbr0",
        "ip_config": "dhcp",
        "unprivileged": 0,
        "features": "nesting=1,keyctl=1",
        "onboot": 1
      }
    },
    "vikunja": {
      "image_tag": "latest",
      "postgres_image_tag": "16-alpine",
      "host_port": 3456,
      "public_url": "https://tasks.dukk.org/",
      "timezone": "America/New_York",
      "jwt_secret_vault_key": "HDC_VIKUNJA_JWT_SECRET",
      "db_password_vault_key": "HDC_VIKUNJA_DB_PASSWORD",
      "mail": {
        "enabled": false,
        "from": "noreply@hdc.dukk.org"
      }
    },
    "install": {
      "enabled": true,
      "compose_dir": "/opt/vikunja"
    }
  },
  "deployments": [
    {
      "system_id": "vikunja-a",
      "proxmox": {
        "host_id": "REPLACE_PVE_NODE",
        "lxc": {
          "vmid": 0,
          "hostname": "vikunja-a"
        }
      }
    }
  ]
}
