{
  "schema_version": 2,
  "defaults": {
    "mode": "proxmox-lxc",
    "proxmox": {
      "lxc": {
        "ostemplate": "local:vztmpl/ubuntu-22.04-standard_22.04-1_amd64.tar.zst",
        "storage": "local-lvm",
        "rootfs_gb": 16,
        "memory_mb": 4096,
        "cores": 2,
        "bridge": "vmbr0",
        "ip_config": "dhcp",
        "unprivileged": 0,
        "features": "nesting=1,keyctl=1",
        "onboot": 1
      }
    },
    "open_webui": {
      "image_tag": "v0.6.26",
      "host_port": 3000,
      "secret_key_vault_key": "HDC_OPEN_WEBUI_SECRET_KEY",
      "webui_auth": true,
      "ollama_backends": [
        {
          "id": "ollama-a",
          "url": "http://192.0.2.25:11434",
          "notes": "vm-ollama-a GPU node — matches inventory/manual/systems/vm-ollama-a.json"
        },
        {
          "id": "ollama-b",
          "url": "http://REPLACE_AFTER_DEPLOY:11434",
          "notes": "ollama-b on hypervisor-c — set URL after ollama-b has an IP"
        },
        {
          "id": "ollama-c",
          "url": "http://REPLACE_AFTER_DEPLOY:11434",
          "notes": "ollama-c on hypervisor-b — set URL after ollama-c has an IP"
        }
      ]
    },
    "install": {
      "enabled": true,
      "compose_dir": "/opt/open-webui"
    }
  },
  "deployments": [
    {
      "system_id": "open-webui-a",
      "proxmox": {
        "host_id": "hypervisor-a",
        "lxc": {
          "vmid": 486,
          "hostname": "open-webui-a"
        }
      }
    }
  ]
}
