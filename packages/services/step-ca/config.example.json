{
  "schema_version": 2,
  "step_ca": {
    "ca_name": "HDC Internal CA",
    "dns_names": ["ca.hdc.example.invalid"],
    "listen_address": ":443",
    "deployment_type": "standalone",
    "provisioner_name": "admin",
    "enable_acme": true,
    "password_vault_key": "HDC_STEP_CA_PASSWORD",
    "step_path": "/etc/step-ca"
  },
  "defaults": {
    "mode": "proxmox-qemu",
    "proxmox": {
      "qemu": {
        "template_vmid": 9024,
        "storage": "local-lvm",
        "full": 1,
        "cores": 2,
        "memory_mb": 2048,
        "rootfs_gb": 16
      },
      "network": {
        "bridge": "vmbr0",
        "gateway": "192.0.2.1"
      }
    },
    "install": {
      "enabled": true
    }
  },
  "deployments": [
    {
      "system_id": "vm-step-ca-a",
      "role": "standalone",
      "hostname": "step-ca-a",
      "proxmox": {
        "host_id": "hypervisor-a",
        "qemu": {
          "vmid": 125,
          "ip": "192.0.2.24/24"
        }
      },
      "configure": {
        "ssh": {
          "host": "192.0.2.24"
        }
      }
    }
  ]
}
