{
  "schema_version": 2,
  "kali_desktop": {
    "user": "kali",
    "password_vault_key": "HDC_KALI_DESKTOP_PASSWORD",
    "image": {
      "url": "https://cdimage.kali.org/current/kali-linux-2026.1-qemu-amd64.7z"
    },
    "template_name": "kali-cloud-template"
  },
  "defaults": {
    "mode": "proxmox-qemu",
    "proxmox": {
      "host_id": "pve-c",
      "qemu": {
        "template_vmid": 9050,
        "storage": "local-lvm",
        "image_storage": "local",
        "cores": 4,
        "memory_mb": 8192,
        "rootfs_gb": 64
      },
      "network": {
        "bridge": "vmbr0",
        "gateway": "10.0.0.1",
        "dns": ["10.0.0.2", "10.0.0.3"]
      }
    }
  },
  "deployments": [
    {
      "system_id": "vm-kali-a",
      "hostname": "kali-a",
      "proxmox": {
        "host_id": "pve-c",
        "qemu": {
          "vmid": null,
          "ip": "10.0.0.189/24"
        }
      },
      "configure": {
        "ssh": {
          "host": "10.0.0.189",
          "user": "kali"
        }
      }
    }
  ]
}
