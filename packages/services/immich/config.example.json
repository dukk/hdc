{
  "schema_version": 2,
  "defaults": {
    "mode": "proxmox-qemu",
    "proxmox": {
      "qemu": {
        "template_vmid": 9024,
        "storage": "local-lvm",
        "full": 1,
        "cores": 4,
        "memory_mb": 8192,
        "rootfs_gb": 32,
        "data_disk_gb": 256
      },
      "network": {
        "bridge": "vmbr0",
        "gateway": "192.0.2.1"
      }
    },
    "immich": {
      "release": "latest",
      "port": 2283,
      "public_url": null,
      "upload_location": "/data/immich/library",
      "db_data_location": "/data/immich/postgres",
      "db_password_vault_key": "HDC_IMMICH_DB_PASSWORD",
      "timezone": "UTC",
      "disable_machine_learning": false
    },
    "install": {
      "enabled": true,
      "compose_dir": "/opt/immich"
    },
    "configure": {
      "ssh": {
        "user": "root"
      }
    }
  },
  "deployments": [
    {
      "system_id": "vm-immich-a",
      "hostname": "immich-a",
      "proxmox": {
        "host_id": "hypervisor-a",
        "qemu": {
          "vmid": 487,
          "ip": "192.0.2.40/24"
        }
      },
      "configure": {
        "ssh": {
          "host": "192.0.2.40"
        }
      }
    }
  ]
}
