{
  "schema_version": 2,
  "defaults": {
    "mode": "proxmox-lxc",
    "proxmox": {
      "network": {
        "gateway": "10.0.0.1"
      },
      "lxc": {
        "ostemplate": "local:vztmpl/ubuntu-22.04-standard_22.04-1_amd64.tar.zst",
        "storage": "local-lvm",
        "rootfs_gb": 64,
        "memory_mb": 4096,
        "cores": 2,
        "bridge": "vmbr0",
        "ip_config": "10.0.0.111/24,gw=10.0.0.1",
        "unprivileged": 0,
        "features": "nesting=1,keyctl=1",
        "onboot": 1
      }
    },
    "yacy": {
      "image_tag": "latest",
      "http_port": 8090,
      "https_port": 8443,
      "peer_name": "hdc-yacy-a",
      "public_url": null,
      "admin_password_vault_key": "HDC_YACY_ADMIN_PASSWORD"
    },
    "install": {
      "enabled": true,
      "compose_dir": "/opt/yacy"
    }
  },
  "deployments": [
    {
      "system_id": "yacy-a",
      "proxmox": {
        "host_id": "hypervisor-a",
        "lxc": {
          "vmid": 486,
          "hostname": "yacy-a",
          "ip_config": "10.0.0.111/24,gw=10.0.0.1"
        }
      }
    }
  ]
}
