# Copy to packages/services/paperclip/.env in hdc-private (or hdc root; never commit).
# Values are optional unless the package manifest declares env_required.

# Paperclip (`packages/services/paperclip`) — Better Auth secret and Postgres password; auto-generated on first deploy if missing.
# node tools/hdc/cli.mjs secrets set HDC_PAPERCLIP_BETTER_AUTH_SECRET
# node tools/hdc/cli.mjs secrets set HDC_PAPERCLIP_DB_PASSWORD
# HDC_PAPERCLIP_BETTER_AUTH_SECRET=
# HDC_PAPERCLIP_DB_PASSWORD=
