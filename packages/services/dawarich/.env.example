# Copy to packages/services/dawarich/.env in hdc-private (or hdc root; never commit).
# Values are optional unless the package manifest declares env_required.

# Dawarich (`packages/services/dawarich`) — Rails secret and Postgres password; auto-generated on first deploy if missing.
# node tools/hdc/cli.mjs secrets set HDC_DAWARICH_SECRET_KEY_BASE
# node tools/hdc/cli.mjs secrets set HDC_DAWARICH_DB_PASSWORD
# HDC_DAWARICH_SECRET_KEY_BASE=
# HDC_DAWARICH_DB_PASSWORD=
