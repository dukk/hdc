# Copy to packages/services/n8n/.env in hdc-private (or hdc root; never commit).
# Values are optional unless the package manifest declares env_required.

# n8n (`packages/services/n8n`) — credential encryption key; auto-generated on first deploy if missing.
# node tools/hdc/cli.mjs secrets set HDC_N8N_ENCRYPTION_KEY
# HDC_N8N_ENCRYPTION_KEY=
