{
  "schema_version": 2,
  "defaults": {
    "mode": "proxmox-lxc",
    "proxmox": {
      "lxc": {
        "ostemplate": "local:vztmpl/ubuntu-22.04-standard_22.04-1_amd64.tar.zst",
        "storage": "local-lvm",
        "rootfs_gb": 24,
        "memory_mb": 2048,
        "cores": 2,
        "bridge": "vmbr0",
        "ip_config": "dhcp",
        "unprivileged": 0,
        "features": "nesting=1,keyctl=1",
        "onboot": 1
      }
    },
    "stirling_pdf": {
      "image": "stirlingtools/stirling-pdf:latest",
      "host_port": 8080,
      "memory_limit_mb": 2048,
      "public_url": null,
      "timezone": "America/New_York",
      "langs": "en_US",
      "ui_app_name": "Stirling-PDF",
      "security": {
        "enable_login": true,
        "initial_username": "admin",
        "admin_password_vault_key": "HDC_STIRLING_PDF_ADMIN_PASSWORD"
      }
    },
    "install": {
      "enabled": true,
      "compose_dir": "/opt/stirling-pdf"
    }
  },
  "deployments": [
    {
      "system_id": "stirling-pdf-a",
      "proxmox": {
        "host_id": "REPLACE_PVE_NODE",
        "lxc": {
          "vmid": 0,
          "hostname": "stirling-pdf-a"
        }
      }
    }
  ]
}
