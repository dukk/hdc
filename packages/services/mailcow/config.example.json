{
  "schema_version": 2,
  "defaults": {
    "mode": "proxmox-lxc",
    "proxmox": {
      "lxc": {
        "ostemplate": "local:vztmpl/ubuntu-22.04-standard_22.04-1_amd64.tar.zst",
        "storage": "local-lvm",
        "rootfs_gb": 40,
        "memory_mb": 6144,
        "cores": 4,
        "bridge": "vmbr0",
        "ip_config": "dhcp",
        "unprivileged": 0,
        "features": "nesting=1,keyctl=1",
        "onboot": 1
      }
    },
    "mailcow": {
      "git_ref": "master",
      "hostname": "mail.example.invalid",
      "timezone": "America/Chicago",
      "admin_url": "https://mail.example.invalid",
      "api_url": "https://mail.example.invalid",
      "api_key_vault_key": "HDC_MAILCOW_API_KEY",
      "dns_publish": {
        "cloudflare_dkim": true
      },
      "dbpass_vault_key": "HDC_MAILCOW_DBPASS",
      "dbroot_vault_key": "HDC_MAILCOW_DBROOT",
      "redispass_vault_key": "HDC_MAILCOW_REDISPASS",
      "skip_clamd": false,
      "skip_solr": true,
      "domains": [
        {
          "name": "example.invalid",
          "description": "Primary mail domain",
          "dkim_selector": "dkim",
          "dkim_key_size": 2048,
          "outbound": {
            "mode": "direct"
          },
          "dns": {
            "mx_priority": 10,
            "spf": "v=spf1 mx a ~all",
            "dmarc": "v=DMARC1; p=quarantine; rua=mailto:dmarc@example.invalid",
            "notes": "Publish these records in BIND or Cloudflare. DKIM TXT is filled after maintain generates the key."
          },
          "mailboxes": [
            {
              "local_part": "admin",
              "name": "Example Admin",
              "quota_mb": 3072,
              "password_vault_key": "HDC_MAILCOW_MAILBOX_ADMIN_EXAMPLE_INVALID_PASSWORD"
            }
          ],
          "aliases": [
            {
              "address": "info@example.invalid",
              "goto": ["admin@example.invalid"]
            }
          ]
        },
        {
          "name": "relay-only.example.invalid",
          "description": "Outbound via internal postfix-relay (SMTP2GO upstream)",
          "dkim_selector": "dkim",
          "dkim_key_size": 2048,
          "outbound": {
            "mode": "postfix-relay"
          },
          "dns": {
            "mx_priority": 10,
            "spf": "v=spf1 include:spf.smtp2go.com ~all",
            "dmarc": "v=DMARC1; p=none; rua=mailto:dmarc-reports@example.invalid",
            "notes": "Inbound MX still points at mailcow. Outbound uses hdc postfix-relay; add provider DKIM CNAMEs per SMTP2GO docs when using SMTP2GO."
          }
        }
      ]
    },
    "install": {
      "enabled": true,
      "install_dir": "/opt/mailcow-dockerized"
    }
  },
  "deployments": [
    {
      "system_id": "mailcow-a",
      "proxmox": {
        "host_id": "REPLACE_PVE_NODE",
        "lxc": {
          "vmid": 0,
          "hostname": "mailcow-a",
          "ip_config": "dhcp"
        }
      }
    }
  ]
}
