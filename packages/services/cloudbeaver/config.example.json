{
  "schema_version": 2,
  "defaults": {
    "mode": "proxmox-lxc",
    "proxmox": {
      "network": {
        "gateway": "192.0.2.1"
      },
      "lxc": {
        "ostemplate": "local:vztmpl/ubuntu-22.04-standard_22.04-1_amd64.tar.zst",
        "storage": "local-lvm",
        "rootfs_gb": 16,
        "memory_mb": 3072,
        "cores": 2,
        "bridge": "vmbr0",
        "ip_config": "dhcp",
        "unprivileged": 0,
        "features": "nesting=1,keyctl=1",
        "onboot": 1
      }
    },
    "cloudbeaver": {
      "image": "dbeaver/cloudbeaver:latest",
      "host_port": 8978,
      "public_url": null,
      "admin": {
        "enabled": true,
        "username": "cbadmin",
        "server_name": "HDC CloudBeaver",
        "admin_password_vault_key": "HDC_CLOUDBEAVER_ADMIN_PASSWORD"
      },
      "extra_hosts": ["host.docker.internal:host-gateway"]
    },
    "install": {
      "enabled": true,
      "compose_dir": "/opt/cloudbeaver"
    }
  },
  "deployments": [
    {
      "system_id": "cloudbeaver-a",
      "proxmox": {
        "host_id": "REPLACE_PVE_NODE",
        "lxc": {
          "vmid": 0,
          "hostname": "cloudbeaver-a"
        }
      }
    }
  ]
}
