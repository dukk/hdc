{
  "schema_version": 2,
  "defaults": {
    "mode": "proxmox-lxc",
    "proxmox": {
      "lxc": {
        "ostemplate": "local:vztmpl/ubuntu-22.04-standard_22.04-1_amd64.tar.zst",
        "storage": "local-lvm",
        "rootfs_gb": 32,
        "memory_mb": 2048,
        "cores": 2,
        "bridge": "vmbr0",
        "ip_config": "dhcp",
        "unprivileged": 1,
        "onboot": 1
      },
      "qemu": {
        "template_vmid": 9000,
        "rootfs_gb": 32,
        "memory_mb": 2048,
        "cores": 2
      }
    },
    "hdc_runner": {
      "install_root": "/opt/hdc",
      "private_root": "/opt/hdc-private",
      "meta_root": "/opt/hdc-runner",
      "node_version": "22",
      "bw_version": "2025.11.0",
      "env": {},
      "mail": {
        "enabled": true,
        "to": "ops@example.invalid",
        "from": "noreply@example.invalid",
        "subject_prefix": "[HDC]",
        "on_failure_only": false
      },
      "discord": {
        "enabled": true,
        "title_prefix": "[HDC]",
        "on_failure_only": false
      },
      "schedules": [
        {
          "id": "daily-maintain",
          "cron": "0 3 * * *",
          "cli": ["maintain", "daily"],
          "cli_args": ["--skip-clients"],
          "mail": { "enabled": true, "on_failure_only": false },
          "discord": { "enabled": true, "on_failure_only": false }
        },
        {
          "id": "bind-maintain-weekly",
          "cron": "30 4 * * 0",
          "cli": ["run", "service", "bind", "maintain"],
          "cli_args": ["--no-reboot", "--skip-resources"]
        },
        {
          "id": "agent-manager-hourly",
          "cron": "0 * * * *",
          "type": "agent",
          "agent_role": "hdc-manager",
          "cli_args": []
        }
      ],
      "sync": {
        "exclude": [".git", "node_modules", "**/reports"]
      },
      "web": {
        "enabled": true,
        "host": "0.0.0.0",
        "port": 9120,
        "username": "hdc",
        "password_vault_key": "HDC_HDC_RUNNER_UI_PASSWORD",
        "session_secret_vault_key": "HDC_HDC_RUNNER_UI_SESSION_SECRET",
        "api_token_vault_key": "HDC_HDC_RUNNER_API_TOKEN",
        "allowed_verbs": ["query", "maintain"],
        "max_concurrent_jobs": 1,
        "allowed_schedule_ids": [],
        "allowed_packages": []
      },
      "paperclip_bridge": {
        "enabled": false,
        "host": "0.0.0.0",
        "port": 9121,
        "secret_vault_key": "HDC_PAPERCLIP_AGENT_BRIDGE_SECRET",
        "hdc_runner_url": "http://127.0.0.1:9120"
      },
      "agents": {
        "enabled": true,
        "cursor_api_key_vault_key": "HDC_CURSOR_API_KEY",
        "workspace": "/opt/hdc",
        "private_root": "/opt/hdc-private",
        "max_concurrent_agent_runs": 1,
        "manager_schedule_id": "agent-manager-hourly"
      }
    },
    "install": {
      "enabled": true
    }
  },
  "deployments": [
    {
      "system_id": "hdc-runner-a",
      "proxmox": {
        "host_id": "hypervisor-a",
        "lxc": {
          "vmid": 590,
          "hostname": "hdc-runner-a"
        }
      },
      "configure": {
        "ssh": {
          "host": ""
        }
      }
    }
  ]
}
