{
  "schema_version": 2,
  "defaults": {
    "mode": "proxmox-lxc",
    "proxmox": {
      "network": {
        "gateway": "10.0.0.1"
      },
      "lxc": {
        "ostemplate": "local:vztmpl/ubuntu-22.04-standard_22.04-1_amd64.tar.zst",
        "storage": "local-lvm",
        "rootfs_gb": 8,
        "memory_mb": 512,
        "cores": 1,
        "bridge": "vmbr0",
        "ip_config": "dhcp",
        "unprivileged": 0,
        "features": "nesting=1,keyctl=1",
        "onboot": 1
      }
    },
    "homepage": {
      "image_tag": "latest",
      "host_port": 3000,
      "public_url": "https://hdc.dukk.org",
      "allowed_hosts": ["hdc.dukk.org", "homepage-a.hdc.dukk.org", "10.0.0.49:3000"],
      "config_files": {
        "services": "homepage/services.example.yaml",
        "settings": "homepage/settings.example.yaml",
        "bookmarks": "homepage/bookmarks.example.yaml"
      },
      "proxmox_widget": {
        "enabled": true,
        "service_account_id": "homepage",
        "hosts": ["pve-a", "pve-b", "pve-c", "pve-d", "pve-h"]
      }
    },
    "install": {
      "enabled": true,
      "compose_dir": "/opt/homepage"
    }
  },
  "deployments": [
    {
      "system_id": "homepage-a",
      "proxmox": {
        "host_id": "REPLACE_PVE_NODE",
        "lxc": {
          "vmid": 0,
          "hostname": "homepage-a"
        }
      }
    }
  ]
}
