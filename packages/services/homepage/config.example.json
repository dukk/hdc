{
  "schema_version": 2,
  "defaults": {
    "mode": "proxmox-lxc",
    "proxmox": {
      "network": {
        "gateway": "10.0.0.1"
      },
      "lxc": {
        "ostemplate": "local:vztmpl/ubuntu-22.04-standard_22.04-1_amd64.tar.zst",
        "storage": "local-lvm",
        "rootfs_gb": 8,
        "memory_mb": 512,
        "cores": 1,
        "bridge": "vmbr0",
        "ip_config": "dhcp",
        "unprivileged": 0,
        "features": "nesting=1,keyctl=1",
        "onboot": 1
      }
    },
    "homepage": {
      "image_tag": "latest",
      "host_port": 3000,
      "public_url": "https://hdc.dukk.org",
      "allowed_hosts": ["hdc.dukk.org", "homepage-a.hdc.dukk.org", "10.0.0.49:3000"],
      "title": "HDC",
      "theme": "dark",
      "disable_indexing": true,
      "service_groups": [
        {
          "name": "Public apps",
          "services": [
            {
              "name": "Immich",
              "icon": "immich.png",
              "href": "https://immich.dukk.org",
              "description": "Photos & videos",
              "site_monitor": "https://immich.dukk.org"
            },
            {
              "name": "Vaultwarden",
              "icon": "vaultwarden.png",
              "href": "https://vault.dukk.org",
              "description": "Passwords",
              "site_monitor": "https://vault.dukk.org"
            },
            {
              "name": "Home Assistant",
              "icon": "home-assistant.png",
              "href": "https://ha.dukk.org",
              "description": "Smart home",
              "site_monitor": "https://ha.dukk.org"
            },
            {
              "name": "draw.io",
              "icon": "drawio.png",
              "href": "https://draw.dukk.org",
              "description": "Diagrams",
              "site_monitor": "https://draw.dukk.org"
            },
            {
              "name": "Audiobookshelf",
              "icon": "audiobookshelf.png",
              "href": "https://bookshelf.dukk.org",
              "description": "Audiobooks",
              "site_monitor": "https://bookshelf.dukk.org"
            }
          ]
        },
        {
          "name": "Productivity",
          "services": [
            {
              "name": "n8n",
              "icon": "n8n.png",
              "href": "http://n8n.hdc.dukk.org:5678",
              "description": "Workflow automation",
              "site_monitor": "http://10.0.0.120:5678"
            },
            {
              "name": "Open WebUI",
              "icon": "open-webui.png",
              "href": "http://open-webui.hdc.dukk.org:3000",
              "description": "AI chat UI",
              "site_monitor": "http://10.0.0.21:3000"
            },
            {
              "name": "Postiz",
              "icon": "postiz.png",
              "href": "http://postiz-a.hdc.dukk.org",
              "description": "Social scheduling",
              "site_monitor": "http://10.0.0.150"
            }
          ]
        },
        {
          "name": "Media & search",
          "services": [
            {
              "name": "Plex",
              "icon": "plex.png",
              "href": "http://nas-1.hdc.dukk.org:32400/web",
              "description": "Media server",
              "site_monitor": "http://10.0.0.9:32400/identity"
            },
            {
              "name": "SearXNG",
              "icon": "searxng.png",
              "href": "http://searxng.hdc.dukk.org:8080",
              "description": "Meta search",
              "site_monitor": "http://10.0.0.135:8080"
            },
            {
              "name": "YaCy A",
              "icon": "yacy.png",
              "href": "http://yacy-a.hdc.dukk.org:8090",
              "description": "Peer search",
              "site_monitor": "http://10.0.0.130:8090"
            },
            {
              "name": "Scanopy",
              "icon": "scanopy.png",
              "href": "http://scanopy.hdc.dukk.org:60072",
              "description": "Network maps",
              "site_monitor": "http://10.0.0.109:60072"
            }
          ]
        },
        {
          "name": "Monitoring",
          "services": [
            {
              "name": "Uptime Kuma",
              "icon": "uptime-kuma.png",
              "href": "http://uptime-kuma.hdc.dukk.org:3001",
              "description": "Status pages",
              "site_monitor": "http://10.0.0.105:3001"
            },
            {
              "name": "Nagios A",
              "icon": "nagios.png",
              "href": "http://nagios-a.hdc.dukk.org/nagios4",
              "description": "Monitoring",
              "site_monitor": "http://10.0.0.100/nagios4"
            },
            {
              "name": "Splunk",
              "icon": "splunk.png",
              "href": "http://splunk-a.hdc.dukk.org:8000",
              "description": "Logs & SIEM",
              "site_monitor": "http://10.0.0.90:8000"
            },
            {
              "name": "Wazuh",
              "icon": "wazuh.png",
              "href": "https://wazuh-a.hdc.dukk.org",
              "description": "Security monitoring",
              "site_monitor": "https://10.0.0.202"
            }
          ]
        },
        {
          "name": "AI",
          "services": [
            {
              "name": "Ollama A",
              "icon": "ollama.png",
              "href": "http://ollama-a.hdc.dukk.org:11434",
              "description": "LLM inference",
              "site_monitor": "http://10.0.0.111:11434"
            },
            {
              "name": "llama.cpp",
              "icon": "llama-cpp.png",
              "href": "http://llama-cpp-a.hdc.dukk.org:8080",
              "description": "GPU inference",
              "site_monitor": "http://10.0.0.115:8080"
            }
          ]
        },
        {
          "name": "Infrastructure",
          "services": [
            {
              "name": "Pi-hole A",
              "icon": "pi-hole.png",
              "href": "http://pi-hole-a.hdc.dukk.org/admin",
              "description": "DNS ad-block",
              "site_monitor": "http://10.0.0.4/admin"
            },
            {
              "name": "Proxmox A",
              "icon": "proxmox.png",
              "href": "https://pve-a.hdc.dukk.org:8006",
              "description": "Hypervisor",
              "site_monitor": "https://10.0.0.11:8006"
            },
            {
              "name": "Mailcow",
              "icon": "mailcow.png",
              "href": "http://mailcow-web.hdc.dukk.org",
              "description": "Mail server",
              "site_monitor": "http://10.0.0.62"
            },
            {
              "name": "BIND A",
              "icon": "bind9.png",
              "href": "http://bind-a.hdc.dukk.org",
              "description": "Internal DNS",
              "site_monitor": "http://10.0.0.2"
            }
          ]
        }
      ],
      "bookmarks": []
    },
    "install": {
      "enabled": true,
      "compose_dir": "/opt/homepage"
    }
  },
  "deployments": [
    {
      "system_id": "homepage-a",
      "proxmox": {
        "host_id": "REPLACE_PVE_NODE",
        "lxc": {
          "vmid": 0,
          "hostname": "homepage-a"
        }
      }
    }
  ]
}
