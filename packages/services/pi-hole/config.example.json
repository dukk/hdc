{
  "schema_version": 2,
  "defaults": {
    "mode": "proxmox-lxc",
    "proxmox": {
      "network": {
        "gateway": "10.0.0.1"
      },
      "lxc": {
        "ostemplate": "local:vztmpl/ubuntu-22.04-standard_22.04-1_amd64.tar.zst",
        "storage": "local-lvm",
        "rootfs_gb": 16,
        "memory_mb": 1024,
        "cores": 1,
        "bridge": "vmbr0",
        "unprivileged": 1,
        "onboot": 1,
        "password": "change-me-lxc-root"
      }
    },
    "pihole": {
      "upstream_dns": ["1.1.1.1", "1.0.0.1"],
      "listening_mode": "ALL",
      "webpassword": "change-me-admin",
      "interface": "eth0",
      "allowlist": [
        "marketingplatform.google.com",
        "www.googletagmanager.com",
        "www.google-analytics.com",
        "analytics.google.com"
      ]
    },
    "install": {
      "enabled": true
    }
  },
  "deployments": [
    {
      "system_id": "pi-hole-a",
      "proxmox": {
        "host_id": "pve-b",
        "lxc": {
          "vmid": 110,
          "hostname": "pi-hole-a",
          "ip_config": "10.0.0.4/24,gw=10.0.0.1"
        }
      }
    },
    {
      "system_id": "pi-hole-b",
      "proxmox": {
        "host_id": "pve-c",
        "lxc": {
          "vmid": 112,
          "hostname": "pi-hole-b",
          "ip_config": "10.0.0.5/24,gw=10.0.0.1"
        }
      }
    }
  ]
}
