{
  "schema_version": 2,
  "letsencrypt": {
    "email_vault_key": "HDC_NGINX_WAF_LE_EMAIL",
    "staging": false,
    "cert_primary_system_id": "vm-nginx-waf-a",
    "challenge": "http-01",
    "webroot": "/var/www/letsencrypt",
    "dns": {
      "zone": "hdc.example.invalid",
      "nameservers": ["192.0.2.2"],
      "tsig_vault_key": "HDC_BIND_TSIG_KEY",
      "key_name": "hdc-bind-xfer"
    }
  },
  "sites": [
    {
      "id": "example-app",
      "server_names": ["app.hdc.example.invalid"],
      "listen": [80, 443],
      "upstream": "http://192.0.2.50:8080",
      "tls": { "enabled": true, "cert_name": "app.hdc.example.invalid" },
      "waf": { "enabled": true },
      "locations": [{ "path": "/", "proxy_headers": true }]
    }
  ],
  "defaults": {
    "mode": "proxmox-qemu",
    "proxmox": {
      "qemu": {
        "template_vmid": 9024,
        "storage": "local-lvm",
        "full": 1,
        "cores": 2,
        "memory_mb": 2048
      },
      "network": {
        "bridge": "vmbr0",
        "gateway": "192.0.2.1"
      }
    },
    "nginx_waf": {
      "modsecurity": {
        "enabled": true,
        "rule_engine": "On",
        "crs_setup": "/etc/modsecurity/crs/crs-setup.conf",
        "crs_rules_glob": "/usr/share/modsecurity-crs/rules/*.conf",
        "audit_log": "/var/log/nginx/modsec_audit.log"
      },
      "client_max_body_size": "64m",
      "proxy_read_timeout": "300s",
      "proxy_connect_timeout": "60s"
    },
    "install": { "enabled": true }
  },
  "deployments": [
    {
      "system_id": "vm-nginx-waf-a",
      "role": "cert-primary",
      "hostname": "nginx-waf-a",
      "proxmox": {
        "host_id": "hypervisor-a",
        "qemu": { "vmid": 300, "ip": "192.0.2.20/24" }
      },
      "configure": {
        "ssh": { "user": "root", "host": "192.0.2.20" }
      }
    },
    {
      "system_id": "vm-nginx-waf-b",
      "role": "peer",
      "hostname": "nginx-waf-b",
      "proxmox": {
        "host_id": "hypervisor-b",
        "qemu": { "vmid": 301, "ip": "192.0.2.21/24" }
      },
      "configure": {
        "ssh": { "user": "root", "host": "192.0.2.21" }
      }
    }
  ]
}
