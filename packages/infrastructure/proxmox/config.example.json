{
  "schema_version": 1,
  "clusters": [
    {
      "id": "example-proxmox-cluster",
      "hosts": [
        {
          "id": "hypervisor-a",
          "pve_node": "hypervisor-a",
          "ip": "192.0.2.11",
          "web_ui": "https://192.0.2.11:8006",
          "ssh": "ssh://root@192.0.2.11"
        },
        {
          "id": "hypervisor-b",
          "pve_node": "hypervisor-b",
          "ip": "192.0.2.12",
          "web_ui": "https://192.0.2.12:8006",
          "ssh": "ssh://root@192.0.2.12"
        }
      ]
    },
    {
      "id": "example-proxmox-v9-cluster",
      "pve_release": "9",
      "hosts": [
        {
          "id": "hypervisor-d",
          "pve_node": "hypervisor-d",
          "ip": "198.51.100.218",
          "web_ui": "https://198.51.100.218:8006",
          "ssh": "ssh://root@198.51.100.218"
        }
      ]
    },
    {
      "id": "example-proxmox-standalone",
      "hosts": [
        {
          "id": "hypervisor-h",
          "pve_node": "hypervisor-h",
          "ip": "192.0.2.14",
          "web_ui": "https://192.0.2.14:8006",
          "ssh": "ssh://root@192.0.2.14"
        }
      ]
    }
  ],
  "provision": {
    "templates": {
      "policy": "ubuntu-lts"
    },
    "host_os": {
      "enabled": true,
      "reboot_wait_seconds": 300
    },
    "storage": {
      "enabled": true,
      "ids": ["nas-a", "nas-b"],
      "discover_from_host": "hypervisor-a",
      "targets": []
    },
    "api_token": {
      "enabled": true,
      "userid": "root@pam",
      "role": "HDCMaintain"
    },
    "ssh_keys": {
      "enabled": true
    },
    "lxc": {
      "ostemplate_storage": "local",
      "default_release": "22.04",
      "ostemplate": "local:vztmpl/ubuntu-22.04-standard_22.04-1_amd64.tar.zst",
      "storage": "local-lvm",
      "rootfs_gb": 32,
      "memory_mb": 4096,
      "cores": 2,
      "bridge": "vmbr0",
      "ip_config": "dhcp",
      "unprivileged": 1,
      "onboot": 1
    },
    "qemu": {
      "storage": "local-lvm",
      "image_storage": "local",
      "default_release": "22.04",
      "template_vmid": 9022,
      "build_template": true,
      "memory_mb": 2048,
      "cores": 2,
      "bridge": "vmbr0"
    }
  },
  "bootstrap_hosts": []
}
