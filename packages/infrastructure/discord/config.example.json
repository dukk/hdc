{
  "schema_version": 1,
  "discord": {
    "api_base_url": "https://discord.com/api/v10",
    "developer_portal_url": "https://discord.com/developers/applications"
  },
  "defaults": {
    "managed": false
  },
  "applications": [
    {
      "id": "hermes",
      "managed": false,
      "match": {
        "application_id": null
      },
      "display_name": "Hermes Agent",
      "bot_token_vault_key": "HDC_HERMES_DISCORD_BOT_TOKEN",
      "description": "Home data center AI agent",
      "redirect_uris": [],
      "interactions_endpoint_url": null,
      "tags": [],
      "bot_public": true,
      "bot_require_code_grant": false,
      "portal_checklist": {
        "privileged_intents": ["message_content"],
        "notes": "Enable Message Content Intent for Hermes Discord channel replies."
      },
      "consumer": "hermes-a",
      "notes": "Bot token shared with packages/services/hermes compose."
    },
    {
      "id": "example-oauth",
      "managed": false,
      "match": {
        "application_id": null
      },
      "display_name": "Example OAuth App",
      "bot_token_vault_key": "HDC_DISCORD_EXAMPLE_OAUTH_BOT_TOKEN",
      "description": "Example OAuth2 application with redirect URIs from nginx-waf",
      "redirect_uris": [],
      "interactions_endpoint_url": null,
      "tags": [],
      "bot_public": true,
      "bot_require_code_grant": false,
      "derive_from": {
        "nginx_waf_config_path": "packages/services/nginx-waf/config.json",
        "site_id": "example-app",
        "callback_path": "/oauth/callback"
      },
      "portal_checklist": {
        "privileged_intents": [],
        "notes": "Create the application in the Developer Portal before import."
      },
      "consumer": null,
      "notes": "Remove or replace when not used."
    }
  ]
}
