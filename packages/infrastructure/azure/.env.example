# Copy to packages/infrastructure/azure/.env in hdc-private (or hdc root; never commit).
# Values are optional unless the package manifest declares env_required.

# Azure app registrations (`packages/infrastructure/azure`) — automation app (see docs/manually-deployed/azure.md).
# HDC_AZURE_TENANT_ID=
# HDC_AZURE_CLIENT_ID=
# node tools/hdc/cli.mjs secrets set HDC_AZURE_CLIENT_SECRET
# HDC_AZURE_CLIENT_SECRET=
