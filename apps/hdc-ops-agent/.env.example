# hdc-ops-agent environment (copy to .env beside agent.ts or set in shell)
# Required for interactive ADK agent (npx adk run agent.ts)
# GOOGLE_API_KEY=

# Optional model override (default: gemini-2.5-flash)
# HDC_OPS_AGENT_MODEL=gemini-2.5-flash

# hdc-private root (same as hdc CLI)
# HDC_PRIVATE_ROOT=C:/dev/dukk/hdc-private

# Override hdc-mcp server path (default: ../hdc-mcp/server.mjs)
# HDC_MCP_SERVER_PATH=

# Discord webhook via hdc vault (HDC_OPS_DISCORD_WEBHOOK_URL) — no value here
