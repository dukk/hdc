{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/lms.config.schema.json",
  "title": "HDC lms service package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "deployments"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 2 },
    "defaults": { "type": "object" },
    "deployments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["system_id"],
        "properties": {
          "system_id": { "type": "string", "pattern": "^vm-lms-[a-z]+$" },
          "mode": { "enum": ["proxmox-qemu"] },
          "hostname": { "type": "string" },
          "proxmox": { "type": "object" },
          "configure": { "type": "object" },
          "install": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" },
              "linux_user": { "type": "string" },
              "gpu": { "type": "boolean" },
              "gpu_backend": { "enum": ["nvidia", "intel"] }
            }
          },
          "lms": {
            "type": "object",
            "properties": {
              "models": {
                "type": "array",
                "items": {
                  "oneOf": [
                    { "type": "string" },
                    {
                      "type": "object",
                      "required": ["name"],
                      "properties": { "name": { "type": "string" } }
                    }
                  ]
                }
              },
              "load_on_start": { "type": ["string", "null"] },
              "server": {
                "type": "object",
                "properties": {
                  "host": { "type": "string" },
                  "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
                }
              }
            }
          }
        }
      }
    }
  }
}
