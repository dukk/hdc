{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/keepalived.config.schema.json",
  "title": "HDC Keepalived service package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "vrrp_instances", "virtual_servers", "deployments"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 2 },
    "keepalived": {
      "type": "object",
      "properties": {
        "auth_pass_vault_key": { "type": "string" },
        "router_id": { "type": "string" }
      }
    },
    "vrrp_instances": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "virtual_router_id", "virtual_ipaddress"],
        "properties": {
          "id": { "type": "string" },
          "instance_name": { "type": "string" },
          "virtual_router_id": { "type": "integer", "minimum": 1, "maximum": 255 },
          "interface": { "type": "string" },
          "virtual_ipaddress": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "track_scripts": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "script"],
              "properties": {
                "id": { "type": "string" },
                "script": { "type": "string" },
                "interval": { "type": "integer", "minimum": 1 },
                "weight": { "type": "integer" }
              }
            }
          }
        }
      }
    },
    "virtual_servers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "vrrp_instance_id", "vip", "port", "real_servers"],
        "properties": {
          "id": { "type": "string" },
          "vrrp_instance_id": { "type": "string" },
          "vip": { "type": "string" },
          "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
          "protocol": { "enum": ["TCP", "UDP", "tcp", "udp"] },
          "lb_kind": { "enum": ["NAT", "DR", "TUN", "nat", "dr", "tun"] },
          "lb_algo": { "type": "string" },
          "real_servers": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["address", "port"],
              "properties": {
                "address": { "type": "string" },
                "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
                "weight": { "type": "integer", "minimum": 1 },
                "system_id": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "defaults": { "type": "object" },
    "deployments": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["system_id", "deployment_kind", "configure"],
        "properties": {
          "system_id": { "type": "string" },
          "deployment_kind": { "enum": ["director", "real_server"] },
          "role": { "type": "string" },
          "state": { "enum": ["MASTER", "BACKUP", "master", "backup"] },
          "priority": { "type": "integer", "minimum": 1, "maximum": 255 },
          "mode": { "enum": ["proxmox-qemu", "configure-only"] },
          "lb_kind": { "enum": ["NAT", "DR", "TUN", "nat", "dr", "tun"] },
          "vrrp_instance_ids": {
            "type": "array",
            "items": { "type": "string" }
          },
          "virtual_server_ids": {
            "type": "array",
            "items": { "type": "string" }
          },
          "proxmox": { "type": "object" },
          "configure": {
            "type": "object",
            "properties": {
              "ssh": {
                "type": "object",
                "required": ["host"],
                "properties": {
                  "host": { "type": "string" },
                  "user": { "type": "string" }
                }
              }
            }
          },
          "install": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" }
            }
          }
        }
      }
    }
  }
}
