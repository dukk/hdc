{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/azure-compute.config.schema.json",
  "title": "HDC azure-compute infrastructure package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "deployments"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "defaults": {
      "type": "object",
      "properties": {
        "azure": { "$ref": "#/$defs/azureDefaults" }
      }
    },
    "deployments": {
      "type": "array",
      "items": { "$ref": "#/$defs/deployment" }
    }
  },
  "$defs": {
    "azureDefaults": {
      "type": "object",
      "properties": {
        "subscription_id": { "type": "string" },
        "resource_group": { "type": "string" },
        "location": { "type": "string" },
        "tags": { "type": "object", "additionalProperties": { "type": "string" } }
      }
    },
    "deployment": {
      "type": "object",
      "required": ["id", "system_id", "mode"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "system_id": { "type": "string", "minLength": 1 },
        "mode": { "enum": ["azure-vm", "azure-aci"] },
        "azure": {
          "type": "object",
          "properties": {
            "subscription_id": { "type": "string" },
            "resource_group": { "type": "string" },
            "location": { "type": "string" },
            "resource_name": { "type": "string" },
            "vm_size": { "type": "string" },
            "os_disk_gb": { "type": "number", "minimum": 32 },
            "admin_username": { "type": "string" },
            "public_ip": { "type": "boolean" },
            "cpu": { "type": "number", "minimum": 0.5 },
            "memory_gb": { "type": "number", "minimum": 0.5 },
            "containers": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["name", "image"],
                "properties": {
                  "name": { "type": "string" },
                  "image": { "type": "string" },
                  "ports": { "type": "array", "items": { "type": "integer" } }
                }
              }
            },
            "image": {
              "type": "object",
              "properties": {
                "publisher": { "type": "string" },
                "offer": { "type": "string" },
                "sku": { "type": "string" },
                "version": { "type": "string" }
              }
            },
            "tags": { "type": "object", "additionalProperties": { "type": "string" } }
          }
        }
      }
    }
  }
}
