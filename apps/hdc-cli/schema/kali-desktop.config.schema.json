{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/kali-desktop.config.schema.json",
  "title": "HDC Kali desktop service package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "deployments"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "kali_desktop": {
      "type": "object",
      "properties": {
        "user": { "type": "string" },
        "password_vault_key": { "type": "string" },
        "image": {
          "type": "object",
          "properties": {
            "url": { "type": "string", "format": "uri" }
          }
        },
        "template_name": { "type": "string" }
      }
    },
    "defaults": { "type": "object" },
    "deployments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["system_id"],
        "properties": {
          "system_id": { "type": "string", "pattern": "^vm-kali-[a-z]+$" },
          "hostname": { "type": "string" },
          "mode": { "enum": ["proxmox-qemu"] },
          "proxmox": { "type": "object" },
          "configure": {
            "type": "object",
            "properties": {
              "ssh": {
                "type": "object",
                "properties": {
                  "host": { "type": "string" },
                  "user": { "type": "string" }
                }
              }
            }
          }
        }
      }
    }
  }
}
