{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/gcp-compute.config.schema.json",
  "title": "HDC gcp-compute infrastructure package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "deployments"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "defaults": {
      "type": "object",
      "properties": {
        "gcp": { "$ref": "#/$defs/gcpDefaults" }
      }
    },
    "deployments": {
      "type": "array",
      "items": { "$ref": "#/$defs/deployment" }
    }
  },
  "$defs": {
    "gcpDefaults": {
      "type": "object",
      "properties": {
        "project_id": { "type": "string" },
        "region": { "type": "string" },
        "zone": { "type": "string" },
        "labels": { "type": "object", "additionalProperties": { "type": "string" } }
      }
    },
    "deployment": {
      "type": "object",
      "required": ["id", "system_id", "mode"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "system_id": { "type": "string", "minLength": 1 },
        "mode": { "enum": ["gcp-vm", "gcp-cloud-run"] },
        "gcp": {
          "type": "object",
          "properties": {
            "project_id": { "type": "string" },
            "region": { "type": "string" },
            "zone": { "type": "string" },
            "resource_name": { "type": "string" },
            "machine_type": { "type": "string" },
            "boot_disk_gb": { "type": "number", "minimum": 10 },
            "image_family": { "type": "string" },
            "image_project": { "type": "string" },
            "image": { "type": "string" },
            "cpu": { "type": "number", "minimum": 0.08 },
            "memory_mb": { "type": "integer", "minimum": 128 },
            "min_instances": { "type": "integer", "minimum": 0 },
            "max_instances": { "type": "integer", "minimum": 1 },
            "allow_unauthenticated": { "type": "boolean" },
            "labels": { "type": "object", "additionalProperties": { "type": "string" } }
          }
        }
      }
    }
  }
}
