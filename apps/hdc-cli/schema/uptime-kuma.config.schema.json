{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/uptime-kuma.config.schema.json",
  "title": "HDC uptime-kuma service package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "deployments"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 4 },
    "uptime_kuma_auth": {
      "type": "object",
      "properties": {
        "api_url": { "type": "string", "format": "uri" },
        "api_via_ssh": { "type": "boolean" },
        "username_env": { "type": "string" },
        "password_vault_key": { "type": "string" }
      }
    },
    "notifications": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "type", "managed"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
          "name": { "type": "string", "minLength": 1 },
          "type": { "enum": ["discord", "smtp"] },
          "managed": { "type": "boolean" },
          "discord_webhook_vault_key": { "type": "string" },
          "discord_username": { "type": "string" },
          "discord_prefix_message": { "type": "string" },
          "smtp_host": { "type": "string" },
          "smtp_port": { "type": "integer", "minimum": 1, "maximum": 65535 },
          "smtp_secure": { "type": "boolean" },
          "smtp_ignore_tls_error": { "type": "boolean" },
          "smtp_username_env": { "type": "string" },
          "smtp_password_vault_key": { "type": "string" },
          "mail_from": { "type": "string" },
          "mail_to": { "type": "string" },
          "mail_cc": { "type": "string" },
          "mail_bcc": { "type": "string" },
          "custom_subject": { "type": "string" },
          "use_mail_relay": { "type": "boolean" },
          "apply_to_monitors": { "type": "boolean" }
        }
      }
    },
    "monitors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "type", "managed"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
          "name": { "type": "string", "minLength": 1 },
          "type": { "enum": ["http", "ping"] },
          "url": { "type": "string" },
          "hostname": { "type": "string" },
          "group": { "type": "string" },
          "tags": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "notifications": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "interval": { "type": "integer", "minimum": 20, "maximum": 86400 },
          "max_retries": { "type": "integer", "minimum": 0, "maximum": 10 },
          "retry_interval": { "type": "integer", "minimum": 1, "maximum": 86400 },
          "timeout": { "type": "integer", "minimum": 1, "maximum": 300 },
          "accepted_status_codes": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "ignore_tls": { "type": "boolean" },
          "managed": { "type": "boolean" },
          "notes": { "type": ["string", "null"] }
        }
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "color": { "type": "string" }
        }
      }
    },
    "status_pages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "slug", "title", "managed"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
          "slug": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": ["string", "null"] },
          "theme": { "type": "string" },
          "published": { "type": "boolean" },
          "show_tags": { "type": "boolean" },
          "show_powered_by": { "type": "boolean" },
          "show_certificate_expiry": { "type": "boolean" },
          "show_only_last_heartbeat": { "type": "boolean" },
          "auto_refresh_interval": { "type": "integer", "minimum": 5 },
          "custom_css": { "type": "string" },
          "footer_text": { "type": ["string", "null"] },
          "rss_title": { "type": ["string", "null"] },
          "domain_names": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "icon": { "type": "string" },
          "analytics_id": { "type": ["string", "null"] },
          "analytics_script_url": { "type": ["string", "null"] },
          "analytics_type": { "type": ["string", "null"] },
          "managed": { "type": "boolean" },
          "groups": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "monitors"],
              "properties": {
                "name": { "type": "string", "minLength": 1 },
                "weight": { "type": "integer", "minimum": 1 },
                "monitors": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["id"],
                    "properties": {
                      "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
                      "send_url": { "type": "boolean" },
                      "url": { "type": ["string", "null"] }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "defaults": { "type": "object" },
    "deployments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["system_id"],
        "properties": {
          "system_id": { "type": "string", "pattern": "^uptime-kuma-[a-z]+$" },
          "mode": { "enum": ["proxmox-lxc", "oci-vm"] },
          "proxmox": { "type": "object" },
          "oci": {
            "type": "object",
            "properties": {
              "instance_id": { "type": "string" },
              "subnet_id": { "type": "string" },
              "nsg_ids": {
                "type": "array",
                "items": { "type": "string" }
              },
              "shape": { "type": "string" },
              "boot_volume_gb": { "type": "integer", "minimum": 10 },
              "image_ocid": { "type": "string" },
              "assign_public_ip": { "type": "boolean" },
              "admin_ingress": {
                "type": "object",
                "properties": {
                  "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
                  "allowed_cidrs": {
                    "type": "array",
                    "items": { "type": "string" },
                    "minItems": 1
                  }
                }
              }
            }
          },
          "configure": {
            "type": "object",
            "properties": {
              "ssh": {
                "type": "object",
                "properties": {
                  "host": { "type": "string" },
                  "user": { "type": "string" }
                }
              }
            }
          },
          "uptime_kuma_auth": {
            "type": "object",
            "properties": {
              "api_url": { "type": "string" },
              "api_via_ssh": { "type": "boolean" },
              "username_env": { "type": "string" },
              "password_vault_key": { "type": "string" }
            }
          },
          "monitors": { "type": "array" },
          "notifications": { "type": "array" },
          "status_pages": { "type": "array" },
          "tags": { "type": "array" },
          "uptime_kuma": {
            "type": "object",
            "properties": {
              "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
              "node_version": { "type": "string" },
              "release": { "type": "string" },
              "public_url": { "type": "string", "format": "uri" }
            }
          },
          "install": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" }
            }
          }
        }
      }
    }
  }
}
