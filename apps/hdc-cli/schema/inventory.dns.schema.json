{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/inventory.dns.schema.json",
  "title": "HDC inventory sidecar — DNS zone",
  "description": "Authoritative zone data rendered by the bind service package.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "kind", "zone_type"],
  "properties": {
    "schema_version": { "const": 1 },
    "id": {
      "type": "string",
      "minLength": 1,
      "description": "Zone name (e.g. hdc.example.invalid or 2.0.192.in-addr.arpa); must match filename stem."
    },
    "kind": { "const": "dns" },
    "zone_type": { "enum": ["forward", "reverse"] },
    "subnet": {
      "type": "string",
      "description": "CIDR for reverse zones (e.g. 192.0.2.0/24); used for PTR auto-generation from forward A records."
    },
    "nameservers": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Optional override for NS glue in SOA (defaults to primary/secondary IPs from bind config)."
    },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "name"],
        "properties": {
          "type": { "enum": ["A", "AAAA", "CNAME", "PTR", "TXT", "NS", "MX"] },
          "name": { "type": "string" },
          "data": { "type": "string" },
          "ttl": { "type": "integer", "minimum": 60 },
          "priority": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": false
      }
    },
    "notes": { "type": "string" }
  }
}
