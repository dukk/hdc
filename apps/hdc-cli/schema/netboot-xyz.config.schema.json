{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/netboot-xyz.config.schema.json",
  "title": "HDC netboot-xyz service package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "deployments"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 2 },
    "defaults": { "type": "object" },
    "deployments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["system_id"],
        "properties": {
          "system_id": { "type": "string", "pattern": "^netboot-xyz-[a-z]+$" },
          "mode": { "enum": ["proxmox-lxc"] },
          "proxmox": { "type": "object" },
          "netboot_xyz": {
            "type": "object",
            "properties": {
              "image": { "type": "string" },
              "image_tag": { "type": "string" },
              "menu_version": { "type": ["string", "null"] },
              "web_app_port": { "type": "integer", "minimum": 1, "maximum": 65535 },
              "nginx_port": { "type": "integer", "minimum": 1, "maximum": 65535 },
              "nginx_host_port": { "type": "integer", "minimum": 1, "maximum": 65535 },
              "tftp_host_port": { "type": "integer", "minimum": 1, "maximum": 65535 },
              "tftpd_opts": { "type": ["string", "null"] },
              "timezone": { "type": "string" },
              "puid": { "type": "integer", "minimum": 0 },
              "pgid": { "type": "integer", "minimum": 0 }
            }
          },
          "install": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" },
              "compose_dir": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
