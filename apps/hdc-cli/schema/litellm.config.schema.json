{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/litellm.config.schema.json",
  "title": "HDC litellm service package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "deployments"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 2 },
    "defaults": { "type": "object" },
    "deployments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["system_id"],
        "properties": {
          "system_id": { "type": "string", "pattern": "^litellm-[a-z]+$" },
          "mode": { "enum": ["proxmox-lxc"] },
          "proxmox": { "type": "object" },
          "litellm": {
            "type": "object",
            "properties": {
              "image_tag": { "type": "string" },
              "postgres_image_tag": { "type": "string" },
              "host_port": { "type": "integer", "minimum": 1, "maximum": 65535 },
              "public_url": { "type": ["string", "null"] },
              "store_model_in_db": { "type": "boolean" },
              "master_key_vault_key": { "type": "string" },
              "salt_key_vault_key": { "type": "string" },
              "db_password_vault_key": { "type": "string" },
              "openrouter_api_key_vault_key": { "type": "string" },
              "ollama_backends": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["id", "url"],
                  "properties": {
                    "id": { "type": "string" },
                    "url": { "type": "string", "format": "uri" },
                    "notes": { "type": "string" }
                  }
                }
              },
              "openai_backends": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["id", "url"],
                  "properties": {
                    "id": { "type": "string" },
                    "url": { "type": "string", "format": "uri" },
                    "notes": { "type": "string" }
                  }
                }
              },
              "model_list": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["model_name", "provider", "model"],
                  "properties": {
                    "model_name": { "type": "string" },
                    "provider": { "enum": ["ollama", "openai", "openrouter", "auto_router"] },
                    "model": { "type": "string" },
                    "ollama_backend_id": { "type": "string" },
                    "openai_backend_id": { "type": "string" },
                    "order": { "type": "integer", "minimum": 1 },
                    "weight": { "type": "number", "exclusiveMinimum": 0 },
                    "complexity_router_config": { "type": "object" },
                    "complexity_router_default_model": { "type": "string" }
                  }
                }
              },
              "router_settings": { "type": "object" },
              "litellm_settings": { "type": "object" },
              "mail": {
                "type": "object",
                "properties": {
                  "enabled": { "type": "boolean" },
                  "from": { "type": "string" }
                }
              },
              "a2a_agents": {
                "type": "array",
                "description": "A2A agents registered on the LiteLLM gateway (rendered as config.yaml agents:)",
                "items": {
                  "type": "object",
                  "required": ["name", "url"],
                  "additionalProperties": false,
                  "properties": {
                    "name": {
                      "type": "string",
                      "minLength": 1,
                      "description": "LiteLLM agent_name / path segment under /a2a/<name>"
                    },
                    "url": {
                      "type": "string",
                      "format": "uri",
                      "description": "Upstream A2A invocation URL (agent card host)"
                    },
                    "description": { "type": "string" },
                    "protocol_version": {
                      "type": "string",
                      "enum": ["0.3", "1.0"],
                      "default": "0.3"
                    },
                    "card_name": {
                      "type": "string",
                      "description": "Display name on agent_card_params (defaults to name)"
                    },
                    "kind": {
                      "type": "string",
                      "enum": ["fleet", "augmentor"],
                      "description": "fleet = hdc container agent; augmentor = external IDE/cloud bridge"
                    },
                    "runtime": {
                      "type": "string",
                      "enum": ["cursor-cloud", "cursor-cli", "claude-code", "custom"],
                      "description": "Augmentor backend runtime (omit for fleet agents)"
                    },
                    "repos": {
                      "type": "array",
                      "items": {
                        "type": "string",
                        "enum": ["hdc", "hdc-clumps"]
                      },
                      "description": "Repositories an augmentor may edit"
                    },
                    "delegatable_by": {
                      "type": "array",
                      "items": {
                        "type": "string",
                        "enum": [
                          "hdc-engineer",
                          "hdc-sre-engineer",
                          "hdc-manager",
                          "hdc-qa",
                          "hdc-research",
                          "hdc-security-expert",
                          "hdc-security-architect",
                          "hdc-network-architect"
                        ]
                      },
                      "description": "Fleet roles allowed to delegate subtasks to this augmentor"
                    },
                    "enabled": {
                      "type": "boolean",
                      "default": true,
                      "description": "When false, augmentor is registered but not offered for delegation"
                    }
                  }
                }
              }
            }
          },
          "install": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" },
              "compose_dir": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
