{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/kafka.config.schema.json",
  "title": "HDC kafka service package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "kafka", "deployments"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 2 },
    "kafka": {
      "type": "object",
      "required": ["cluster_id"],
      "properties": {
        "cluster_id": { "type": "string", "minLength": 1 },
        "version": { "type": "string" },
        "scala_version": { "type": "string" },
        "listener_port": { "type": "integer", "minimum": 1 },
        "controller_port": { "type": "integer", "minimum": 1 },
        "log_dirs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "defaults": { "type": "object" },
    "deployments": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["system_id", "node_id"],
        "properties": {
          "system_id": { "type": "string", "pattern": "^vm-kafka-[a-z]+$" },
          "node_id": { "type": "integer", "minimum": 1, "maximum": 3 },
          "hostname": { "type": "string" },
          "mode": { "enum": ["proxmox-qemu", "configure-only"] },
          "proxmox": { "type": "object" },
          "configure": { "type": "object" }
        }
      }
    }
  }
}
