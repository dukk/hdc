{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/vllm.config.schema.json",
  "title": "HDC vllm service package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "deployments"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 2 },
    "defaults": {
      "type": "object",
      "properties": {
        "mode": { "const": "proxmox-qemu" },
        "proxmox": { "type": "object" },
        "install": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "device": { "enum": ["cuda", "cpu"] },
            "compose_dir": { "type": "string" },
            "hf_cache_dir": { "type": "string" },
            "cuda_image": { "type": "string" },
            "cpu_image": { "type": "string" }
          }
        },
        "vllm": {
          "type": "object",
          "properties": {
            "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
            "host": { "type": "string" },
            "model": { "type": ["string", "null"] },
            "served_model_name": { "type": ["string", "null"] },
            "max_model_len": { "type": "integer", "minimum": 1 },
            "gpu_memory_utilization": { "type": "number", "minimum": 0, "maximum": 1 },
            "dtype": { "type": ["string", "null"] },
            "extra_args": { "type": "array", "items": { "type": "string" } },
            "cpu_kv_cache_space_gb": { "type": "number", "minimum": 0 },
            "public_url": { "type": ["string", "null"] },
            "hf_token_vault_key": { "type": "string" }
          }
        },
        "configure": { "type": "object" }
      }
    },
    "deployments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["system_id"],
        "properties": {
          "system_id": {
            "type": "string",
            "pattern": "^vm-vllm-[a-z]+$"
          },
          "mode": { "const": "proxmox-qemu" },
          "hostname": { "type": "string" },
          "configure": {
            "type": "object",
            "properties": {
              "ssh": {
                "type": "object",
                "properties": {
                  "user": { "type": "string" },
                  "host": { "type": "string" }
                }
              }
            }
          },
          "proxmox": {
            "type": "object",
            "properties": {
              "host_id": { "type": "string" },
              "network": { "type": "object" },
              "qemu": {
                "type": "object",
                "properties": {
                  "vmid": { "type": "number" },
                  "template_vmid": { "type": "number" },
                  "ip": { "type": "string" },
                  "hostpci": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["id"],
                      "properties": {
                        "id": { "type": "string" },
                        "pcie": { "type": "boolean" },
                        "rombar": { "type": "boolean" },
                        "xvga": { "type": "boolean" }
                      }
                    }
                  }
                }
              }
            }
          },
          "install": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" },
              "device": { "enum": ["cuda", "cpu"] },
              "compose_dir": { "type": "string" },
              "hf_cache_dir": { "type": "string" },
              "cuda_image": { "type": "string" },
              "cpu_image": { "type": "string" }
            }
          },
          "vllm": {
            "type": "object",
            "properties": {
              "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
              "host": { "type": "string" },
              "model": { "type": ["string", "null"] },
              "served_model_name": { "type": ["string", "null"] },
              "max_model_len": { "type": "integer", "minimum": 1 },
              "gpu_memory_utilization": { "type": "number", "minimum": 0, "maximum": 1 },
              "dtype": { "type": ["string", "null"] },
              "extra_args": { "type": "array", "items": { "type": "string" } },
              "cpu_kv_cache_space_gb": { "type": "number", "minimum": 0 },
              "public_url": { "type": ["string", "null"] },
              "hf_token_vault_key": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
