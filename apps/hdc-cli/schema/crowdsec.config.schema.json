{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/crowdsec.config.schema.json",
  "title": "HDC crowdsec service package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "deployments"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 2 },
    "defaults": { "type": "object" },
    "deployments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["system_id"],
        "properties": {
          "system_id": { "type": "string", "pattern": "^crowdsec-[a-z]+$" },
          "mode": { "enum": ["proxmox-lxc"] },
          "proxmox": { "type": "object" },
          "install": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" }
            }
          },
          "crowdsec": {
            "type": "object",
            "properties": {
              "lapi_port": { "type": "integer", "minimum": 1, "maximum": 65535 },
              "public_url": { "type": "string" },
              "enroll_key_vault_key": { "type": "string" },
              "hub_update": { "type": "boolean" },
              "collections": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "auto_registration_allowed_ranges": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "unifi": {
                "type": "object",
                "properties": {
                  "syslog": {
                    "type": "object",
                    "properties": {
                      "enabled": { "type": "boolean" },
                      "listen_port": { "type": "integer", "minimum": 1, "maximum": 65535 },
                      "allowed_senders": {
                        "type": "array",
                        "items": { "type": "string", "minLength": 1 }
                      },
                      "cef_split": { "type": "boolean" }
                    }
                  }
                }
              },
              "bouncers": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "type": { "enum": ["firewall", "unifi"] },
                    "enabled": { "type": ["boolean", "integer"] },
                    "system_id": { "type": "string" },
                    "group_name": { "type": "string", "minLength": 1 },
                    "max_decisions": { "type": "integer", "minimum": 1 },
                    "never_block_cidrs": {
                      "type": "array",
                      "items": { "type": "string", "minLength": 1 }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
