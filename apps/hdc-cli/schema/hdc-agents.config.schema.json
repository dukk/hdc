{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/hdc-agents.config.schema.json",
  "title": "HDC agent runtime fleet service package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "deployments"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 2 },
    "defaults": { "type": "object" },
    "deployments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["system_id"],
        "properties": {
          "system_id": { "type": "string", "pattern": "^hdc-agents-[a-z]+$" },
          "mode": { "enum": ["proxmox-lxc"] },
          "proxmox": { "type": "object" },
          "hdc_agents": {
            "type": "object",
            "properties": {
              "image_tag": { "type": "string" },
              "litellm_base_url": { "type": "string" },
              "default_model": { "type": "string" },
              "public_url": { "type": ["string", "null"] },
              "web": {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "admin_username": { "type": "string" },
                  "admin_password_vault_key": { "type": "string" }
                }
              },
              "oidc": {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "issuer": { "type": "string" },
                  "client_id": { "type": "string" },
                  "client_secret_vault_key": { "type": "string" }
                }
              },
              "agents": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "role": { "type": "string" },
                    "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
                    "enabled": { "type": "boolean" }
                  }
                }
              },
              "augmentation": {
                "type": "object",
                "properties": {
                  "enabled": { "type": "boolean" },
                  "sidecars": {
                    "type": "array",
                    "items": { "type": "string", "enum": ["cursor-cloud-bridge"] }
                  },
                  "cursor_cloud": {
                    "type": "object",
                    "properties": {
                      "bridge_name": { "type": "string" },
                      "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
                      "repos": {
                        "type": "array",
                        "items": { "type": "string", "enum": ["hdc", "hdc-clumps"] }
                      },
                      "delegatable_by": {
                        "type": "array",
                        "items": {
                          "type": "string",
                          "enum": ["hdc-engineer", "hdc-sre-engineer"]
                        }
                      },
                      "repository_url": { "type": "string", "format": "uri" }
                    }
                  }
                }
              },
              "notifications": {
                "type": "object",
                "properties": {
                  "channels": {
                    "type": "object",
                    "additionalProperties": true,
                    "properties": {
                      "email": { "type": "object", "additionalProperties": true },
                      "discord": { "type": "object", "additionalProperties": true },
                      "slack": { "type": "object", "additionalProperties": true },
                      "teams": { "type": "object", "additionalProperties": true },
                      "telegram": { "type": "object", "additionalProperties": true }
                    }
                  },
                  "routes": {
                    "type": "object",
                    "additionalProperties": {
                      "type": "array",
                      "items": {
                        "enum": ["discord", "email", "slack", "teams", "telegram"]
                      }
                    },
                    "properties": {
                      "needs_decision": {
                        "type": "array",
                        "items": { "enum": ["discord", "email", "slack", "teams", "telegram"] }
                      },
                      "mailbox_received": {
                        "type": "array",
                        "items": { "enum": ["discord", "email", "slack", "teams", "telegram"] }
                      },
                      "mailbox_spoof": {
                        "type": "array",
                        "items": { "enum": ["discord", "email", "slack", "teams", "telegram"] }
                      },
                      "mailbox_task_update": {
                        "type": "array",
                        "items": { "enum": ["discord", "email", "slack", "teams", "telegram"] }
                      }
                    }
                  }
                }
              }
            }
          },
          "install": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" },
              "compose_dir": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
