{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/postgresql.config.schema.json",
  "title": "HDC postgresql service package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "deployments"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 2 },
    "postgresql": {
      "type": "object",
      "properties": {
        "version_major": { "type": "integer", "minimum": 12 },
        "listen_addresses": { "type": "string" },
        "listen_cidrs": { "type": "array", "items": { "type": "string" } },
        "superuser_vault_key": { "type": "string" },
        "replication_vault_key": { "type": "string" },
        "replication_user": { "type": "string" },
        "databases": { "type": "array" },
        "roles": { "type": "array" }
      }
    },
    "defaults": { "type": "object" },
    "deployments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["system_id", "role"],
        "properties": {
          "system_id": { "type": "string", "pattern": "^vm-postgres-[a-z]+$" },
          "role": { "enum": ["standalone", "primary", "standby"] },
          "primary_system_id": { "type": "string" },
          "hostname": { "type": "string" },
          "mode": { "enum": ["proxmox-qemu", "configure-only"] },
          "proxmox": { "type": "object" },
          "configure": { "type": "object" },
          "databases": { "type": "array" },
          "roles": { "type": "array" }
        }
      }
    }
  }
}
