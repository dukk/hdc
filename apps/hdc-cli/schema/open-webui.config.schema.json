{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/open-webui.config.schema.json",
  "title": "HDC open-webui service package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "deployments"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 2 },
    "defaults": { "type": "object" },
    "deployments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["system_id"],
        "properties": {
          "system_id": { "type": "string", "pattern": "^open-webui-[a-z]+$" },
          "mode": { "enum": ["proxmox-lxc"] },
          "proxmox": { "type": "object" },
          "open_webui": {
            "type": "object",
            "properties": {
              "image_tag": { "type": "string" },
              "host_port": { "type": "integer", "minimum": 1, "maximum": 65535 },
              "public_url": { "type": ["string", "null"] },
              "secret_key_vault_key": { "type": "string" },
              "webui_auth": { "type": "boolean" },
              "ollama_backends": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["id", "url"],
                  "properties": {
                    "id": { "type": "string" },
                    "url": { "type": "string", "format": "uri" },
                    "notes": { "type": "string" }
                  }
                }
              },
              "openai_backends": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["id", "url", "api_key_vault_key"],
                  "properties": {
                    "id": { "type": "string" },
                    "url": { "type": "string", "format": "uri" },
                    "api_key_vault_key": { "type": "string" },
                    "model_ids": {
                      "type": "array",
                      "items": { "type": "string" }
                    },
                    "notes": { "type": "string" }
                  }
                }
              }
            }
          },
          "install": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" },
              "compose_dir": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
