{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/audiobookshelf.config.schema.json",
  "title": "HDC audiobookshelf service package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "deployments"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 2 },
    "defaults": { "type": "object" },
    "deployments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["system_id"],
        "properties": {
          "system_id": { "type": "string", "pattern": "^vm-audiobookshelf-[a-z]+$" },
          "mode": { "enum": ["proxmox-qemu", "configure-only"] },
          "hostname": { "type": "string" },
          "proxmox": { "type": "object" },
          "configure": {
            "type": "object",
            "properties": {
              "ssh": {
                "type": "object",
                "properties": {
                  "user": { "type": "string" },
                  "host": { "type": "string" }
                }
              }
            }
          },
          "audiobookshelf": {
            "type": "object",
            "properties": {
              "image_tag": { "type": "string" },
              "host_port": { "type": "integer", "minimum": 1, "maximum": 65535 },
              "public_url": { "type": "string" },
              "timezone": { "type": "string" }
            }
          },
          "install": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" },
              "compose_dir": { "type": "string" },
              "data_mount": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
