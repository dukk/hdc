{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/keycloak.config.schema.json",
  "title": "HDC keycloak service package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "deployments"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 2 },
    "defaults": { "type": "object" },
    "deployments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["system_id"],
        "properties": {
          "system_id": { "type": "string", "pattern": "^keycloak-[a-z]+$" },
          "mode": { "enum": ["proxmox-lxc"] },
          "proxmox": { "type": "object" },
          "install": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" },
              "compose_dir": { "type": "string" }
            }
          },
          "keycloak": {
            "type": "object",
            "properties": {
              "image_tag": { "type": "string" },
              "host_port": { "type": "integer", "minimum": 1, "maximum": 65535 },
              "public_url": { "type": "string", "pattern": "^https?://.+" },
              "external_url": { "type": "string", "pattern": "^https?://.+" },
              "api_url": {
                "anyOf": [
                  { "type": "string", "pattern": "^https?://.+" },
                  { "type": "null" }
                ]
              },
              "admin_user": { "type": "string" },
              "admin_password_vault_key": { "type": "string" },
              "database": {
                "type": "object",
                "properties": {
                  "mode": { "enum": ["bundled", "external"] }
                }
              },
              "realms": {
                "type": "array",
                "items": { "$ref": "#/$defs/realm" }
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "realmUser": {
      "type": "object",
      "required": ["username", "password_vault_key"],
      "additionalProperties": true,
      "properties": {
        "username": { "type": "string", "minLength": 1 },
        "email": { "type": "string" },
        "enabled": { "type": "boolean" },
        "email_verified": { "type": "boolean" },
        "first_name": { "type": "string" },
        "last_name": { "type": "string" },
        "password_vault_key": { "type": "string", "minLength": 1 },
        "temporary_password": { "type": "boolean" }
      }
    },
    "realmClient": {
      "type": "object",
      "required": ["client_id"],
      "additionalProperties": true,
      "properties": {
        "client_id": { "type": "string", "minLength": 1 },
        "name": { "type": "string" },
        "enabled": { "type": "boolean" },
        "protocol": { "type": "string" },
        "public_client": { "type": "boolean" },
        "standard_flow_enabled": { "type": "boolean" },
        "direct_access_grants_enabled": { "type": "boolean" },
        "service_accounts_enabled": { "type": "boolean" },
        "full_scope_allowed": { "type": "boolean" },
        "root_url": { "type": "string" },
        "base_url": { "type": "string" },
        "redirect_uris": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "web_origins": {
          "type": "array",
          "items": { "type": "string" }
        },
        "secret_vault_key": { "type": "string", "minLength": 1 }
      }
    },
    "realmIdentityProvider": {
      "type": "object",
      "required": ["alias", "provider_id", "client_id", "client_secret_vault_key"],
      "additionalProperties": true,
      "properties": {
        "alias": { "type": "string", "minLength": 1 },
        "provider_id": { "type": "string", "minLength": 1 },
        "enabled": { "type": "boolean" },
        "display_name": { "type": "string" },
        "trust_email": { "type": "boolean" },
        "store_token": { "type": "boolean" },
        "link_only": { "type": "boolean" },
        "first_broker_login_flow_alias": { "type": "string" },
        "sync_mode": { "type": "string", "enum": ["IMPORT", "FORCE", "LEGACY"] },
        "default_scope": { "type": "string" },
        "client_id": { "type": "string", "minLength": 1 },
        "client_secret_vault_key": { "type": "string", "minLength": 1 }
      }
    },
    "realm": {
      "type": "object",
      "required": ["realm"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "realm": { "type": "string", "minLength": 1, "not": { "const": "master" } },
        "enabled": { "type": "boolean" },
        "display_name": { "type": "string" },
        "login_with_email_allowed": { "type": "boolean" },
        "registration_allowed": { "type": "boolean" },
        "reset_password_allowed": { "type": "boolean" },
        "remember_me": { "type": "boolean" },
        "verify_email": { "type": "boolean" },
        "ssl_required": { "type": "string", "enum": ["external", "all", "none"] },
        "mail": { "$ref": "#/$defs/realmMail" },
        "users": {
          "type": "array",
          "items": { "$ref": "#/$defs/realmUser" }
        },
        "clients": {
          "type": "array",
          "items": { "$ref": "#/$defs/realmClient" }
        },
        "identity_providers": {
          "type": "array",
          "items": { "$ref": "#/$defs/realmIdentityProvider" }
        }
      }
    },
    "realmMail": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "from": { "type": "string" },
        "from_display_name": { "type": "string" },
        "reply_to": { "type": "string" }
      }
    }
  }
}
