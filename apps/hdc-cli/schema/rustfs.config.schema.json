{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/rustfs.config.schema.json",
  "title": "HDC RustFS service package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "deployments"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 2 },
    "rustfs": {
      "type": "object",
      "properties": {
        "image": { "type": "string" },
        "s3_port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "console_port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "drives_per_node": { "type": "integer", "minimum": 1, "maximum": 16 },
        "data_path_prefix": { "type": "string" },
        "access_key_vault_key": { "type": "string" },
        "secret_key_vault_key": { "type": "string" },
        "s3_public_url": { "type": "string" },
        "console_public_url": { "type": "string" },
        "console_cors_allowed_origins": { "type": "string" },
        "cluster_dns_suffix": { "type": "string" },
        "unsafe_bypass_disk_check": { "type": "boolean" }
      }
    },
    "defaults": { "type": "object" },
    "deployments": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "required": ["system_id"],
        "properties": {
          "system_id": { "type": "string", "pattern": "^rustfs-[a-z]+$" },
          "mode": { "enum": ["proxmox-lxc"] },
          "cluster": {
            "type": "object",
            "properties": {
              "peer_hostname": { "type": "string" }
            }
          },
          "proxmox": { "type": "object" },
          "rustfs": { "type": "object" },
          "install": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" },
              "compose_dir": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
