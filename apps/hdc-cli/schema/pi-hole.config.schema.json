{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/pi-hole.config.schema.json",
  "title": "HDC pi-hole service package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "deployments"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 2 },
    "defaults": { "type": "object" },
    "deployments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["system_id"],
        "properties": {
          "system_id": { "type": "string", "pattern": "^pi-hole-[a-z]+$" },
          "mode": { "enum": ["proxmox-lxc"] },
          "proxmox": { "type": "object" },
          "pihole": {
            "type": "object",
            "properties": {
              "upstream_dns": {
                "type": "array",
                "items": { "type": "string" }
              },
              "listening_mode": {
                "enum": ["LOCAL", "SINGLE", "ALL", "BIND"]
              },
              "webpassword": { "type": "string" },
              "interface": { "type": "string" },
              "allowlist": {
                "type": "array",
                "items": {
                  "oneOf": [
                    { "type": "string" },
                    {
                      "type": "object",
                      "required": ["domain"],
                      "properties": {
                        "domain": { "type": "string" },
                        "comment": { "type": "string" }
                      }
                    }
                  ]
                }
              },
              "local_dns": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "type": { "type": "string" },
                    "name": { "type": "string" },
                    "data": { "type": "string" }
                  }
                }
              },
              "api_token_vault_key": { "type": "string" },
              "webpassword_vault_key": { "type": "string" }
            }
          },
          "install": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" }
            }
          }
        }
      }
    }
  }
}
