{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "windows-desktop package config",
  "type": "object",
  "required": ["deployments"],
  "additionalProperties": true,
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "windows_desktop": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "admin_vault_key": { "type": "string", "minLength": 1 },
        "admin_username": { "type": "string", "minLength": 1 },
        "locale": { "type": "string", "minLength": 2 }
      }
    },
    "defaults": { "type": "object", "additionalProperties": true },
    "deployments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["system_id"],
        "additionalProperties": true,
        "properties": {
          "system_id": {
            "type": "string",
            "pattern": "^vm-(win11|windows)-[a-z]+$"
          },
          "hostname": { "type": "string" },
          "mode": {
            "type": "string",
            "enum": ["proxmox-qemu-iso", "proxmox-qemu-clone"]
          },
          "proxmox": { "type": "object", "additionalProperties": true },
          "configure": { "type": "object", "additionalProperties": true }
        }
      }
    }
  }
}
