{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/oci-compute.config.schema.json",
  "title": "HDC oci-compute infrastructure package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "oci"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "oci": {
      "type": "object",
      "required": ["compartment_id"],
      "properties": {
        "region": { "type": "string" },
        "compartment_id": { "type": "string" },
        "availability_domain": { "type": "string" },
        "default_tags": { "type": "object", "additionalProperties": { "type": "string" } }
      }
    },
    "cost": {
      "type": "object",
      "properties": {
        "confirm_before_deploy": { "type": "boolean" },
        "hours_per_month": { "type": "number", "minimum": 1 }
      }
    },
    "vcns": { "type": "array", "items": { "$ref": "#/$defs/vcn" } },
    "subnets": { "type": "array", "items": { "$ref": "#/$defs/subnet" } },
    "network_security_groups": { "type": "array", "items": { "$ref": "#/$defs/nsg" } },
    "instances": { "type": "array", "items": { "$ref": "#/$defs/instance" } },
    "container_instances": { "type": "array", "items": { "$ref": "#/$defs/container_instance" } }
  },
  "$defs": {
    "managed": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "managed": { "type": "boolean" },
        "tags": { "type": "object", "additionalProperties": { "type": "string" } }
      }
    },
    "vcn": {
      "allOf": [
        { "$ref": "#/$defs/managed" },
        {
          "type": "object",
          "required": ["cidr"],
          "properties": {
            "cidr": { "type": "string" },
            "dns_label": { "type": "string" }
          }
        }
      ]
    },
    "subnet": {
      "allOf": [
        { "$ref": "#/$defs/managed" },
        {
          "type": "object",
          "required": ["vcn_id", "cidr"],
          "properties": {
            "vcn_id": { "type": "string" },
            "cidr": { "type": "string" },
            "public": { "type": "boolean" },
            "dns_label": { "type": "string" }
          }
        }
      ]
    },
    "nsg": {
      "allOf": [
        { "$ref": "#/$defs/managed" },
        {
          "type": "object",
          "required": ["vcn_id"],
          "properties": {
            "vcn_id": { "type": "string" },
            "ingress": { "type": "array", "items": { "$ref": "#/$defs/nsg_rule" } },
            "egress": { "type": "array", "items": { "$ref": "#/$defs/nsg_rule" } }
          }
        }
      ]
    },
    "nsg_rule": {
      "type": "object",
      "properties": {
        "protocol": { "type": "string" },
        "port_min": { "type": "integer", "minimum": 0 },
        "port_max": { "type": "integer", "minimum": 0 },
        "source": { "type": "string" },
        "destination": { "type": "string" }
      }
    },
    "instance": {
      "allOf": [
        { "$ref": "#/$defs/managed" },
        {
          "type": "object",
          "required": ["system_id", "subnet_id", "image_ocid"],
          "properties": {
            "system_id": { "type": "string" },
            "subnet_id": { "type": "string" },
            "nsg_ids": { "type": "array", "items": { "type": "string" } },
            "shape": { "type": "string" },
            "ocpus": { "type": "number", "minimum": 0.01 },
            "memory_gb": { "type": "number", "minimum": 1 },
            "boot_volume_gb": { "type": "number", "minimum": 10 },
            "image_ocid": { "type": "string" },
            "assign_public_ip": { "type": "boolean" }
          }
        }
      ]
    },
    "container_instance": {
      "allOf": [
        { "$ref": "#/$defs/managed" },
        {
          "type": "object",
          "required": ["system_id", "subnet_id", "containers"],
          "properties": {
            "system_id": { "type": "string" },
            "subnet_id": { "type": "string" },
            "nsg_ids": { "type": "array", "items": { "type": "string" } },
            "shape": { "type": "string" },
            "ocpus": { "type": "number", "minimum": 0.01 },
            "memory_gb": { "type": "number", "minimum": 1 },
            "assign_public_ip": { "type": "boolean" },
            "containers": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["name", "image"],
                "properties": {
                  "name": { "type": "string" },
                  "image": { "type": "string" },
                  "ports": { "type": "array", "items": { "type": "integer", "minimum": 1 } }
                }
              }
            }
          }
        }
      ]
    }
  }
}
