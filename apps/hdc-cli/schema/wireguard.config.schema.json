{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/wireguard.config.schema.json",
  "title": "HDC wireguard service package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "deployments"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 2 },
    "defaults": { "type": "object" },
    "deployments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["system_id"],
        "properties": {
          "system_id": { "type": "string", "pattern": "^wireguard-[a-z]+$" },
          "mode": { "enum": ["proxmox-lxc"] },
          "proxmox": { "type": "object" },
          "install": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" }
            }
          },
          "wireguard": {
            "type": "object",
            "properties": {
              "interface_address": { "type": "string" },
              "listen_port": { "type": "integer", "minimum": 1, "maximum": 65535 },
              "private_key_vault_key": { "type": "string" },
              "post_up": { "type": "string" },
              "post_down": { "type": "string" },
              "peers": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["name", "public_key_vault_key", "preshared_key_vault_key", "allowed_ips"],
                  "properties": {
                    "name": { "type": "string" },
                    "public_key_vault_key": { "type": "string" },
                    "preshared_key_vault_key": { "type": "string" },
                    "allowed_ips": { "type": "array", "minItems": 1, "items": { "type": "string" } }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
