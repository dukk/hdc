{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/wallabag.config.schema.json",
  "title": "HDC wallabag service package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "deployments"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 2 },
    "defaults": { "type": "object" },
    "deployments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["system_id"],
        "properties": {
          "system_id": { "type": "string", "pattern": "^wallabag-[a-z]+$" },
          "mode": { "enum": ["proxmox-lxc"] },
          "proxmox": { "type": "object" },
          "wallabag": {
            "type": "object",
            "properties": {
              "image_tag": { "type": "string" },
              "mariadb_image_tag": { "type": "string" },
              "redis_image_tag": { "type": "string" },
              "host_port": { "type": "integer", "minimum": 1, "maximum": 65535 },
              "public_url": { "type": "string" },
              "server_name": { "type": "string" },
              "timezone": { "type": "string" },
              "db_password_vault_key": { "type": "string" },
              "secret_vault_key": { "type": "string" },
              "mail": {
                "type": "object",
                "properties": {
                  "enabled": { "type": "boolean" },
                  "from": { "type": "string" }
                }
              }
            }
          },
          "install": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" },
              "compose_dir": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
