{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/nextcloud.config.schema.json",
  "title": "HDC nextcloud service package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "deployments"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 2 },
    "defaults": { "type": "object" },
    "deployments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["system_id"],
        "properties": {
          "system_id": { "type": "string", "pattern": "^nextcloud-[a-z]+$" },
          "mode": { "enum": ["proxmox-lxc"] },
          "proxmox": { "type": "object" },
          "nextcloud": {
            "type": "object",
            "properties": {
              "aio": {
                "type": "object",
                "properties": {
                  "image_channel": { "type": "string", "enum": ["latest", "beta"] },
                  "interface_host_port": { "type": "integer", "minimum": 1, "maximum": 65535 },
                  "reverse_proxy": {
                    "type": "object",
                    "properties": {
                      "enabled": { "type": "boolean" },
                      "domain": { "type": ["string", "null"] },
                      "apache_port": { "type": "integer", "minimum": 1, "maximum": 65535 }
                    }
                  }
                }
              }
            }
          },
          "install": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" },
              "compose_dir": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
