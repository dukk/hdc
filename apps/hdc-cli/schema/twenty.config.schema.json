{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/twenty.config.schema.json",
  "title": "HDC twenty service package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "deployments"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 2 },
    "defaults": { "type": "object" },
    "deployments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["system_id"],
        "properties": {
          "system_id": {
            "type": "string",
            "pattern": "^(twenty|vm-twenty)-[a-z]+$"
          },
          "mode": { "enum": ["proxmox-lxc", "proxmox-qemu"] },
          "hostname": { "type": "string" },
          "configure": {
            "type": "object",
            "properties": {
              "ssh": {
                "type": "object",
                "properties": {
                  "host": { "type": "string" },
                  "user": { "type": "string" }
                }
              }
            }
          },
          "proxmox": { "type": "object" },
          "twenty": {
            "type": "object",
            "properties": {
              "image_tag": { "type": "string" },
              "postgres_image_tag": { "type": "string" },
              "redis_image_tag": { "type": "string" },
              "host_port": { "type": "integer", "minimum": 1, "maximum": 65535 },
              "public_url": { "type": "string" },
              "storage_type": { "enum": ["local", "s3"] },
              "multi_workspace_enabled": { "type": "boolean" },
              "encryption_key_vault_key": { "type": "string" },
              "fallback_encryption_key_vault_key": { "type": "string" },
              "db_password_vault_key": { "type": "string" },
              "db_name": { "type": "string" },
              "db_user": { "type": "string" },
              "mail": { "type": "object" },
              "storage_s3": { "type": "object" }
            }
          },
          "install": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" },
              "compose_dir": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
