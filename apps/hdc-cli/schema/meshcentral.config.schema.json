{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/meshcentral.config.schema.json",
  "title": "HDC MeshCentral service package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "deployments"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 2 },
    "defaults": { "type": "object" },
    "deployments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["system_id"],
        "properties": {
          "system_id": { "type": "string", "pattern": "^meshcentral-[a-z]+$" },
          "mode": { "enum": ["proxmox-lxc"] },
          "proxmox": { "type": "object" },
          "meshcentral": {
            "type": "object",
            "properties": {
              "image_tag": { "type": "string" },
              "public_url": { "type": "string" },
              "hostname": { "type": ["string", "null"] },
              "trusted_proxies": {
                "type": "array",
                "items": { "type": "string" }
              },
              "allow_new_accounts": { "type": "boolean" },
              "mongo_username": { "type": "string" },
              "mongo_database": { "type": "string" },
              "mongo_password_vault_key": { "type": "string" },
              "api": {
                "type": "object",
                "properties": {
                  "username_vault_key": { "type": "string" },
                  "password_vault_key": { "type": "string" },
                  "url": { "type": ["string", "null"] }
                }
              },
              "devices": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string" },
                    "name": { "type": "string" },
                    "node_id": { "type": ["string", "null"] },
                    "platform": {
                      "type": "string",
                      "enum": ["windows", "linux", "unknown"]
                    },
                    "managed": { "type": "boolean" }
                  }
                }
              }
            }
          },
          "install": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" },
              "compose_dir": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
