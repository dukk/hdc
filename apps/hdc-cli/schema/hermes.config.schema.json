{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/hermes.config.schema.json",
  "title": "HDC hermes service package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "deployments"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 2 },
    "defaults": { "type": "object" },
    "deployments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["system_id"],
        "properties": {
          "system_id": { "type": "string", "pattern": "^hermes-[a-z]+$" },
          "mode": { "enum": ["proxmox-lxc", "proxmox-qemu"] },
          "hostname": { "type": "string" },
          "proxmox": { "type": "object" },
          "configure": { "type": "object" },
          "hermes": {
            "type": "object",
            "properties": {
              "image_tag": { "type": "string" },
              "api_port": { "type": "integer", "minimum": 1, "maximum": 65535 },
              "dashboard_port": { "type": "integer", "minimum": 1, "maximum": 65535 },
              "dashboard_enabled": { "type": "boolean" },
              "dashboard_username": { "type": "string" },
              "openrouter_api_key_vault_key": { "type": "string" },
              "dashboard_password_vault_key": { "type": "string" },
              "dashboard_auth_secret_vault_key": { "type": "string" },
              "searxng_url": { "type": ["string", "null"] },
              "ollama_backends": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["id", "url"],
                  "properties": {
                    "id": { "type": "string" },
                    "url": { "type": "string" },
                    "primary": { "type": "boolean" },
                    "notes": { "type": "string" }
                  }
                }
              },
              "model": {
                "type": "object",
                "properties": {
                  "default": { "type": "string" },
                  "context_length": { "type": "integer", "minimum": 1 }
                }
              },
              "fallback_providers": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["provider", "model"],
                  "properties": {
                    "provider": { "type": "string" },
                    "model": { "type": "string" }
                  }
                }
              },
              "agent": {
                "type": "object",
                "properties": {
                  "api_timeout": { "type": "integer", "minimum": 1 }
                }
              },
              "discord": {
                "type": "object",
                "properties": {
                  "enabled": { "type": "boolean" },
                  "bot_token_vault_key": { "type": "string" },
                  "require_mention": { "type": "boolean" },
                  "free_response_channels": { "type": "string" },
                  "auto_thread": { "type": "boolean" }
                }
              },
              "config_extra": { "type": "object" },
              "env_extra": { "type": "object" }
            }
          },
          "install": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" },
              "compose_dir": { "type": "string" },
              "data_subdir": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
