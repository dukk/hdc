{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/zabbix.config.schema.json",
  "title": "HDC zabbix service package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "deployments"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 2 },
    "defaults": { "type": "object" },
    "deployments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["system_id"],
        "properties": {
          "system_id": {
            "type": "string",
            "pattern": "^(zabbix-[a-z]+|vm-zabbix-[a-z]+)$"
          },
          "mode": { "enum": ["proxmox-lxc", "proxmox-qemu"] },
          "proxmox": { "type": "object" },
          "configure": { "type": "object" },
          "zabbix": {
            "type": "object",
            "properties": {
              "release": { "type": "string" },
              "database": { "enum": ["pgsql", "mysql"] },
              "web_http_port": { "type": "integer", "minimum": 1, "maximum": 65535 },
              "server_port": { "type": "integer", "minimum": 1, "maximum": 65535 },
              "public_url": { "type": "string" },
              "db_password_vault_key": { "type": "string" },
              "db_root_password_vault_key": { "type": "string" }
            }
          },
          "install": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" },
              "compose_dir": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
