{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/uptimerobot.config.schema.json",
  "title": "HDC uptimerobot infrastructure package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "uptimerobot", "monitors", "status_pages", "alert_contacts"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "uptimerobot": {
      "type": "object",
      "properties": {
        "api_base_url": { "type": "string", "format": "uri" },
        "primary_status_page_url": { "type": ["string", "null"], "format": "uri" },
        "auth": {
          "type": "object",
          "properties": {
            "api_key_vault_key": { "type": "string", "minLength": 1 }
          }
        },
        "account": {
          "type": "object",
          "properties": {
            "email": { "type": ["string", "null"] },
            "monitor_limit": { "type": ["integer", "null"] },
            "monitor_interval": { "type": ["integer", "null"] },
            "up_monitors": { "type": ["integer", "null"] },
            "down_monitors": { "type": ["integer", "null"] },
            "pause_monitors": { "type": ["integer", "null"] }
          }
        }
      }
    },
    "monitors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "uptimerobot_id", "friendly_name", "type", "interval_seconds", "status", "managed"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "uptimerobot_id": { "type": "integer" },
          "friendly_name": { "type": "string" },
          "type": { "type": "string" },
          "url": { "type": ["string", "null"] },
          "interval_seconds": { "type": "integer", "minimum": 1 },
          "status": { "type": "string" },
          "managed": { "type": "boolean" },
          "notes": { "type": ["string", "null"] },
          "alert_contacts": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["contact_id", "threshold", "recurrence"],
              "properties": {
                "contact_id": { "type": "string" },
                "threshold": { "type": "integer" },
                "recurrence": { "type": "integer" }
              }
            }
          },
          "options": { "type": "object" }
        }
      }
    },
    "status_pages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "uptimerobot_id", "friendly_name", "monitors", "sort", "status", "managed"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "uptimerobot_id": { "type": "integer" },
          "friendly_name": { "type": "string" },
          "standard_url": { "type": ["string", "null"], "format": "uri" },
          "custom_url": { "type": ["string", "null"] },
          "monitors": {
            "oneOf": [
              { "const": "all" },
              { "type": "array", "items": { "type": "string" } }
            ]
          },
          "sort": { "type": "string" },
          "status": { "type": "string" },
          "managed": { "type": "boolean" },
          "notes": { "type": ["string", "null"] }
        }
      }
    },
    "alert_contacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "uptimerobot_id", "friendly_name", "type", "status", "managed"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "uptimerobot_id": { "type": "integer" },
          "friendly_name": { "type": "string" },
          "type": { "type": "string" },
          "value": { "type": ["string", "null"] },
          "status": { "type": "string" },
          "managed": { "type": "boolean" },
          "notes": { "type": ["string", "null"] }
        }
      }
    }
  }
}
