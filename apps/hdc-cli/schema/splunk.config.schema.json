{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/splunk.config.schema.json",
  "title": "HDC splunk service package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "deployments"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "splunk": {
      "type": "object",
      "properties": {
        "version": { "type": "string" },
        "build": { "type": "string" },
        "license": { "enum": ["free"] },
        "admin_vault_key": { "type": "string" },
        "http_port": { "type": "integer", "minimum": 1 },
        "mgmt_port": { "type": "integer", "minimum": 1 },
        "splunk_home": { "type": "string" },
        "var_mount": { "type": "string" }
      }
    },
    "defaults": { "type": "object" },
    "deployments": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": {
        "type": "object",
        "required": ["system_id", "role"],
        "properties": {
          "system_id": { "type": "string", "pattern": "^vm-splunk-[a-z]+$" },
          "role": { "enum": ["standalone"] },
          "hostname": { "type": "string" },
          "mode": { "enum": ["proxmox-qemu", "configure-only"] },
          "proxmox": { "type": "object" },
          "configure": { "type": "object" },
          "splunk": { "type": "object" },
          "install": { "type": "object" }
        }
      }
    }
  }
}
