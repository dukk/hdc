{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/trivy.config.schema.json",
  "title": "HDC trivy service package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "deployments"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 2 },
    "defaults": { "type": "object" },
    "deployments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["system_id"],
        "properties": {
          "system_id": { "type": "string", "pattern": "^trivy-[a-z]+$" },
          "mode": { "enum": ["proxmox-lxc"] },
          "proxmox": { "type": "object" },
          "install": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" }
            }
          },
          "trivy": {
            "type": "object",
            "properties": {
              "version": { "type": "string" },
              "scan_targets": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["host"],
                  "properties": {
                    "id": { "type": "string" },
                    "host": { "type": "string" },
                    "ssh_user": { "type": "string" },
                    "paths": { "type": "array", "items": { "type": "string" } },
                    "docker_compose_dirs": { "type": "array", "items": { "type": "string" } }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
