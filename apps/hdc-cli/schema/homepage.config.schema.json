{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/homepage.config.schema.json",
  "title": "HDC homepage service package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "deployments"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 2 },
    "defaults": { "type": "object" },
    "deployments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["system_id"],
        "properties": {
          "system_id": { "type": "string", "pattern": "^homepage-[a-z]+$" },
          "mode": { "enum": ["proxmox-lxc"] },
          "proxmox": { "type": "object" },
          "homepage": {
            "type": "object",
            "properties": {
              "image_tag": { "type": "string" },
              "host_port": { "type": "integer", "minimum": 1, "maximum": 65535 },
              "public_url": { "type": "string", "pattern": "^https://.+" },
              "allowed_hosts": {
                "type": "array",
                "items": { "type": "string" },
                "minItems": 1
              },
              "config_files": {
                "type": "object",
                "required": ["services", "settings", "bookmarks"],
                "properties": {
                  "services": { "type": "string", "minLength": 1 },
                  "settings": { "type": "string", "minLength": 1 },
                  "bookmarks": { "type": "string", "minLength": 1 },
                  "widgets": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Optional header info widgets (datetime, search, resources, …)."
                  }
                },
                "additionalProperties": false
              },
              "proxmox_widget": {
                "type": "object",
                "properties": {
                  "enabled": { "type": ["boolean", "integer"] },
                  "service_account_id": {
                    "type": "string",
                    "description": "References provision.service_accounts[].id in proxmox config."
                  },
                  "hosts": {
                    "type": "array",
                    "items": { "type": "string", "minLength": 1 },
                    "description": "Proxmox host ids for per-node widget URL env vars."
                  },
                  "tls_insecure": {
                    "type": "boolean",
                    "description": "When true (default), set NODE_TLS_REJECT_UNAUTHORIZED=0 in the Homepage container for self-signed PVE HTTPS."
                  }
                },
                "additionalProperties": false
              },
              "pihole_widget": {
                "type": "object",
                "properties": {
                  "enabled": { "type": ["boolean", "integer"] },
                  "version": {
                    "type": "integer",
                    "minimum": 5,
                    "description": "Pi-hole API version for gethomepage widget (6 for Pi-hole v6+)."
                  },
                  "instances": {
                    "type": "array",
                    "items": { "type": "string", "minLength": 1 },
                    "description": "Instance letters (a, b) or system_ids (pi-hole-a); empty = all deployments."
                  }
                },
                "additionalProperties": false
              },
              "immich_widget": {
                "type": "object",
                "properties": {
                  "enabled": { "type": ["boolean", "integer"] }
                },
                "additionalProperties": false
              },
              "glances_widget": {
                "type": "object",
                "properties": {
                  "enabled": { "type": ["boolean", "integer"] }
                },
                "additionalProperties": false
              },
              "homeassistant_widget": {
                "type": "object",
                "properties": {
                  "enabled": { "type": ["boolean", "integer"] },
                  "token_vault_key": {
                    "type": "string",
                    "description": "Vault key for HA long-lived access token (default HDC_HOMEPAGE_HA_TOKEN)."
                  }
                },
                "additionalProperties": false
              },
              "plex_widget": {
                "type": "object",
                "properties": {
                  "enabled": { "type": ["boolean", "integer"] },
                  "url": {
                    "type": "string",
                    "description": "Plex Media Server base URL (default http://192.0.2.9:32400)."
                  },
                  "token_vault_key": {
                    "type": "string",
                    "description": "Vault key for Plex token (default HDC_HOMEPAGE_PLEX_TOKEN)."
                  }
                },
                "additionalProperties": false
              },
              "audiobookshelf_widget": {
                "type": "object",
                "properties": {
                  "enabled": { "type": ["boolean", "integer"] },
                  "token_vault_key": {
                    "type": "string",
                    "description": "Vault key for Audiobookshelf admin API token (default HDC_HOMEPAGE_AUDIOBOOKSHELF_TOKEN)."
                  },
                  "library_buckets": {
                    "type": "object",
                    "description": "Optional exact library name → bucket overrides for customapi stats (audiobooks, ebooks, other). Unlisted libraries use folder/name heuristics.",
                    "properties": {
                      "audiobooks": {
                        "type": "array",
                        "items": { "type": "string", "minLength": 1 }
                      },
                      "ebooks": {
                        "type": "array",
                        "items": { "type": "string", "minLength": 1 }
                      },
                      "other": {
                        "type": "array",
                        "items": { "type": "string", "minLength": 1 }
                      }
                    },
                    "additionalProperties": false
                  }
                },
                "additionalProperties": false
              },
              "uptime_kuma_widget": {
                "type": "object",
                "properties": {
                  "enabled": { "type": ["boolean", "integer"] },
                  "slug": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Default Uptime Kuma status page slug (URL path after /status/) for the first instance."
                  },
                  "instances": {
                    "type": "array",
                    "items": { "type": "string", "minLength": 1 },
                    "description": "uptime-kuma deployment instance flags (e.g. a, ext-a). Default [a] when omitted."
                  },
                  "slugs": {
                    "type": "object",
                    "additionalProperties": { "type": "string", "minLength": 1 },
                    "description": "Per-instance status page slug overrides (keys match instances[], e.g. ext-a)."
                  }
                },
                "additionalProperties": false
              },
              "crowdsec_widget": {
                "type": "object",
                "properties": {
                  "enabled": { "type": ["boolean", "integer"] },
                  "token_vault_key": {
                    "type": "string",
                    "description": "Vault key for LAPI password (default HDC_HOMEPAGE_CROWDSEC_LAPI_PASSWORD)."
                  },
                  "machine_id": {
                    "type": "string",
                    "description": "CrowdSec machine_id for widget username (default localhost)."
                  }
                },
                "additionalProperties": false
              },
              "unifi_widget": {
                "type": "object",
                "properties": {
                  "enabled": { "type": ["boolean", "integer"] },
                  "api_key_vault_key": {
                    "type": "string",
                    "description": "Vault key for UniFi Integration API key (default HDC_UNIFI_NETWORK_API_KEY)."
                  },
                  "site": {
                    "type": "string",
                    "description": "Optional site name override; default from unifi-network default_site_id."
                  }
                },
                "additionalProperties": false
              },
              "diskstation_widget": {
                "type": "object",
                "properties": {
                  "enabled": { "type": ["boolean", "integer"] },
                  "port": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 65535,
                    "description": "DSM HTTP port for gethomepage diskstation widget (default 5000)."
                  },
                  "instances": {
                    "type": "array",
                    "items": { "type": "string", "minLength": 1 },
                    "description": "Synology instance letters (a, b); default both when omitted."
                  },
                  "usernames": {
                    "type": "object",
                    "additionalProperties": { "type": "string", "minLength": 1 },
                    "description": "Per-instance DSM username overrides (keys match instances[], e.g. a, b)."
                  }
                },
                "additionalProperties": false
              },
              "mailcow_widget": {
                "type": "object",
                "properties": {
                  "enabled": { "type": ["boolean", "integer"] }
                },
                "additionalProperties": false
              },
              "bind_widget": {
                "type": "object",
                "properties": {
                  "enabled": { "type": ["boolean", "integer"] }
                },
                "additionalProperties": false
              }
            },
            "required": ["allowed_hosts", "config_files"]
          },
          "install": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" },
              "compose_dir": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
