# Copy to `.env` in the repo root (never commit `.env`).
# Values are optional unless a plugin declares `env_required` in its manifest.

# Optional: path to the private hdc-private repo (package config.json + inventory).
# Default when unset: sibling directory ../hdc-private next to this repo if it exists.
# HDC_PRIVATE_ROOT=C:/dev/dukk/hdc-private

# Default for all HDC HTTPS clients that support it: when set to 1, accept self-signed / untrusted certs
# if the integration-specific variable is unset or empty (e.g. HDC_PROXMOX_TLS_INSECURE, HDC_UNIFI_TLS_INSECURE).
# A non-empty per-integration value wins (only "1" disables verification for that integration).
# HDC_TLS_INSECURE=1

# Passphrase for the encrypted secrets vault at ~/.hdc/vault.enc (see `node tools/hdc/cli.mjs secrets path`).
# If set to the correct passphrase, scripts unlock the vault without prompting. Otherwise the CLI prompts
# when a command needs the vault. Creating a new vault: use `secrets init` (prompts twice) or set this once.
# Rotating the passphrase: `node tools/hdc/cli.mjs secrets change-passphrase`, then update this variable.
# Other secrets are stored inside the vault; scripts load them on demand via `createVaultAccess` / `getSecret`
# in `tools/hdc/lib/vault-access.mjs` (not merged into process.env at startup).
# Export to disk (plaintext, mode 0600; use a path outside this repo, never commit):
# node tools/hdc/cli.mjs secrets get HDC_EXAMPLE --out %USERPROFILE%\.hdc\export\HDC_EXAMPLE
# node tools/hdc/cli.mjs secrets dump --out-dir %USERPROFILE%\.hdc\export
# HDC_VAULT_PASSPHRASE=choose-a-strong-passphrase

# Secret backend: local (~/.hdc/vault.enc only), vaultwarden (Bitwarden CLI + Vaultwarden server), or auto (default).
# auto uses Vaultwarden when HDC_VAULTWARDEN_URL and HDC_VAULTWARDEN_EMAIL are set; falls back to local if bw/server unavailable.
# HDC_SECRET_BACKEND=auto
# HDC_VAULTWARDEN_URL=https://vault.dukk.org  (legacy alias: https://vault.hdc.dukk.org)
# HDC_VAULTWARDEN_EMAIL=you@example.com
# HDC organization + collection for automation secrets (bw list organizations / bw list org-collections --organizationid <orgId>):
# HDC_VAULTWARDEN_ORGANIZATION_ID=<uuid>   # optional when HDC_VAULTWARDEN_ORGANIZATION_NAME resolves (default name: HDC)
# HDC_VAULTWARDEN_ORGANIZATION_NAME=HDC
# HDC_VAULTWARDEN_COLLECTION_ID=<uuid>     # required when Vaultwarden backend is active
# Bulk migrate local vault -> Vaultwarden org: node tools/hdc/cli.mjs secrets push -- --force
# Optional: path to bw when not on PATH (Windows: install from bitwarden.com/help/cli/)
# Optional: only when bw is not on PATH. On Windows do not set this to npm bw.cmd — hdc resolves @bitwarden/cli automatically.
# HDC_BW_EXECUTABLE=C:/path/to/bw.exe
# Vaultwarden master password (optional — prompted on unlock; opt-in save after first successful unlock):
# node tools/hdc/cli.mjs secrets set HDC_VAULTWARDEN_MASTER_PASSWORD
# HDC_VAULTWARDEN_MASTER_PASSWORD=
# Example: SSH user for Proxmox automation (referenced from inventory sidecars)
# HDC_PROXMOX_SSH_USER=root
# Per-hypervisor SSH passwords (prompted on first failed connection, then stored in vault):
# HDC_PROXMOX_SSH_PASSWORD_HYPERVISOR_A, HDC_PROXMOX_SSH_PASSWORD_HYPERVISOR_B, …

# Proxmox VE API token for `node tools/hdc/cli.mjs run infrastructure proxmox query` (preferred: store as HDC_PROXMOX_API_TOKEN in the vault).
# Value may be `user@realm!tokenid=secret` or the full `PVEAPIToken=...` form. Per-host vault override: HDC_PROXMOX_API_TOKEN_HYPERVISOR_A, etc.
# After replacing or reinstalling a node, update the matching per-host vault key (maintain/query prompt if the stored token no longer verifies).
# `run infrastructure proxmox maintain` can auto-create per-host tokens named hdc-<this-machine-hostname> (e.g. hdc-dukk-lap) via SSH/pveum when missing.
#
# Service accounts (provision.service_accounts[] in proxmox config) — e.g. homepage Proxmox widget:
# HDC_PROXMOX_USER_HOMEPAGE_PASSWORD=...   (auto-generated on first maintain)
# HDC_HOMEPAGE_PROXMOX_API_TOKEN=homepage@pam!homepage=...
# HDC_PROXMOX_API_TOKEN=root@pam!hdc-token=xxxxxxxx
# If the API presents a self-signed certificate: HDC_PROXMOX_TLS_INSECURE=1 (or set HDC_TLS_INSECURE=1 globally)

# Per-inventory `hdc` local user passwords are written by `node tools/hdc/cli.mjs users bootstrap-hdc`
# as `HDC_USER_HDC_PASSWORD_<INVENTORY_ID_UPPER_SNAKE>` (see vault: `secrets list`).

# Local sudo admin on Linux Proxmox guests (service maintain baseline). Username in .env; password in vault.
# HDC_ADMIN_USER=your-linux-username
# node tools/hdc/cli.mjs secrets set HDC_ADMIN_USER_PASSWORD
# Default SSH user for Proxmox Ubuntu guests (configure.ssh.user overrides)
# HDC_GUEST_SSH_USER=hdc

# SSH user for the central Nagios host (`inventory/manual/systems/hypervisor-a.json` nagios.auth).
# If unset, Nagios deploy falls back to HDC_PROXMOX_SSH_USER for the central host.
# HDC_NAGIOS_SSH_USER=root

# Proxmox LXC root password when creating guests non-interactively (or set proxmox.lxc.password in package config).
# HDC_PROXMOX_LXC_ROOT_PASSWORD=

# Postfix relay / SMTP2GO (`packages/services/postfix-relay`) — smtp2go username and password (prefer vault).
# node tools/hdc/cli.mjs secrets set HDC_POSTFIX_RELAY_SMTP_USER
# node tools/hdc/cli.mjs secrets set HDC_POSTFIX_RELAY_SMTP_PASSWORD
# HDC_POSTFIX_RELAY_SMTP_USER=
# HDC_POSTFIX_RELAY_SMTP_PASSWORD=

# SMTP2GO API (`packages/infrastructure/smtp2go`) — sender domains; separate from postfix-relay SMTP creds.
# node tools/hdc/cli.mjs secrets set HDC_SMTP2GO_API_KEY
# HDC_SMTP2GO_API_KEY=

# UptimeRobot API (`packages/infrastructure/uptimerobot`) — monitors, status pages, alert contacts.
# node tools/hdc/cli.mjs secrets set HDC_UPTIMEROBOT_API_KEY
# HDC_UPTIMEROBOT_API_KEY=

# OpenRouter Management API (`packages/infrastructure/openrouter`) — credits and key admin; not for chat completions.
# Inference keys for consumers stay separate (e.g. HDC_HERMES_OPENROUTER_API_KEY for hermes).
# Hermes also accepts HDC_OPENROUTER_API_KEY as a shared fallback when HDC_HERMES_OPENROUTER_API_KEY is unset.
# node tools/hdc/cli.mjs secrets set HDC_OPENROUTER_MANAGEMENT_API_KEY
# HDC_OPENROUTER_MANAGEMENT_API_KEY=
# node tools/hdc/cli.mjs secrets set HDC_HERMES_OPENROUTER_API_KEY
# HDC_HERMES_OPENROUTER_API_KEY=
# node tools/hdc/cli.mjs secrets set HDC_OPENROUTER_API_KEY
# HDC_OPENROUTER_API_KEY=
# Discord applications (`packages/infrastructure/discord`) — per-app bot_token_vault_key in config.
# Hermes uses HDC_HERMES_DISCORD_BOT_TOKEN (also tracked by the discord infra package).
# node tools/hdc/cli.mjs secrets set HDC_HERMES_DISCORD_BOT_TOKEN
# HDC_HERMES_DISCORD_BOT_TOKEN=

# Scanopy network discovery (`packages/services/scanopy`) — prefer vault over env.
# node tools/hdc/cli.mjs secrets set HDC_SCANOPY_POSTGRES_PASSWORD
# HDC_SCANOPY_POSTGRES_PASSWORD=

# YaCy search (`packages/services/yacy`) — admin UI password; prefer vault over env.
# node tools/hdc/cli.mjs secrets set HDC_YACY_ADMIN_PASSWORD
# HDC_YACY_ADMIN_PASSWORD=

# SearXNG (`packages/services/searxng`) — instance secret (SEARXNG_SECRET); auto-generated on first deploy if missing.
# node tools/hdc/cli.mjs secrets set HDC_SEARXNG_SECRET
# HDC_SEARXNG_SECRET=

# Open WebUI (`packages/services/open-webui`) — JWT signing key (64+ random chars); prefer vault.
# node tools/hdc/cli.mjs secrets set HDC_OPEN_WEBUI_SECRET_KEY
# HDC_OPEN_WEBUI_SECRET_KEY=

# Vaultwarden (`packages/services/vaultwarden`) — admin panel token; prefer vault.
# node tools/hdc/cli.mjs secrets set HDC_VAULTWARDEN_ADMIN_TOKEN
# HDC_VAULTWARDEN_ADMIN_TOKEN=

# Stirling PDF (`packages/services/stirling-pdf`) — initial admin login password.
# node tools/hdc/cli.mjs secrets set HDC_STIRLING_PDF_ADMIN_PASSWORD
# HDC_STIRLING_PDF_ADMIN_PASSWORD=

# n8n (`packages/services/n8n`) — credential encryption key; auto-generated on first deploy if missing.
# node tools/hdc/cli.mjs secrets set HDC_N8N_ENCRYPTION_KEY
# HDC_N8N_ENCRYPTION_KEY=

# Vikunja (`packages/services/vikunja`) — JWT secret and Postgres password; auto-generated on first deploy if missing.
# node tools/hdc/cli.mjs secrets set HDC_VIKUNJA_JWT_SECRET
# node tools/hdc/cli.mjs secrets set HDC_VIKUNJA_DB_PASSWORD
# HDC_VIKUNJA_JWT_SECRET=
# HDC_VIKUNJA_DB_PASSWORD=

# Mailcow (`packages/services/mailcow`) — DB/Redis passwords auto-generated on first deploy if missing.
# API key required for maintain domain/DKIM/relay reconciliation (create in Mailcow admin UI):
# node tools/hdc/cli.mjs secrets set HDC_MAILCOW_API_KEY
# HDC_MAILCOW_DBPASS=
# HDC_MAILCOW_DBROOT=
# HDC_MAILCOW_REDISPASS=
# HDC_MAILCOW_API_KEY=

# Nextcloud AIO (packages/services/nextcloud): no vault secrets for v1 — admin/domain via AIO UI on :8080

# Postiz social scheduling (`packages/services/postiz`) — prefer vault over env.
# Auto-generated on first deploy if missing:
# node tools/hdc/cli.mjs secrets set HDC_POSTIZ_DB_PASSWORD
# node tools/hdc/cli.mjs secrets set HDC_POSTIZ_JWT_SECRET
# HDC_POSTIZ_DB_PASSWORD=
# HDC_POSTIZ_JWT_SECRET=

# Immich photo library (`packages/services/immich`) — Postgres password for Docker Compose (alphanumeric); prefer vault.
# node tools/hdc/cli.mjs secrets set HDC_IMMICH_DB_PASSWORD
# HDC_IMMICH_DB_PASSWORD=
# Admin API key (Immich UI → Administration → API Keys): systemConfig.read + systemConfig.update for query --import / maintain admin sync.
# node tools/hdc/cli.mjs secrets set HDC_IMMICH_API_KEY
# HDC_IMMICH_API_KEY=

# Uptime Kuma (`packages/services/uptime-kuma`) — no secrets required for deploy v1.
# Optional future API query: node tools/hdc/cli.mjs secrets set HDC_UPTIME_KUMA_API_TOKEN
# HDC_UPTIME_KUMA_API_TOKEN=

# Pi-hole DNS filtering (`packages/services/pi-hole`) — prefer vault over env.
# node tools/hdc/cli.mjs secrets set HDC_PIHOLE_WEBPASSWORD
# node tools/hdc/cli.mjs secrets set HDC_PIHOLE_API_TOKEN
# Optional per-instance API tokens: HDC_PIHOLE_API_TOKEN_A, HDC_PIHOLE_API_TOKEN_B
# HDC_PIHOLE_WEBPASSWORD=
# HDC_PIHOLE_API_TOKEN=

# SolidTime time tracking (`packages/services/solidtime`) — prefer vault over env.
# Auto-generated on first deploy if missing: node tools/hdc/cli.mjs secrets set HDC_SOLIDTIME_DB_PASSWORD
# HDC_SOLIDTIME_DB_PASSWORD=

# PostgreSQL (`packages/services/postgresql`) — prefer vault over env.
# node tools/hdc/cli.mjs secrets set HDC_POSTGRESQL_SUPERUSER_PASSWORD
# node tools/hdc/cli.mjs secrets set HDC_POSTGRESQL_REPLICATION_PASSWORD
# Optional per-instance superuser: HDC_POSTGRESQL_SUPERUSER_PASSWORD_A, HDC_POSTGRESQL_SUPERUSER_PASSWORD_B
# HDC_POSTGRESQL_SUPERUSER_PASSWORD=
# HDC_POSTGRESQL_REPLICATION_PASSWORD=

# Redis Cluster (`packages/services/redis`) — prefer vault over env.
# node tools/hdc/cli.mjs secrets set HDC_REDIS_PASSWORD
# HDC_REDIS_PASSWORD=

# Valkey Cluster (`packages/services/valkey`) — prefer vault over env.
# node tools/hdc/cli.mjs secrets set HDC_VALKEY_PASSWORD
# HDC_VALKEY_PASSWORD=

# Splunk Free standalone (`packages/services/splunk`) — prefer vault over env.
# node tools/hdc/cli.mjs secrets set HDC_SPLUNK_ADMIN_PASSWORD
# HDC_SPLUNK_ADMIN_PASSWORD=

# Apache Kafka KRaft cluster (`packages/services/kafka`) — cluster_id in config.json (no vault required for PLAINTEXT).
# Copy packages/services/kafka/config.example.json to config.json and set kafka.cluster_id (kafka-storage.sh random-uuid).

# Apache Cassandra cluster (`packages/services/cassandra`) — prefer vault over env.
# node tools/hdc/cli.mjs secrets set HDC_CASSANDRA_SUPERUSER_PASSWORD
# HDC_CASSANDRA_SUPERUSER_PASSWORD=

# Nginx web reverse proxy (`packages/services/nginx`) — prefer vault over env.
# node tools/hdc/cli.mjs secrets set HDC_NGINX_LE_EMAIL
# HDC_NGINX_LE_EMAIL=

# Smallstep step-ca internal CA (`packages/services/step-ca`) — prefer vault over env.
# node tools/hdc/cli.mjs secrets set HDC_STEP_CA_PASSWORD
# Optional per-instance: HDC_STEP_CA_PASSWORD_A
# HDC_STEP_CA_PASSWORD=

# Gatus health dashboard (`packages/services/gatus`) — optional alerting tokens in config_yaml_extra via ${ENV}.
# Example: node tools/hdc/cli.mjs secrets set HDC_GATUS_SLACK_WEBHOOK
# HDC_GATUS_SLACK_WEBHOOK=

# Nginx WAF reverse proxy (`packages/services/nginx-waf`) — prefer vault over env.
# node tools/hdc/cli.mjs secrets set HDC_NGINX_WAF_LETS_ENCRYPT_EMAIL
# Legacy key HDC_NGINX_WAF_LE_EMAIL is still read with a deprecation warning.
# DNS-01 challenge reuses BIND TSIG: node tools/hdc/cli.mjs secrets set HDC_BIND_TSIG_KEY
# HDC_NGINX_WAF_LETS_ENCRYPT_EMAIL=

# Home clients (`packages/clients/client`) — Windows WinRM + Linux SSH.
# node tools/hdc/cli.mjs secrets set HDC_WINRM_USER_PASSWORD
# WinRM user (MSA: MicrosoftAccount\you@outlook.com; local: .\username; Entra: AzureAD\you@company.com).
# Per-host password: auth.winrm_password_vault_suffix → HDC_WINRM_PASSWORD_<SUFFIX> in vault.
# HDC_WINRM_USER=MicrosoftAccount\you@outlook.com
# HDC_CLIENT_SSH_USER=
# Optional: Sysinternals PsExec for auto WinRM bootstrap (else PATH or config winrm_bootstrap.psexec_path)
# HDC_PSEXEC_PATH=

# Cloudflare DNS (`packages/infrastructure/cloudflare`) — API token (prefer vault).
# node tools/hdc/cli.mjs secrets set HDC_CLOUDFLARE_API_TOKEN
# HDC_CLOUDFLARE_API_TOKEN=
# Optional when zone listing needs an account filter:
# HDC_CLOUDFLARE_ACCOUNT_ID=

# GCP OAuth / Google Auth Platform (`packages/infrastructure/gcp-oauth`) — per-app client credentials (prefer vault).
# node tools/hdc/cli.mjs secrets set HDC_GCP_OAUTH_VAULTWARDEN_CLIENT_ID
# node tools/hdc/cli.mjs secrets set HDC_GCP_OAUTH_VAULTWARDEN_CLIENT_SECRET
# Or: hdc run infrastructure gcp-oauth maintain -- --import ./client_secret.json

# Azure app registrations (`packages/infrastructure/azure`) — automation app (see docs/manually-deployed/azure.md).
# HDC_AZURE_TENANT_ID=
# HDC_AZURE_CLIENT_ID=
# node tools/hdc/cli.mjs secrets set HDC_AZURE_CLIENT_SECRET
# HDC_AZURE_CLIENT_SECRET=

# Twilio (`packages/infrastructure/twilio`) — Account SID and Auth Token (prefer vault).
# node tools/hdc/cli.mjs secrets set HDC_TWILIO_ACCOUNT_SID
# node tools/hdc/cli.mjs secrets set HDC_TWILIO_AUTH_TOKEN
# HDC_TWILIO_ACCOUNT_SID=
# HDC_TWILIO_AUTH_TOKEN=
# Asterisk SIP Credential List (separate from API credentials): HDC_TWILIO_SIP_USERNAME, HDC_TWILIO_SIP_PASSWORD

# Synology NAS (`packages/infrastructure/synology-nas`) — SSH admin user and per-host passwords (prefer vault).
# Enable SSH in DSM Control Panel → Terminal & SNMP before first maintain.
# node tools/hdc/cli.mjs secrets set HDC_SYNOLOGY_SSH_PASSWORD_NAS_1
# node tools/hdc/cli.mjs secrets set HDC_SYNOLOGY_SSH_PASSWORD_NAS_2
# HDC_SYNOLOGY_SSH_USER=admin
# HDC_SYNOLOGY_SSH_PASSWORD_NAS_1=
# HDC_SYNOLOGY_SSH_PASSWORD_NAS_2=
