# Copy to `.env` in the repo root (never commit `.env`).
# Global HDC CLI: vault, secret backend, ops notifications, guest baseline.
# Package-specific variables: clumps/<tier>/<id>/.env (see each .env.example).

# Global HDC CLI: vault, secret backend, ops notifications, guest baseline.
# Discord webhooks: CLI ops summaries use HDC_OPS_DISCORD_WEBHOOK_URL; hdc-agents fleet
# (scheduler / MCP / manager escalations) use HDC_AGENTS_DISCORD_WEBHOOK_URL.
# Prefer vault: hdc secrets set HDC_OPS_DISCORD_WEBHOOK_URL
# Prefer vault: hdc secrets set HDC_AGENTS_DISCORD_WEBHOOK_URL
# HDC_OPS_DISCORD_WEBHOOK_URL=
# HDC_AGENTS_DISCORD_WEBHOOK_URL=
# HDC_OPS_DISCORD_NOTIFY=1
# Slack Incoming Webhooks (channel slack-incoming-webhook; mirror Discord when set):
# CLI prefers HDC_OPS_SLACK_WEBHOOK_URL then HDC_AGENTS_SLACK_WEBHOOK_URL.
# Prefer vault: hdc secrets set HDC_AGENTS_SLACK_WEBHOOK_URL
# HDC_OPS_SLACK_WEBHOOK_URL=
# HDC_AGENTS_SLACK_WEBHOOK_URL=
# Slack HDC app (channel slack-hdc-app; Approve/Deny buttons via chat.postMessage):
# Register with: hdc run infrastructure slack deploy --
# HDC_SLACK_CONFIG_TOKEN=
# HDC_SLACK_CONFIG_REFRESH_TOKEN=
# HDC_SLACK_BOT_TOKEN=
# HDC_SLACK_DECISION_CHANNEL=
# HDC_SLACK_HDC_APP_SIGNING_SECRET=
# HDC_SLACK_HDC_APP_CLIENT_ID=
# HDC_SLACK_HDC_APP_CLIENT_SECRET=
# Optional decision buttons (hdc-ops Discord app): set when application_id + public_key +
# bot token + channel_id are configured (see clumps/infrastructure/discord + hdc-agents.discord).
# Prefer vault for the bot token: hdc secrets set HDC_OPS_DISCORD_BOT_TOKEN
# HDC_OPS_DISCORD_APPLICATION_ID=
# HDC_OPS_DISCORD_PUBLIC_KEY=
# HDC_OPS_DISCORD_BOT_TOKEN=
# HDC_OPS_DISCORD_CHANNEL_ID=
# Notification attribution (optional overrides; hdc-agents sets HDC_OPS_SYSTEM_ID from deployment system_id):
# HDC_OPS_SYSTEM_ID=
# HDC_OPS_NOTIFY_APP=
# Legacy alias for system id when HDC_OPS_SYSTEM_ID is unset:
# HDC_OPS_DISCORD_HOST=
# Manager multi-channel notifications (hdc-agents notifications.routes): optional vault keys
# (Slack webhook keys documented above with Discord.)
# Prefer vault: hdc secrets set HDC_AGENTS_TEAMS_WEBHOOK_URL
# Prefer vault: hdc secrets set HDC_AGENTS_TELEGRAM_BOT_TOKEN
# HDC_AGENTS_TEAMS_WEBHOOK_URL=
# HDC_AGENTS_TELEGRAM_BOT_TOKEN=
# Optional: paid web-search backend for hdc_web_search (fleet agents). Default is DuckDuckGo HTML (no key).
# HDC_WEB_SEARCH_API_KEY=
# Optional: path to the private hdc-private repo (clump config.json + inventory).
# Default when unset: sibling directory ../hdc-private next to this repo if it exists.
# HDC_PRIVATE_ROOT=C:/path/to/hdc-private
# HDC_TLS_INSECURE=1
# Passphrase for the encrypted secrets vault at ~/.hdc/vault.enc (see `hdc secrets path`).
# If set to the correct passphrase, scripts unlock the vault without prompting. Otherwise the CLI prompts
# Rotating the passphrase: `hdc secrets change-passphrase`, then update this variable.
# HDC_VAULT_PASSPHRASE=choose-a-strong-passphrase
# Off-workstation vault backups: `hdc secrets backup` (and `maintain daily`) copies vault.enc
# plus an encrypted bundle of bootstrap .env files to each ";"-separated directory below
# (e.g. a NAS share and a second copy). Retention keeps the newest N per prefix (default 30).
# HDC_VAULT_BACKUP_DIRS=\\nas-a\backups\hdc-vault;D:/backups/hdc-vault
# HDC_VAULT_BACKUP_RETAIN=30
# Secret backend: local (~/.hdc/vault.enc only), vaultwarden (Bitwarden CLI + Vaultwarden server), or auto (default).
# auto uses Vaultwarden when HDC_VAULTWARDEN_URL and (HDC_VAULTWARDEN_EMAIL or API key pair) are set; falls back to local if bw/server unavailable.
# HDC_SECRET_BACKEND=auto
# HDC_VAULTWARDEN_URL=https://vault.example.invalid  (legacy alias: https://vault.home.example.invalid)
# HDC_VAULTWARDEN_EMAIL=you@example.com
# hdc secrets set HDC_VAULTWARDEN_KEY_CLIENT_ID
# hdc secrets set HDC_VAULTWARDEN_KEY_CLIENT_SECRET
# HDC_VAULTWARDEN_KEY_CLIENT_ID=
# HDC_VAULTWARDEN_KEY_CLIENT_SECRET=
# HDC_VAULTWARDEN_ORGANIZATION_ID=<uuid>   # optional when HDC_VAULTWARDEN_ORGANIZATION_NAME resolves (default name: HDC)
# HDC_VAULTWARDEN_ORGANIZATION_NAME=HDC
# HDC_VAULTWARDEN_COLLECTION_ID=<uuid>     # required when Vaultwarden backend is active
# HDC_BW_EXECUTABLE=C:/path/to/bw.exe
# hdc secrets set HDC_VAULTWARDEN_MASTER_PASSWORD
# HDC_VAULTWARDEN_MASTER_PASSWORD=
# HDC_ADMIN_USER=your-linux-username
# hdc secrets set HDC_ADMIN_USER_PASSWORD
# HDC_GUEST_SSH_USER=hdc
# Remote-exec hang protection: hard timeout for a single SSH/pct/qm command (default 30 min)
# and idle timeout for Proxmox API HTTP requests (default 120 s).
# HDC_SSH_COMMAND_TIMEOUT_MS=1800000
# HDC_PVE_HTTP_TIMEOUT_MS=120000
# ── hdc-mcp-server (see docs/manually-deployed/hdc-mcp-server.md) ──
# GOOGLE_API_KEY=   # Gemini API key for interactive ADK agent (npx adk run)
# HDC_OPS_AGENT_MODEL=gemini-2.5-flash
# ── Package .env files (one per package; live values in hdc-private) ──
# Copy each clumps/<tier>/<id>/.env.example → hdc-private/<same path>/.env
# Loaded only when running that package (hdc run / maintain daily).

