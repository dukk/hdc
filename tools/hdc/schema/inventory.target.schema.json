{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/inventory.target.schema.json",
  "title": "HDC inventory sidecar — target",
  "description": "Extra structured data for one hdc package (manifest id under packages/). Scripts may add top-level keys beyond those listed.",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "id", "kind", "automation_target"],
  "properties": {
    "schema_version": { "const": 1 },
    "id": { "type": "string", "minLength": 1 },
    "kind": { "const": "target" },
    "automation_target": { "type": "string", "minLength": 1 },
    "data": { "type": "object" },
    "auth": { "type": "object" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "notes": { "type": "string" },
    "last_verified": { "type": ["string", "null"] },
    "query_last": {}
  }
}
