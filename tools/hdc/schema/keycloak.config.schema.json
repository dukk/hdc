{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/keycloak.config.schema.json",
  "title": "HDC keycloak service package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "deployments"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 2 },
    "defaults": { "type": "object" },
    "deployments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["system_id"],
        "properties": {
          "system_id": { "type": "string", "pattern": "^keycloak-[a-z]+$" },
          "mode": { "enum": ["proxmox-lxc"] },
          "proxmox": { "type": "object" },
          "install": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" },
              "compose_dir": { "type": "string" }
            }
          },
          "keycloak": {
            "type": "object",
            "properties": {
              "image_tag": { "type": "string" },
              "host_port": { "type": "integer", "minimum": 1, "maximum": 65535 },
              "external_url": { "type": "string", "pattern": "^https?://.+" },
              "admin_user": { "type": "string" },
              "admin_password_vault_key": { "type": "string" },
              "database": {
                "type": "object",
                "properties": {
                  "mode": { "enum": ["bundled", "external"] }
                }
              }
            }
          }
        }
      }
    }
  }
}
