{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/ollama.config.schema.json",
  "title": "HDC ollama service package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "deployments"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 2 },
    "defaults": { "type": "object" },
    "deployments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["system_id"],
        "properties": {
          "system_id": {
            "type": "string",
            "pattern": "^(vm-ollama|ollama)-[a-z]+$"
          },
          "mode": { "enum": ["proxmox-lxc", "proxmox-qemu", "ubuntu-docker"] },
          "hostname": { "type": "string" },
          "proxmox": {
            "type": "object",
            "properties": {
              "host_id": { "type": "string" },
              "lxc": { "type": "object" },
              "qemu": {
                "type": "object",
                "properties": {
                  "vmid": { "type": "number" },
                  "template_vmid": { "type": "number" },
                  "ip": { "type": "string" },
                  "hostpci": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["id"],
                      "properties": {
                        "id": { "type": "string" },
                        "pcie": { "type": "boolean" },
                        "rombar": { "type": "boolean" },
                        "xvga": { "type": "boolean" }
                      }
                    }
                  }
                }
              },
              "network": { "type": "object" }
            }
          },
          "configure": { "type": "object" },
          "install": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" },
              "method": { "enum": ["github-release", "curl-install-sh"] },
              "gpu": { "type": "boolean" },
              "gpu_backend": { "enum": ["nvidia", "intel"] }
            }
          }
        }
      }
    }
  }
}
