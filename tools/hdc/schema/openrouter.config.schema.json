{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/openrouter.config.schema.json",
  "title": "HDC openrouter infrastructure package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "openrouter", "api_keys"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "openrouter": {
      "type": "object",
      "properties": {
        "api_base_url": { "type": "string", "format": "uri" },
        "auth": {
          "type": "object",
          "properties": {
            "management_api_key_vault_key": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "defaults": {
      "type": "object",
      "properties": {
        "limit_usd": { "type": ["number", "null"] },
        "limit_reset": { "type": ["string", "null"] },
        "include_byok_in_limit": { "type": "boolean" }
      }
    },
    "credits": {
      "type": "object",
      "properties": {
        "low_balance_usd": { "type": ["number", "null"] }
      }
    },
    "api_keys": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "managed": { "type": "boolean" },
          "inference_api_key_vault_key": { "type": ["string", "null"] },
          "openrouter_hash": { "type": ["string", "null"] },
          "limit_usd": { "type": ["number", "null"] },
          "limit_reset": { "type": ["string", "null"] },
          "include_byok_in_limit": { "type": "boolean" },
          "disabled": { "type": "boolean" },
          "consumer": { "type": ["string", "null"] },
          "notes": { "type": ["string", "null"] }
        }
      }
    }
  }
}
