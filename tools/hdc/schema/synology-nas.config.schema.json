{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/synology-nas.config.schema.json",
  "title": "HDC synology-nas infrastructure package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "deployments"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "defaults": {
      "type": "object",
      "properties": {
        "ssh": {
          "type": "object",
          "properties": {
            "user": { "type": "string" },
            "user_env": { "type": "string" }
          }
        },
        "maintain": {
          "type": "object",
          "properties": {
            "reboot_wait_seconds": { "type": "number", "minimum": 60 },
            "dsm_upgrade": { "type": "boolean" },
            "package_upgrade": { "type": "boolean" },
            "docker_ensure": { "type": "boolean" },
            "ssh_keys": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" }
              }
            }
          }
        },
        "docker": {
          "type": "object",
          "properties": {
            "compose_base_dir": { "type": "string" }
          }
        }
      }
    },
    "deployments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["system_id", "ssh"],
        "properties": {
          "instance": { "type": "string", "pattern": "^[a-z]$" },
          "system_id": { "type": "string", "pattern": "^nas-[a-z0-9][a-z0-9-]*$" },
          "hostname": { "type": "string" },
          "ssh": {
            "type": "object",
            "required": ["host"],
            "properties": {
              "user": { "type": "string" },
              "host": { "type": "string" }
            }
          },
          "maintain": { "type": "object" },
          "docker": {
            "type": "object",
            "properties": {
              "compose_base_dir": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
