{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/litellm.config.schema.json",
  "title": "HDC litellm service package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "deployments"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 2 },
    "defaults": { "type": "object" },
    "deployments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["system_id"],
        "properties": {
          "system_id": { "type": "string", "pattern": "^litellm-[a-z]+$" },
          "mode": { "enum": ["proxmox-lxc"] },
          "proxmox": { "type": "object" },
          "litellm": {
            "type": "object",
            "properties": {
              "image_tag": { "type": "string" },
              "postgres_image_tag": { "type": "string" },
              "host_port": { "type": "integer", "minimum": 1, "maximum": 65535 },
              "public_url": { "type": ["string", "null"] },
              "store_model_in_db": { "type": "boolean" },
              "master_key_vault_key": { "type": "string" },
              "salt_key_vault_key": { "type": "string" },
              "db_password_vault_key": { "type": "string" },
              "openrouter_api_key_vault_key": { "type": "string" },
              "ollama_backends": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["id", "url"],
                  "properties": {
                    "id": { "type": "string" },
                    "url": { "type": "string", "format": "uri" },
                    "notes": { "type": "string" }
                  }
                }
              },
              "model_list": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["model_name", "provider", "model"],
                  "properties": {
                    "model_name": { "type": "string" },
                    "provider": { "enum": ["ollama", "openrouter"] },
                    "model": { "type": "string" },
                    "ollama_backend_id": { "type": "string" }
                  }
                }
              },
              "router_settings": { "type": "object" },
              "litellm_settings": { "type": "object" }
            }
          },
          "install": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" },
              "compose_dir": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
