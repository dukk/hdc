{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/mosquitto.config.schema.json",
  "title": "HDC mosquitto service package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "deployments"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 2 },
    "defaults": { "type": "object" },
    "deployments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["system_id"],
        "properties": {
          "system_id": { "type": "string", "pattern": "^mosquitto-[a-z]+$" },
          "mode": { "enum": ["proxmox-lxc"] },
          "proxmox": { "type": "object" },
          "install": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" }
            }
          },
          "mosquitto": {
            "type": "object",
            "properties": {
              "tls": {
                "type": "object",
                "properties": {
                  "enabled": { "type": "boolean" },
                  "cert_name": { "type": "string" },
                  "listener_port": { "type": "integer", "minimum": 1, "maximum": 65535 },
                  "step_ca_config_path": { "type": "string" },
                  "root_ca_path": { "type": "string" },
                  "cert_dir": { "type": "string" },
                  "acme_email": { "type": "string" },
                  "acme_email_env": { "type": "string" }
                }
              },
              "plain_listener": {
                "type": "object",
                "properties": {
                  "enabled": { "type": "boolean" },
                  "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
                }
              },
              "users": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["username", "password_vault_key"],
                  "properties": {
                    "username": { "type": "string" },
                    "password_vault_key": { "type": "string" }
                  }
                }
              },
              "acl": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["user", "topic", "access"],
                  "properties": {
                    "user": { "type": "string" },
                    "topic": { "type": "string" },
                    "access": { "enum": ["read", "write", "readwrite"] }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
