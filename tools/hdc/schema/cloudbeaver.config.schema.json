{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/cloudbeaver.config.schema.json",
  "title": "HDC CloudBeaver service package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "deployments"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 2 },
    "defaults": { "type": "object" },
    "deployments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["system_id"],
        "properties": {
          "system_id": { "type": "string", "pattern": "^cloudbeaver-[a-z]+$" },
          "mode": { "enum": ["proxmox-lxc"] },
          "proxmox": { "type": "object" },
          "cloudbeaver": {
            "type": "object",
            "properties": {
              "image": { "type": "string" },
              "host_port": { "type": "integer", "minimum": 1, "maximum": 65535 },
              "public_url": { "type": ["string", "null"] },
              "extra_hosts": {
                "type": "array",
                "items": { "type": "string" }
              },
              "admin": {
                "type": "object",
                "properties": {
                  "enabled": { "type": "boolean" },
                  "username": { "type": "string" },
                  "server_name": { "type": "string" },
                  "admin_password_vault_key": { "type": "string" }
                }
              }
            }
          },
          "install": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" },
              "compose_dir": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
