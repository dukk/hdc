{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/asterisk.config.schema.json",
  "title": "HDC Asterisk service package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "deployments"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 2 },
    "asterisk": {
      "type": "object",
      "properties": {
        "sip_port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "sip_transport": { "type": "string", "enum": ["udp", "tcp", "udp,tcp"] },
        "rtp_port_min": { "type": "integer", "minimum": 1024, "maximum": 65535 },
        "rtp_port_max": { "type": "integer", "minimum": 1024, "maximum": 65535 },
        "nat": { "type": "object" },
        "twilio": { "type": "object" },
        "endpoints": { "type": "array" }
      }
    },
    "defaults": { "type": "object" },
    "deployments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["system_id"],
        "properties": {
          "system_id": { "type": "string" },
          "mode": {
            "enum": ["proxmox-lxc", "proxmox-qemu", "configure-only"]
          },
          "proxmox": { "type": "object" },
          "configure": { "type": "object" },
          "install": { "type": "object" }
        }
      }
    }
  }
}
