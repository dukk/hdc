{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/inventory.policy.schema.json",
  "title": "HDC inventory sidecar — policy",
  "description": "Manually documented firewall rule, port forward, or ACL expectation (compare with packages/unifi-network query output).",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "id", "kind", "policy_class"],
  "properties": {
    "schema_version": { "const": 1 },
    "id": { "type": "string", "minLength": 1 },
    "kind": { "const": "policy" },
    "policy_class": {
      "enum": ["firewall_policy", "port_forward", "acl_rule"],
      "description": "firewall_policy: zone firewall; port_forward: DNAT; acl_rule: switch ACL"
    },
    "access": { "type": "object" },
    "auth": { "type": "object" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "automation_targets": { "type": "array", "items": { "type": "string" } },
    "notes": { "type": "string" },
    "last_verified": { "type": ["string", "null"] },
    "query_last": {},
    "sources": {
      "type": "object",
      "description": "Per-package snapshots: sources[<package_id>] = { collected_at, query_last }.",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "collected_at": { "type": "string" },
          "query_last": {}
        }
      }
    }
  }
}
