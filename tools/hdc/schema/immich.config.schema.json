{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/immich.config.schema.json",
  "title": "HDC immich service package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "deployments"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 2 },
    "defaults": { "type": "object" },
    "deployments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["system_id"],
        "properties": {
          "system_id": { "type": "string", "pattern": "^vm-immich-[a-z]+$" },
          "mode": { "enum": ["proxmox-qemu", "configure-only"] },
          "hostname": { "type": "string" },
          "proxmox": { "type": "object" },
          "configure": { "type": "object" },
          "immich": {
            "type": "object",
            "properties": {
              "release": { "type": "string" },
              "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
              "public_url": { "type": ["string", "null"] },
              "upload_location": { "type": "string" },
              "db_data_location": { "type": "string" },
              "db_password_vault_key": { "type": "string" },
              "timezone": { "type": "string" },
              "disable_machine_learning": { "type": "boolean" }
            }
          },
          "install": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" },
              "compose_dir": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
