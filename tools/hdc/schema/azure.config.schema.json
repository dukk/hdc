{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/azure-entra.config.schema.json",
  "title": "HDC azure-entra infrastructure package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "applications"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "azure_entra": {
      "type": "object",
      "properties": {
        "graph_base_url": { "type": "string", "format": "uri" }
      }
    },
    "application_filter": {
      "type": "object",
      "properties": {
        "mode": { "enum": ["all", "include", "exclude"] },
        "display_name_prefixes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "applications": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "display_name", "match"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "managed": { "type": "boolean" },
          "match": {
            "type": "object",
            "properties": {
              "client_id": { "type": "string" },
              "display_name": { "type": "string" }
            }
          },
          "display_name": { "type": "string", "minLength": 1 },
          "sign_in_audience": {
            "enum": [
              "AzureADMyOrg",
              "AzureADMultipleOrgs",
              "AzureADandPersonalMicrosoftAccount",
              "PersonalMicrosoftAccount"
            ]
          },
          "web": {
            "type": "object",
            "properties": {
              "redirect_uris": { "type": "array", "items": { "type": "string" } }
            }
          },
          "spa": {
            "type": "object",
            "properties": {
              "redirect_uris": { "type": "array", "items": { "type": "string" } }
            }
          },
          "public_client": {
            "type": "object",
            "properties": {
              "redirect_uris": { "type": "array", "items": { "type": "string" } }
            }
          },
          "required_resource_access": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["resource_app_id", "resource_access"],
              "properties": {
                "resource_app_id": { "type": "string" },
                "resource_access": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["id", "type"],
                    "properties": {
                      "id": { "type": "string" },
                      "type": { "enum": ["Scope", "Role"] }
                    }
                  }
                }
              }
            }
          },
          "identifier_uris": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
