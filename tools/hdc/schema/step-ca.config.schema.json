{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/step-ca.config.schema.json",
  "title": "HDC step-ca service package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "deployments"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 2 },
    "step_ca": {
      "type": "object",
      "properties": {
        "ca_name": { "type": "string" },
        "dns_names": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "listen_address": { "type": "string" },
        "deployment_type": { "type": "string" },
        "provisioner_name": { "type": "string" },
        "enable_acme": { "type": "boolean" },
        "password_vault_key": { "type": "string" },
        "step_path": { "type": "string" }
      }
    },
    "defaults": { "type": "object" },
    "deployments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["system_id", "role"],
        "properties": {
          "system_id": { "type": "string", "pattern": "^vm-step-ca-[a-z]+$" },
          "role": { "enum": ["standalone"] },
          "hostname": { "type": "string" },
          "mode": { "enum": ["proxmox-qemu", "configure-only"] },
          "proxmox": { "type": "object" },
          "configure": { "type": "object" }
        }
      }
    }
  }
}
