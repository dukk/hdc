{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/mailcow.config.schema.json",
  "title": "HDC mailcow service package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "deployments"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 2 },
    "defaults": { "type": "object" },
    "deployments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["system_id"],
        "properties": {
          "system_id": { "type": "string", "pattern": "^(mailcow|vm-mailcow)-[a-z]+$" },
          "mode": { "enum": ["proxmox-lxc", "proxmox-qemu", "configure-only"] },
          "hostname": { "type": "string" },
          "proxmox": { "type": "object" },
          "configure": {
            "type": "object",
            "properties": {
              "ssh": {
                "type": "object",
                "properties": {
                  "user": { "type": "string" },
                  "host": { "type": "string" }
                }
              }
            }
          },
          "mailcow": {
            "type": "object",
            "properties": {
              "git_ref": { "type": "string" },
              "hostname": { "type": "string", "minLength": 3 },
              "timezone": { "type": "string" },
              "admin_url": { "type": "string" },
              "api_key_vault_key": { "type": "string" },
              "skip_clamd": { "type": "boolean" },
              "skip_solr": { "type": "boolean" },
              "domains": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["name"],
                  "properties": {
                    "name": { "type": "string" },
                    "description": { "type": "string" },
                    "dkim_selector": { "type": "string" },
                    "dkim_key_size": { "type": "integer", "enum": [1024, 2048] },
                    "outbound": {
                      "type": "object",
                      "properties": {
                        "mode": { "enum": ["direct", "postfix-relay"] }
                      }
                    },
                    "dns": {
                      "type": "object",
                      "properties": {
                        "mx_priority": { "type": "integer", "minimum": 0 },
                        "spf": { "type": "string" },
                        "dmarc": { "type": "string" },
                        "notes": { "type": "string" }
                      }
                    }
                  }
                }
              }
            }
          },
          "install": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" },
              "install_dir": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
