{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/aws.config.schema.json",
  "title": "HDC AWS infrastructure package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "aws"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "aws": {
      "type": "object",
      "required": ["region"],
      "properties": {
        "region": { "type": "string", "minLength": 1 },
        "default_tags": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "cost": {
      "type": "object",
      "properties": {
        "confirm_before_deploy": { "type": "boolean" },
        "hours_per_month": { "type": "number", "minimum": 1 }
      }
    },
    "vpcs": { "type": "array", "items": { "$ref": "#/$defs/vpc" } },
    "subnets": { "type": "array", "items": { "$ref": "#/$defs/subnet" } },
    "security_groups": { "type": "array", "items": { "$ref": "#/$defs/security_group" } },
    "iam_roles": { "type": "array", "items": { "$ref": "#/$defs/iam_role" } },
    "ebs_volumes": { "type": "array", "items": { "$ref": "#/$defs/ebs_volume" } },
    "ec2_instances": { "type": "array", "items": { "$ref": "#/$defs/ec2_instance" } },
    "s3_buckets": { "type": "array", "items": { "$ref": "#/$defs/s3_bucket" } },
    "ecs_clusters": { "type": "array", "items": { "$ref": "#/$defs/ecs_cluster" } },
    "ecs_services": { "type": "array", "items": { "$ref": "#/$defs/ecs_service" } }
  },
  "$defs": {
    "managed_resource": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "managed": { "type": "boolean" },
        "tags": { "type": "object", "additionalProperties": { "type": "string" } }
      },
      "required": ["id"]
    },
    "vpc": {
      "allOf": [
        { "$ref": "#/$defs/managed_resource" },
        {
          "type": "object",
          "required": ["cidr"],
          "properties": {
            "cidr": { "type": "string" },
            "enable_nat_gateway": { "type": "boolean" }
          }
        }
      ]
    },
    "subnet": {
      "allOf": [
        { "$ref": "#/$defs/managed_resource" },
        {
          "type": "object",
          "required": ["vpc_id", "cidr", "az"],
          "properties": {
            "vpc_id": { "type": "string" },
            "cidr": { "type": "string" },
            "az": { "type": "string" },
            "public": { "type": "boolean" }
          }
        }
      ]
    },
    "security_group": {
      "allOf": [
        { "$ref": "#/$defs/managed_resource" },
        {
          "type": "object",
          "required": ["vpc_id"],
          "properties": {
            "vpc_id": { "type": "string" },
            "description": { "type": "string" },
            "ingress": { "type": "array" },
            "egress": { "type": "array" }
          }
        }
      ]
    },
    "iam_role": {
      "allOf": [
        { "$ref": "#/$defs/managed_resource" },
        {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "trust": { "enum": ["ec2", "ecs-tasks"] },
            "policies": { "type": "array", "items": { "type": "string" } }
          }
        }
      ]
    },
    "ebs_volume": {
      "allOf": [
        { "$ref": "#/$defs/managed_resource" },
        {
          "type": "object",
          "properties": {
            "size_gb": { "type": "number", "minimum": 1 },
            "volume_type": { "type": "string" },
            "attach_to": { "type": "string" },
            "az": { "type": "string" }
          }
        }
      ]
    },
    "ec2_instance": {
      "allOf": [
        { "$ref": "#/$defs/managed_resource" },
        {
          "type": "object",
          "required": ["instance_type", "ami", "subnet_id"],
          "properties": {
            "name": { "type": "string" },
            "instance_type": { "type": "string" },
            "ami": { "type": "string" },
            "subnet_id": { "type": "string" },
            "security_group_ids": { "type": "array", "items": { "type": "string" } },
            "key_name": { "type": ["string", "null"] },
            "user_data": { "type": "string" },
            "root_volume_gb": { "type": "number" },
            "root_volume_type": { "type": "string" },
            "iam_instance_profile": { "type": ["string", "null"] },
            "ebs_volumes": { "type": "array" }
          }
        }
      ]
    },
    "s3_bucket": {
      "allOf": [
        { "$ref": "#/$defs/managed_resource" },
        {
          "type": "object",
          "required": ["name"],
          "properties": {
            "name": { "type": "string" },
            "versioning": { "type": "boolean" },
            "encryption": { "type": "boolean" },
            "estimated_size_gb": { "type": "number", "minimum": 0 }
          }
        }
      ]
    },
    "ecs_cluster": {
      "allOf": [
        { "$ref": "#/$defs/managed_resource" },
        {
          "type": "object",
          "properties": {
            "name": { "type": "string" }
          }
        }
      ]
    },
    "ecs_service": {
      "allOf": [
        { "$ref": "#/$defs/managed_resource" },
        {
          "type": "object",
          "required": ["cluster_id"],
          "properties": {
            "cluster_id": { "type": "string" },
            "name": { "type": "string" },
            "cpu": { "type": "number" },
            "memory": { "type": "number" },
            "desired_count": { "type": "number", "minimum": 0 },
            "subnet_ids": { "type": "array", "items": { "type": "string" } },
            "security_group_ids": { "type": "array", "items": { "type": "string" } },
            "task_definition": { "type": "object" }
          }
        }
      ]
    }
  }
}
