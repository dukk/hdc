{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/llama-cpp.config.schema.json",
  "title": "HDC llama-cpp service package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "deployments"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 2 },
    "defaults": { "type": "object" },
    "deployments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["system_id"],
        "properties": {
          "system_id": { "type": "string", "pattern": "^llama-cpp-[a-z]+$" },
          "mode": { "enum": ["proxmox-lxc", "proxmox-qemu"] },
          "proxmox": { "type": "object" },
          "install": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" },
              "backend": { "enum": ["cpu", "cuda", "vulkan", "rocm"] },
              "release": { "type": "string" },
              "cuda_version": { "type": "string" },
              "rocm_version": { "type": "string" }
            }
          },
          "server": {
            "type": "object",
            "properties": {
              "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
              "host": { "type": "string" },
              "models_dir": { "type": "string" },
              "model": { "type": ["string", "null"] },
              "hf_model": { "type": ["string", "null"] },
              "extra_args": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    }
  }
}
