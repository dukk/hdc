{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/dawarich.config.schema.json",
  "title": "HDC dawarich service package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "deployments"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 2 },
    "defaults": { "type": "object" },
    "deployments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["system_id"],
        "properties": {
          "system_id": { "type": "string", "pattern": "^dawarich-[a-z]+$" },
          "mode": { "enum": ["proxmox-lxc"] },
          "proxmox": { "type": "object" },
          "dawarich": {
            "type": "object",
            "properties": {
              "image_tag": { "type": "string" },
              "postgis_image_tag": { "type": "string" },
              "redis_image_tag": { "type": "string" },
              "host_port": { "type": "integer", "minimum": 1, "maximum": 65535 },
              "rails_env": { "enum": ["development", "staging", "production"] },
              "public_url": { "type": "string" },
              "time_zone": { "type": "string" },
              "store_geodata": { "type": "boolean" },
              "application_protocol": { "enum": ["http", "https"] },
              "app_cpu_limit": { "type": "string" },
              "app_memory_limit": { "type": "string" },
              "secret_key_base_vault_key": { "type": "string" },
              "db_password_vault_key": { "type": "string" }
            }
          },
          "install": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" },
              "compose_dir": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
