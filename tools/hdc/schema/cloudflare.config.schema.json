{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/cloudflare.config.schema.json",
  "title": "HDC cloudflare infrastructure package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "zones"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "cloudflare": {
      "type": "object",
      "properties": {
        "api_base_url": { "type": "string", "format": "uri" },
        "account_id": { "type": ["string", "null"] },
        "zone_filter": {
          "type": "object",
          "properties": {
            "mode": { "enum": ["all", "include", "exclude"] },
            "names": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "defaults": {
      "type": "object",
      "properties": {
        "ttl": { "type": "integer", "minimum": 1 },
        "proxied": { "type": "boolean" }
      }
    },
    "zones": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "records"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "records": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["type", "name", "data"],
              "properties": {
                "type": {
                  "enum": ["A", "AAAA", "CNAME", "TXT", "MX", "NS", "PTR", "CAA", "SRV"]
                },
                "name": { "type": "string" },
                "data": { "type": "string" },
                "ttl": { "type": "integer", "minimum": 1 },
                "priority": { "type": "integer", "minimum": 0 },
                "proxied": { "type": "boolean" }
              }
            }
          }
        }
      }
    }
  }
}
