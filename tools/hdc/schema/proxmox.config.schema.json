{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/proxmox.config.schema.json",
  "title": "HDC package config — Proxmox infrastructure",
  "description": "packages/infrastructure/proxmox/config.json — hypervisor clusters, provision defaults, optional bootstrap_hosts for users bootstrap-hdc.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "clusters"],
  "properties": {
    "schema_version": { "const": 1 },
    "clusters": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/cluster" }
    },
    "provision": { "$ref": "#/$defs/provision" },
    "bootstrap_hosts": {
      "type": "array",
      "items": { "$ref": "#/$defs/bootstrap_host" },
      "default": []
    }
  },
  "$defs": {
    "cluster": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "hosts"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Logical cluster id (matches inventory proxmox_cluster.id when applicable)."
        },
        "pve_release": {
          "type": "string",
          "minLength": 1,
          "description": "Optional Proxmox VE release hint (e.g. 8.4 or 9) when API /version is unavailable; selects hdc API/CLI profile."
        },
        "hosts": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/host" }
        },
        "api_base": {
          "type": "string",
          "minLength": 1,
          "description": "Deprecated: use web_ui on each host instead."
        }
      }
    },
    "host": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "pve_node", "ip", "web_ui", "ssh"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Inventory hypervisor id (e.g. hypervisor-a)."
        },
        "pve_node": {
          "type": "string",
          "minLength": 1,
          "description": "Proxmox node name as shown in the API (often same as id)."
        },
        "ip": {
          "type": "string",
          "minLength": 1,
          "description": "Management/LAN IPv4 or hostname."
        },
        "web_ui": {
          "type": "string",
          "minLength": 1,
          "description": "Proxmox web UI URL (https://host:8006) — used as API base."
        },
        "ssh": {
          "type": "string",
          "minLength": 1,
          "pattern": "^ssh://",
          "description": "SSH URL for bootstrap-hdc and remote ops (e.g. ssh://root@192.0.2.11)."
        },
        "down": {
          "type": ["boolean", "integer"],
          "description": "When true, skip maintain/query/SSH iteration for this host; deploy targeting this id fails fast."
        },
        "api_base": {
          "type": "string",
          "minLength": 1,
          "description": "Deprecated: use web_ui instead."
        },
        "proxmox_cluster": {
          "type": "object",
          "description": "Deprecated: cluster id is taken from clusters[].id.",
          "additionalProperties": true
        },
        "local_lvm": {
          "$ref": "#/$defs/host_local_lvm",
          "description": "Per-host local-LVM extend override and extra-disk RAID pools."
        }
      }
    },
    "provision": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "templates": { "$ref": "#/$defs/provision_templates" },
        "host_os": { "$ref": "#/$defs/provision_host_os" },
        "oem_windows_license": { "$ref": "#/$defs/provision_oem_windows_license" },
        "storage": { "$ref": "#/$defs/provision_storage" },
        "api_token": { "$ref": "#/$defs/provision_api_token" },
        "ssh_keys": { "$ref": "#/$defs/provision_ssh_keys" },
        "host_firewall": { "$ref": "#/$defs/provision_host_firewall" },
        "guest_firewall": { "$ref": "#/$defs/provision_guest_firewall" },
        "guest_agents": { "$ref": "#/$defs/provision_guest_agents" },
        "apt_sources": { "$ref": "#/$defs/provision_apt_sources" },
        "lxc": { "$ref": "#/$defs/provision_lxc" },
        "qemu": { "$ref": "#/$defs/provision_qemu" },
        "local_lvm": { "$ref": "#/$defs/provision_local_lvm" }
      }
    },
    "provision_local_lvm": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "extend": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": ["boolean", "integer"],
              "description": "When true (default), maintain grows local-lvm when the boot disk has unallocated space after the PVE partition."
            },
            "storage_id": {
              "type": "string",
              "description": "Proxmox storage id for the default thin pool (default local-lvm)."
            },
            "vg": {
              "type": "string",
              "description": "Volume group name (default pve)."
            },
            "thin_pool": {
              "type": "string",
              "description": "Thin pool LV name (default data)."
            }
          }
        },
        "extra_pools": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": ["boolean", "integer"],
              "description": "When true (default), process clusters[].hosts[].local_lvm.pools on each node."
            },
            "content": {
              "type": "string",
              "description": "Default pvesm content for extra lvmthin pools (default images,rootdir)."
            }
          }
        }
      }
    },
    "host_local_lvm": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "extend": {
          "type": ["boolean", "integer"],
          "description": "Override provision.local_lvm.extend.enabled for this host."
        },
        "pools": {
          "type": "array",
          "items": { "$ref": "#/$defs/local_lvm_pool" }
        }
      }
    },
    "local_lvm_pool": {
      "type": "object",
      "additionalProperties": false,
      "required": ["storage_id", "raid", "vg", "thin_pool"],
      "properties": {
        "storage_id": {
          "type": "string",
          "minLength": 1,
          "description": "Proxmox storage id (e.g. local-lvm-mirrored)."
        },
        "vg": {
          "type": "string",
          "minLength": 1,
          "description": "LVM volume group on the RAID device."
        },
        "thin_pool": {
          "type": "string",
          "minLength": 1,
          "description": "Thin pool logical volume name (default data)."
        },
        "content": {
          "type": "string",
          "description": "pvesm content types (overrides provision.local_lvm.extra_pools.content)."
        },
        "md_name": {
          "type": "string",
          "description": "Optional mdadm array name under /dev/md/ (defaults to vg with non-alnum replaced)."
        },
        "raid": {
          "type": "object",
          "additionalProperties": false,
          "required": ["level", "devices"],
          "properties": {
            "level": {
              "type": "integer",
              "enum": [0],
              "description": "Linux MD RAID level (0 only for now)."
            },
            "devices": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 },
              "description": "Block devices (prefer /dev/disk/by-id/...). One device for a direct PV pool; two or more for RAID0."
            }
          }
        }
      }
    },
    "provision_api_token": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": ["boolean", "integer"],
          "description": "When false, maintain skips ensuring hdc API token role/ACL via SSH (default true)."
        },
        "role": {
          "type": "string",
          "description": "Proxmox role id for the hdc API token (default HDCMaintain)."
        },
        "userid": {
          "type": "string",
          "description": "Proxmox user that owns the hdc API token (default root@pam)."
        },
        "privileges": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "description": "Privilege list for the role; defaults to hdc maintain set (VM.Audit, Datastore.Audit, …)."
        }
      }
    },
    "provision_ssh_keys": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": ["boolean", "integer"],
          "description": "When false, maintain skips installing local ~/.ssh public keys on hypervisors (default true)."
        }
      }
    },
    "provision_apt_sources": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": ["boolean", "integer"],
          "description": "When false, maintain skips no-subscription APT sources and subscription nag (default true)."
        },
        "disable_enterprise": {
          "type": ["boolean", "integer"],
          "description": "Disable pve-enterprise apt entries (default true)."
        },
        "enable_no_subscription": {
          "type": ["boolean", "integer"],
          "description": "Enable pve-no-subscription apt repo (default true)."
        },
        "disable_ceph_enterprise": {
          "type": ["boolean", "integer"],
          "description": "Disable Ceph enterprise apt entries; does not add Ceph no-subscription (default true)."
        },
        "remove_subscription_nag": {
          "type": ["boolean", "integer"],
          "description": "Install nag-removal script and apt Post-Invoke hook (default true)."
        }
      }
    },
    "provision_host_firewall": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": ["boolean", "integer"],
          "description": "When false, maintain skips restricting host SSH and web UI (port 8006) to allowed_source_cidrs (default true)."
        },
        "allowed_source_cidrs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "description": "Source networks allowed for SSH and Proxmox web UI (default example RFC5737 subnets; gateway-style x.x.x.1/24 normalized to .0/24 on apply)."
        },
        "ssh_port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535,
          "description": "SSH port to restrict (default 22)."
        },
        "web_port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535,
          "description": "Proxmox web UI port to restrict (default 8006)."
        }
      }
    },
    "provision_guest_firewall": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": ["boolean", "integer"],
          "description": "When true, maintain writes /etc/pve/firewall/<vmid>.fw for vmids from service package deployments."
        },
        "allowed_source_cidrs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "description": "Inbound allow list for managed guests (falls back to host_firewall cidrs when omitted)."
        },
        "manage_from_deployments": {
          "type": ["boolean", "integer"],
          "description": "When true (default), collect vmids from packages/services/*/config.json deployments."
        }
      }
    },
    "provision_guest_agents": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "crowdsec": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": ["boolean", "integer"] },
            "lapi_url": { "type": "string", "minLength": 1 },
            "enroll_key_vault_key": { "type": "string", "minLength": 1 }
          }
        },
        "wazuh": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": ["boolean", "integer"] },
            "manager_host": { "type": "string", "minLength": 1 },
            "registration_password_vault_key": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "provision_storage": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": ["boolean", "integer"],
          "description": "When false, maintain skips NAS storage ensure (default true)."
        },
        "ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "description": "Storage ids to ensure (default nas-a, nas-b)."
        },
        "discover_from_host": {
          "type": "string",
          "description": "Inventory host id to prefer when discovering storage definitions (e.g. hypervisor-a)."
        },
        "targets": {
          "type": "array",
          "description": "Explicit storage definitions (Proxmox storage.cfg fields). When set, used instead of API discovery.",
          "items": { "type": "object", "additionalProperties": true }
        }
      }
    },
    "provision_host_os": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": ["boolean", "integer"],
          "description": "When false, maintain skips apt update/upgrade on hypervisors (default true)."
        },
        "reboot_wait_seconds": {
          "type": "number",
          "description": "Max seconds to wait for SSH after each sequential reboot (default 300)."
        }
      }
    },
    "provision_oem_windows_license": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": ["boolean", "integer"],
          "description": "When false, maintain skips reporting ACPI SLIC/MSDM OEM Windows license tables and QEMU -acpitable passthrough (default true)."
        }
      }
    },
    "provision_templates": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "policy": {
          "type": "string",
          "enum": ["ubuntu-lts", "legacy"],
          "description": "ubuntu-lts (default): sync all supported Ubuntu LTS LXC vztmpl and QEMU templates; prune older Ubuntu templates."
        }
      }
    },
    "provision_lxc": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "ostemplate": { "type": "string" },
        "ostemplate_storage": {
          "type": "string",
          "description": "Storage for CT templates (vztmpl), e.g. local."
        },
        "default_release": {
          "type": "string",
          "description": "Ubuntu LTS release for default ostemplate (e.g. 22.04)."
        },
        "storage": { "type": "string" },
        "rootfs_gb": { "type": "number" },
        "memory_mb": { "type": "number" },
        "cores": { "type": "number" },
        "bridge": { "type": "string" },
        "ip_config": { "type": "string" },
        "unprivileged": { "type": ["integer", "boolean"] },
        "onboot": { "type": ["integer", "boolean"] },
        "vmid": { "type": "number" }
      }
    },
    "provision_qemu": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "storage": { "type": "string", "description": "Disk storage for VM and cloud-init (e.g. local-lvm)." },
        "image_storage": {
          "type": "string",
          "description": "Directory storage for downloaded cloud .img before import (e.g. local)."
        },
        "default_release": {
          "type": "string",
          "description": "Ubuntu LTS release for default QEMU template (e.g. 22.04 → vmid 9022)."
        },
        "template_vmid": {
          "type": "number",
          "description": "Default QEMU template vmid for create-vm (catalog: 9022=22.04, 9024=24.04, 9026=26.04)."
        },
        "template_name": { "type": "string", "description": "Guest name before conversion to template." },
        "build_template": {
          "type": ["boolean", "integer"],
          "description": "When true (default), maintain builds template_vmid from cloud_image_url if missing."
        },
        "cloud_image_url": { "type": "string", "description": "HTTP(S) URL of cloud image (.img) for QEMU template build." },
        "cloud_image_filename": { "type": "string", "description": "Filename on image_storage after download." },
        "memory_mb": { "type": "number" },
        "cores": { "type": "number" },
        "bridge": { "type": "string" },
        "vmid": { "type": "number" }
      }
    },
    "bootstrap_host": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "tags"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "auth": { "type": "object" },
        "access": { "type": "object" }
      }
    }
  }
}
