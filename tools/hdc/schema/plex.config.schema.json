{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/plex.config.schema.json",
  "title": "HDC plex service package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "deployments"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 2 },
    "defaults": { "type": "object" },
    "deployments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["system_id"],
        "properties": {
          "system_id": { "type": "string", "minLength": 1 },
          "mode": { "enum": ["synology-package"] },
          "hostname": { "type": "string" },
          "synology": {
            "type": "object",
            "properties": {
              "instance": { "type": "string", "pattern": "^[a-z]+$" }
            }
          },
          "plex": {
            "type": "object",
            "properties": {
              "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
              "package_name": { "type": "string" },
              "public_url": { "type": ["string", "null"] },
              "timezone": { "type": "string" }
            }
          },
          "install": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" }
            }
          }
        }
      }
    }
  }
}
