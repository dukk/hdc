{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/paperless-ngx.config.schema.json",
  "title": "HDC paperless-ngx service package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "deployments"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 2 },
    "defaults": { "type": "object" },
    "deployments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["system_id"],
        "properties": {
          "system_id": { "type": "string", "pattern": "^paperless-ngx-[a-z]+$" },
          "mode": { "enum": ["proxmox-lxc"] },
          "proxmox": { "type": "object" },
          "paperless_ngx": {
            "type": "object",
            "properties": {
              "image_tag": { "type": "string" },
              "postgres_image_tag": { "type": "string" },
              "redis_image_tag": { "type": "string" },
              "gotenberg_image_tag": { "type": "string" },
              "tika_image_tag": { "type": "string" },
              "host_port": { "type": "integer", "minimum": 1, "maximum": 65535 },
              "tika_enabled": { "type": "boolean" },
              "public_url": { "type": ["string", "null"] },
              "timezone": { "type": "string" },
              "ocr_language": { "type": "string" },
              "webserver_workers": { "type": "integer", "minimum": 1, "maximum": 32 },
              "usermap_uid": { "type": "integer", "minimum": 0 },
              "usermap_gid": { "type": "integer", "minimum": 0 },
              "secret_key_vault_key": { "type": "string" },
              "db_password_vault_key": { "type": "string" },
              "admin": {
                "type": "object",
                "properties": {
                  "enabled": { "type": "boolean" },
                  "user": { "type": "string" },
                  "mail": { "type": "string" },
                  "password_vault_key": { "type": "string" }
                }
              }
            }
          },
          "install": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" },
              "compose_dir": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
