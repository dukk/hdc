{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/twilio.config.schema.json",
  "title": "HDC twilio infrastructure package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "twilio", "sip_trunks", "phone_numbers"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "twilio": {
      "type": "object",
      "properties": {
        "account_sid": { "type": ["string", "null"] },
        "friendly_name": { "type": ["string", "null"] },
        "status": { "type": ["string", "null"] },
        "api_base_url": { "type": "string", "format": "uri" },
        "trunking_api_base_url": { "type": "string", "format": "uri" },
        "auth": {
          "type": "object",
          "properties": {
            "account_sid_vault_key": { "type": "string", "minLength": 1 },
            "auth_token_vault_key": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "sip_trunks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "sid", "termination_domain"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "sid": { "type": "string", "minLength": 1 },
          "friendly_name": { "type": ["string", "null"] },
          "termination_domain": { "type": "string", "minLength": 1 },
          "origination_urls": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["sid", "sip_url"],
              "properties": {
                "sid": { "type": "string" },
                "friendly_name": { "type": ["string", "null"] },
                "sip_url": { "type": "string" },
                "priority": { "type": "integer" },
                "weight": { "type": "integer" },
                "enabled": { "type": "boolean" }
              }
            }
          },
          "trunk_phone_numbers": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["sid", "phone_number"],
              "properties": {
                "sid": { "type": "string" },
                "phone_number": { "type": "string" }
              }
            }
          },
          "credential_lists": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["sid"],
              "properties": {
                "sid": { "type": "string" },
                "friendly_name": { "type": ["string", "null"] },
                "credentials": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["sid", "username"],
                    "properties": {
                      "sid": { "type": "string" },
                      "username": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "phone_numbers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["sid", "phone_number"],
        "properties": {
          "sid": { "type": "string" },
          "phone_number": { "type": "string" },
          "friendly_name": { "type": ["string", "null"] },
          "voice_url": { "type": ["string", "null"] },
          "sms_url": { "type": ["string", "null"] },
          "trunk_sid": { "type": ["string", "null"] },
          "capabilities": {
            "type": "object",
            "properties": {
              "voice": { "type": "boolean" },
              "sms": { "type": "boolean" },
              "mms": { "type": "boolean" },
              "fax": { "type": "boolean" }
            }
          }
        }
      }
    }
  }
}
