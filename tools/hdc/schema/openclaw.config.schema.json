{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/openclaw.config.schema.json",
  "title": "HDC openclaw service package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "deployments"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 2 },
    "defaults": { "type": "object" },
    "deployments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["system_id"],
        "properties": {
          "system_id": { "type": "string", "pattern": "^vm-openclaw-[a-z]+$" },
          "mode": { "enum": ["proxmox-qemu"] },
          "hostname": { "type": "string" },
          "proxmox": { "type": "object" },
          "configure": { "type": "object" },
          "install": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" },
              "linux_user": { "type": "string" },
              "node_version": { "type": "string" },
              "docker": { "type": "boolean" }
            }
          },
          "openclaw": {
            "type": "object",
            "properties": {
              "version": { "type": "string" },
              "channel": { "type": "string" },
              "gateway_token_vault_key": { "type": "string" },
              "gateway": {
                "type": "object",
                "properties": {
                  "bind": { "enum": ["loopback", "lan"] },
                  "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
                }
              },
              "agents": { "type": "object" },
              "channels": { "type": "object" },
              "config_extra": { "type": "object" },
              "env_secrets": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["vault_key", "guest_env"],
                  "properties": {
                    "vault_key": { "type": "string" },
                    "guest_env": { "type": "string" },
                    "optional": { "type": "boolean" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
