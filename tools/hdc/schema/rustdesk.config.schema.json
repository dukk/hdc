{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/rustdesk.config.schema.json",
  "title": "HDC RustDesk service package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "deployments"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 2 },
    "defaults": { "type": "object" },
    "deployments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["system_id"],
        "properties": {
          "system_id": { "type": "string", "pattern": "^rustdesk-[a-z]+$" },
          "mode": { "enum": ["proxmox-lxc"] },
          "proxmox": { "type": "object" },
          "rustdesk": {
            "type": "object",
            "properties": {
              "image_tag": { "type": "string" },
              "always_use_relay": { "type": "boolean" },
              "id_server_host": { "type": ["string", "null"] }
            }
          },
          "install": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" },
              "compose_dir": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
