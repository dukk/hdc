{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/solidtime.config.schema.json",
  "title": "HDC solidtime service package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "deployments"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 2 },
    "defaults": { "type": "object" },
    "deployments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["system_id"],
        "properties": {
          "system_id": { "type": "string", "pattern": "^solidtime-[a-z]+$" },
          "mode": { "enum": ["proxmox-lxc"] },
          "proxmox": { "type": "object" },
          "solidtime": {
            "type": "object",
            "properties": {
              "version": { "type": "string" },
              "app_url": { "type": ["string", "null"] },
              "enable_registration": { "type": "boolean" },
              "mail_mailer": { "type": "string" },
              "db_password_vault_key": { "type": "string" }
            }
          },
          "install": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" }
            }
          }
        }
      }
    }
  }
}
