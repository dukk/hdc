{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/nagios.config.schema.json",
  "title": "HDC nagios service package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "bind_config_path", "deployments"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 2 },
    "bind_config_path": { "type": "string", "minLength": 1 },
    "defaults": { "type": "object" },
    "deployments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["system_id"],
        "properties": {
          "system_id": { "type": "string", "pattern": "^nagios-[a-z]+$" },
          "mode": { "enum": ["proxmox-lxc"] },
          "proxmox": { "type": "object" },
          "install": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" }
            }
          },
          "configure": {
            "type": "object",
            "properties": {
              "ssh": {
                "type": "object",
                "properties": {
                  "user": { "type": "string" },
                  "host": { "type": "string" }
                }
              }
            }
          }
        }
      }
    }
  }
}
