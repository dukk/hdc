{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hdc.local/schema/nginx-waf.config.schema.json",
  "title": "HDC nginx-waf service package config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "deployments"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 2 },
    "sites": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "server_names", "upstream"],
        "properties": {
          "id": { "type": "string" },
          "server_names": { "type": "array", "items": { "type": "string" } },
          "listen": { "type": "array", "items": { "type": "integer" } },
          "upstream": { "type": "string" },
          "client_ip": { "enum": ["remote_addr", "cloudflare"] },
          "trusted_cidrs": { "type": "array", "items": { "type": "string" } },
          "tls": { "type": "object" },
          "waf": { "type": "object" },
          "locations": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "path": { "type": "string" },
                "proxy_headers": { "type": "boolean" },
                "websocket": { "type": "boolean" },
                "access": {
                  "type": "object",
                  "properties": {
                    "policy": { "enum": ["internal_only"] },
                    "deny_status": { "enum": [401, 404] }
                  },
                  "required": ["policy", "deny_status"]
                }
              }
            }
          }
        }
      }
    },
    "letsencrypt": {
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "email_vault_key": { "type": "string" },
        "staging": { "type": "boolean" },
        "cert_primary_system_id": { "type": "string" },
        "challenge": { "enum": ["http-01", "dns-01"] },
        "webroot": { "type": "string" },
        "dns": { "type": "object" }
      }
    },
    "defaults": {
      "type": "object",
      "properties": {
        "nginx_waf": {
          "type": "object",
          "properties": {
            "modsecurity": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "rule_engine": { "enum": ["On", "DetectionOnly", "Off"] },
                "crs_setup": { "type": "string" },
                "crs_rules_glob": { "type": "string" },
                "unicode_map": { "type": "string" },
                "audit_log": { "type": "string" }
              }
            },
            "trusted_cidrs": { "type": "array", "items": { "type": "string" } },
            "cloudflare_ipv4": { "type": "boolean" }
          }
        }
      }
    },
    "deployments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["system_id", "role"],
        "properties": {
          "system_id": { "type": "string", "pattern": "^vm-nginx-waf-[a-z]+$" },
          "role": { "enum": ["cert-primary", "peer"] },
          "hostname": { "type": "string" },
          "mode": { "enum": ["proxmox-qemu", "configure-only"] },
          "proxmox": { "type": "object" },
          "configure": { "type": "object" }
        }
      }
    }
  }
}
