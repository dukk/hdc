# Operator workspace (this repo is hdc-private). See docs/npm-workspace.md in hdc.
#
# Path to this repo for the CLI (`.` when you run hdc from this directory).
HDC_PRIVATE_ROOT=.

# Vault / secret backend (prefer: hdc secrets set …)
# HDC_VAULT_PASSPHRASE=
# HDC_SECRET_BACKEND=auto

# Optional: pin clump package tree instead of ~/.hdc/clump-repos
# HDC_CLUMPS_ROOT=
