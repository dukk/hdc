# Copy to clumps/infrastructure/twilio/.env in hdc-private (or hdc root; never commit).
# Values are optional unless the package manifest declares env_required.

# Twilio (`clumps/infrastructure/twilio`) — Account SID and Auth Token (prefer vault).
# node apps/hdc-cli/cli.mjs secrets set HDC_TWILIO_ACCOUNT_SID
# node apps/hdc-cli/cli.mjs secrets set HDC_TWILIO_AUTH_TOKEN
# HDC_TWILIO_ACCOUNT_SID=
# HDC_TWILIO_AUTH_TOKEN=
# Asterisk SIP Credential List (separate from API credentials): HDC_TWILIO_SIP_USERNAME, HDC_TWILIO_SIP_PASSWORD
