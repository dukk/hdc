# Entra directory (tenant) ID and Graph automation app (Application.ReadWrite.All).
# Per-app keys: HDC_AZURE_ENTRA_<APP>_APPLICATION_ID / _SECRET_VALUE / optional _SECRET_ID.
# Default automation app_id is hdc (see entra.automation in config.json).
# APPLICATION_ID = Application (client) ID from Overview — not Secret ID.
# SECRET_VALUE = client secret value (prefer vault). SECRET_ID = portal metadata only.
# Legacy HDC_AZURE_ENTRA_CLIENT_ID / HDC_AZURE_ENTRA_CLIENT_SECRET still work with a warning.
# HDC_AZURE_ENTRA_TENANT_ID=
# HDC_AZURE_ENTRA_HDC_APPLICATION_ID=
# HDC_AZURE_ENTRA_HDC_SECRET_ID=
# node apps/hdc-cli/cli.mjs secrets set HDC_AZURE_ENTRA_HDC_SECRET_VALUE
# HDC_AZURE_ENTRA_HDC_SECRET_VALUE=

# ARM compute service principal (optional until --section compute is used).
# HDC_AZURE_COMPUTE_SUBSCRIPTION_ID=
# HDC_AZURE_COMPUTE_TENANT_ID=
# HDC_AZURE_COMPUTE_CLIENT_ID=
# node apps/hdc-cli/cli.mjs secrets set HDC_AZURE_COMPUTE_CLIENT_SECRET
# HDC_AZURE_COMPUTE_CLIENT_SECRET=
