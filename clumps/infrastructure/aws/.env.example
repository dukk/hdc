# Copy to clumps/infrastructure/aws/.env in hdc-private (or hdc root; never commit).
# Values are optional unless the package manifest declares env_required.

# AWS infrastructure (`clumps/infrastructure/aws`) — IAM access key id in .env; secret in vault.
# HDC_AWS_ACCESS_KEY_ID=
# node apps/hdc-cli/cli.mjs secrets set HDC_AWS_SECRET_ACCESS_KEY
# HDC_AWS_SECRET_ACCESS_KEY=
# Optional STS session token for assumed roles:
# node apps/hdc-cli/cli.mjs secrets set HDC_AWS_SESSION_TOKEN
