# Copy to clumps/infrastructure/gcp-oauth/.env in hdc-private (or hdc root; never commit).
# Values are optional unless the package manifest declares env_required.

# GCP OAuth / Google Auth Platform (`clumps/infrastructure/gcp-oauth`) — per-app client credentials (prefer vault).
# node apps/hdc-cli/cli.mjs secrets set HDC_GCP_OAUTH_VAULTWARDEN_CLIENT_ID
# node apps/hdc-cli/cli.mjs secrets set HDC_GCP_OAUTH_VAULTWARDEN_CLIENT_SECRET
# Or: hdc run infrastructure gcp-oauth maintain -- --import ./client_secret.json
