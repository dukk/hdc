# Copy to clumps/infrastructure/synology-nas/.env in hdc-private (or hdc root; never commit).
# Values are optional unless the package manifest declares env_required.

# Synology NAS (`clumps/infrastructure/synology-nas`) — SSH admin user and per-host passwords (prefer vault).
# Enable SSH in DSM Control Panel → Terminal & SNMP before first maintain.
# node apps/hdc-cli/cli.mjs secrets set HDC_SYNOLOGY_SSH_PASSWORD_NAS_1
# node apps/hdc-cli/cli.mjs secrets set HDC_SYNOLOGY_SSH_PASSWORD_NAS_2
# HDC_SYNOLOGY_SSH_USER=admin
# HDC_SYNOLOGY_SSH_PASSWORD_NAS_1=
# HDC_SYNOLOGY_SSH_PASSWORD_NAS_2=
