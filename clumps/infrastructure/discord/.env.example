# Copy to clumps/infrastructure/discord/.env in hdc-private (or hdc root; never commit).
# Values are optional unless the package manifest declares env_required.

# Discord applications (`clumps/infrastructure/discord`) — per-app bot_token_vault_key in config.
# Hermes uses HDC_HERMES_DISCORD_BOT_TOKEN (also tracked by the discord infra package).
# node apps/hdc-cli/cli.mjs secrets set HDC_HERMES_DISCORD_BOT_TOKEN
# HDC_HERMES_DISCORD_BOT_TOKEN=
