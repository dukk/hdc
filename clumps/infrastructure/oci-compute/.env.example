# Copy to clumps/infrastructure/oci-compute/.env in hdc-private (or hdc root; never commit).
# Values are optional unless the package manifest declares env_required.

# Oracle Cloud compute — API signing key in vault.
# HDC_OCI_TENANCY_OCID=
# HDC_OCI_USER_OCID=
# HDC_OCI_FINGERPRINT=
# HDC_OCI_REGION=
# node apps/hdc-cli/cli.mjs secrets set HDC_OCI_API_PRIVATE_KEY
# HDC_OCI_API_PRIVATE_KEY=
