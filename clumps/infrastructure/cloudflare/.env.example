# Copy to clumps/infrastructure/cloudflare/.env in hdc-private (or hdc root; never commit).
# Values are optional unless the package manifest declares env_required.

# Cloudflare DNS (`clumps/infrastructure/cloudflare`) and Workers/Pages (`clumps/infrastructure/cloudflare-workers`) — API token (prefer vault).
# Workers/Pages also require wrangler on PATH (`npm install -g wrangler`).
# node apps/hdc-cli/cli.mjs secrets set HDC_CLOUDFLARE_API_TOKEN
# HDC_CLOUDFLARE_API_TOKEN=
# Required for Workers/Pages API; optional for DNS zone listing:
# HDC_CLOUDFLARE_ACCOUNT_ID=
