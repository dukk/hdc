# Copy to clumps/services/vikunja/.env in hdc-private (or hdc root; never commit).
# Values are optional unless the package manifest declares env_required.

# Vikunja (`clumps/services/vikunja`) — JWT secret and Postgres password; auto-generated on first deploy if missing.
# node apps/hdc-cli/cli.mjs secrets set HDC_VIKUNJA_JWT_SECRET
# node apps/hdc-cli/cli.mjs secrets set HDC_VIKUNJA_DB_PASSWORD
# HDC_VIKUNJA_JWT_SECRET=
# HDC_VIKUNJA_DB_PASSWORD=
