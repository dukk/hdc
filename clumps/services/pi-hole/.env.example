# Copy to clumps/services/pi-hole/.env in hdc-private (or hdc root; never commit).
# Values are optional unless the package manifest declares env_required.

# Pi-hole DNS filtering (`clumps/services/pi-hole`) — prefer vault over env.
# node apps/hdc-cli/cli.mjs secrets set HDC_PIHOLE_WEBPASSWORD
# node apps/hdc-cli/cli.mjs secrets set HDC_PIHOLE_API_TOKEN
# Optional per-instance API tokens: HDC_PIHOLE_API_TOKEN_A, HDC_PIHOLE_API_TOKEN_B
# HDC_PIHOLE_WEBPASSWORD=
# HDC_PIHOLE_API_TOKEN=
