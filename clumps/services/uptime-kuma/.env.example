# Copy to clumps/services/uptime-kuma/.env in hdc-private (or hdc root; never commit).
# Values are optional unless the package manifest declares env_required.

# Uptime Kuma (`clumps/services/uptime-kuma`) — admin login for monitor sync (Socket.IO).
# HDC_UPTIME_KUMA_USERNAME=admin
# node apps/hdc-cli/cli.mjs secrets set HDC_UPTIME_KUMA_PASSWORD
# OCI external instance (uptime-kuma-ext-a):
# HDC_UPTIME_KUMA_USERNAME_EXT_A=admin
# node apps/hdc-cli/cli.mjs secrets set HDC_UPTIME_KUMA_PASSWORD_EXT_A
# Optional read-only API key (Prometheus/metrics only; cannot create monitors):
# node apps/hdc-cli/cli.mjs secrets set HDC_UPTIME_KUMA_API_KEY
# HDC_UPTIME_KUMA_API_KEY=
