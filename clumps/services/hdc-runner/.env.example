# Copy to clumps/services/hdc-runner/.env in hdc-private (or hdc root; never commit).
# HDC scheduled automation runner — values optional unless manifest env_required is set.
# Prefer vault: node apps/hdc-cli/cli.mjs secrets set <KEY>

# CURSOR_API_KEY is pushed to the guest /opt/hdc-runner/.env during maintain
# from vault HDC_CURSOR_API_KEY (falls back to HDC_PAPERCLIP_CURSOR_API_KEY).
# Required when hdc_runner.agents.enabled is true.

# Vaultwarden API key login (optional alternative to HDC_VAULTWARDEN_EMAIL on the guest).
# Set in repo root .env, this package .env, or local hdc vault; maintain pushes to the guest.
# HDC_VAULTWARDEN_KEY_CLIENT_ID=user.xxxxx-xxxx-xxxx
# HDC_VAULTWARDEN_KEY_CLIENT_SECRET=xxxxxxxxxxxxxx
# HDC_VAULTWARDEN_MASTER_PASSWORD is always required on the guest for bw unlock.
