# Copy to clumps/services/dawarich/.env in hdc-private (or hdc root; never commit).
# Values are optional unless the package manifest declares env_required.

# Dawarich (`clumps/services/dawarich`) — Rails secret and Postgres password; auto-generated on first deploy if missing.
# node apps/hdc-cli/cli.mjs secrets set HDC_DAWARICH_SECRET_KEY_BASE
# node apps/hdc-cli/cli.mjs secrets set HDC_DAWARICH_DB_PASSWORD
# HDC_DAWARICH_SECRET_KEY_BASE=
# HDC_DAWARICH_DB_PASSWORD=
