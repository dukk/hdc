{
  "schema_version": 2,
  "defaults": {
    "mode": "proxmox-lxc",
    "proxmox": {
      "lxc": {
        "ostemplate": "local:vztmpl/ubuntu-22.04-standard_22.04-1_amd64.tar.zst",
        "storage": "local-lvm",
        "rootfs_gb": 16,
        "memory_mb": 2048,
        "cores": 2,
        "bridge": "vmbr0",
        "ip_config": "dhcp",
        "unprivileged": 0,
        "features": "nesting=1,keyctl=1",
        "onboot": 1
      }
    },
    "a2a_registry": {
      "pypi_version": "0.1.5",
      "host_port": 8000,
      "public_url": null,
      "log_level": "INFO"
    },
    "install": {
      "enabled": true,
      "compose_dir": "/opt/a2a-registry"
    }
  },
  "deployments": [
    {
      "system_id": "a2a-registry-a",
      "proxmox": {
        "host_id": "REPLACE_PVE_NODE",
        "lxc": {
          "vmid": 0,
          "hostname": "a2a-registry-a"
        }
      }
    }
  ]
}
