# Copy to clumps/services/mailcow/.env in hdc-private (or hdc root; never commit).
# Values are optional unless the package manifest declares env_required.

# Mailcow (`clumps/services/mailcow`) — DB/Redis passwords auto-generated on first deploy if missing.
# API key required for maintain domain/DKIM/relay reconciliation (create in Mailcow admin UI):
# node apps/hdc-cli/cli.mjs secrets set HDC_MAILCOW_API_KEY
# HDC_MAILCOW_DBPASS=
# HDC_MAILCOW_DBROOT=
# HDC_MAILCOW_REDISPASS=
# HDC_MAILCOW_API_KEY=
