# Copy to clumps/services/hdc-agents/.env in hdc-private (or hdc root; never commit).
# HDC agent runtime fleet — values optional unless manifest env_required is set.
# Prefer vault: node apps/hdc-cli/cli.mjs secrets set <KEY>

# Per-agent LiteLLM virtual keys (optional; compose reads HDC_AGENT_LITELLM_KEY_<ROLE>):
# HDC_AGENT_LITELLM_KEY_HDC_MANAGER=
# HDC_AGENT_LITELLM_KEY_HDC_MONITOR=
# HDC_AGENT_LITELLM_KEY_HDC_SRE=
# HDC_AGENT_LITELLM_KEY_HDC_SECURITY_EXPERT=
# HDC_AGENT_LITELLM_KEY_HDC_SECURITY_ARCHITECT=
# HDC_AGENT_LITELLM_KEY_HDC_NETWORK_ARCHITECT=
# HDC_AGENT_LITELLM_KEY_HDC_RESEARCH=
# HDC_AGENT_LITELLM_KEY_HDC_ENGINEER=
