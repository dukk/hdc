# Copy to clumps/services/postgresql/.env in hdc-private (or hdc root; never commit).
# Values are optional unless the package manifest declares env_required.

# PostgreSQL (`clumps/services/postgresql`) — prefer vault over env.
# node apps/hdc-cli/cli.mjs secrets set HDC_POSTGRESQL_SUPERUSER_PASSWORD
# node apps/hdc-cli/cli.mjs secrets set HDC_POSTGRESQL_REPLICATION_PASSWORD
# Optional per-instance superuser: HDC_POSTGRESQL_SUPERUSER_PASSWORD_A, HDC_POSTGRESQL_SUPERUSER_PASSWORD_B
# HDC_POSTGRESQL_SUPERUSER_PASSWORD=
# HDC_POSTGRESQL_REPLICATION_PASSWORD=
