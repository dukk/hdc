{
  "schema_version": 2,
  "defaults": {
    "mode": "proxmox-lxc",
    "proxmox": {
      "lxc": {
        "ostemplate": "local:vztmpl/ubuntu-22.04-standard_22.04-1_amd64.tar.zst",
        "storage": "local-lvm",
        "rootfs_gb": 20,
        "memory_mb": 2048,
        "cores": 2,
        "bridge": "vmbr0",
        "ip_config": "dhcp",
        "unprivileged": 0,
        "features": "nesting=1,keyctl=1",
        "onboot": 1
      }
    },
    "unleash": {
      "image_tag": "7.6.5",
      "postgres_image_tag": "17-alpine",
      "host_port": 4242,
      "public_url": "https://unleash.example.invalid",
      "admin_user": "admin",
      "admin_password_vault_key": "HDC_UNLEASH_ADMIN_PASSWORD",
      "db_password_vault_key": "HDC_UNLEASH_DB_PASSWORD",
      "log_level": "warn"
    },
    "install": {
      "enabled": true,
      "compose_dir": "/opt/unleash"
    }
  },
  "deployments": [
    {
      "system_id": "unleash-a",
      "proxmox": {
        "host_id": "REPLACE_PVE_NODE",
        "lxc": {
          "vmid": 0,
          "hostname": "unleash-a"
        }
      }
    }
  ]
}
