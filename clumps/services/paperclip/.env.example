# Copy to clumps/services/paperclip/.env in hdc-private (or hdc root; never commit).
# Values are optional unless the package manifest declares env_required.

# Paperclip (`clumps/services/paperclip`) — Better Auth secret and Postgres password; auto-generated on first deploy if missing.
# node apps/hdc-cli/cli.mjs secrets set HDC_PAPERCLIP_BETTER_AUTH_SECRET
# node apps/hdc-cli/cli.mjs secrets set HDC_PAPERCLIP_DB_PASSWORD
# HDC_PAPERCLIP_BETTER_AUTH_SECRET=
# HDC_PAPERCLIP_DB_PASSWORD=

# Optional: Cursor Cloud adapter API key → guest compose CURSOR_API_KEY
# node apps/hdc-cli/cli.mjs secrets set HDC_PAPERCLIP_CURSOR_API_KEY
# HDC_PAPERCLIP_CURSOR_API_KEY=

# Optional: Anthropic API key → guest compose ANTHROPIC_API_KEY
# node apps/hdc-cli/cli.mjs secrets set HDC_PAPERCLIP_ANTHROPIC_API_KEY
# HDC_PAPERCLIP_ANTHROPIC_API_KEY=

# Optional: OpenAI API key → guest compose OPENAI_API_KEY
# node apps/hdc-cli/cli.mjs secrets set HDC_PAPERCLIP_OPENAI_API_KEY
# HDC_PAPERCLIP_OPENAI_API_KEY=

# Optional: Google Gemini API key → guest compose GOOGLE_API_KEY
# node apps/hdc-cli/cli.mjs secrets set HDC_PAPERCLIP_GOOGLE_GEMINI_API_KEY
# HDC_PAPERCLIP_GOOGLE_GEMINI_API_KEY=
