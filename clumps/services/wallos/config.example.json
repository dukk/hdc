{
  "schema_version": 2,
  "defaults": {
    "mode": "proxmox-lxc",
    "proxmox": {
      "lxc": {
        "ostemplate": "local:vztmpl/ubuntu-22.04-standard_22.04-1_amd64.tar.zst",
        "storage": "local-lvm",
        "rootfs_gb": 16,
        "memory_mb": 1024,
        "cores": 1,
        "bridge": "vmbr0",
        "ip_config": "dhcp",
        "unprivileged": 0,
        "features": "nesting=1,keyctl=1",
        "onboot": 1
      }
    },
    "wallos": {
      "image_tag": "latest",
      "host_port": 8282,
      "public_url": null,
      "timezone": "America/New_York"
    },
    "install": {
      "enabled": true,
      "compose_dir": "/opt/wallos"
    }
  },
  "deployments": [
    {
      "system_id": "wallos-a",
      "proxmox": {
        "host_id": "REPLACE_PVE_NODE",
        "lxc": {
          "vmid": 0,
          "hostname": "wallos-a"
        }
      }
    }
  ]
}
