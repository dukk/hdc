{
  "schema_version": 2,
  "defaults": {
    "mode": "proxmox-lxc",
    "proxmox": {
      "lxc": {
        "ostemplate": "local:vztmpl/ubuntu-22.04-standard_22.04-1_amd64.tar.zst",
        "storage": "local-lvm",
        "rootfs_gb": 24,
        "memory_mb": 6144,
        "cores": 2,
        "bridge": "vmbr0",
        "ip_config": "dhcp",
        "unprivileged": 0,
        "features": "nesting=1,keyctl=1",
        "onboot": 1
      }
    },
    "litellm": {
      "image_tag": "main-stable",
      "postgres_image_tag": "16",
      "host_port": 4000,
      "store_model_in_db": true,
      "master_key_vault_key": "HDC_LITELLM_MASTER_KEY",
      "salt_key_vault_key": "HDC_LITELLM_SALT_KEY",
      "db_password_vault_key": "HDC_LITELLM_DB_PASSWORD",
      "openrouter_api_key_vault_key": "HDC_OPENROUTER_API_KEY",
      "ollama_backends": [
        {
          "id": "ollama-a",
          "url": "http://REPLACE_OLLAMA_A:11434",
          "notes": "Primary Ollama host — set URL from inventory/manual/systems/vm-ollama-a.json"
        },
        {
          "id": "ollama-b",
          "url": "http://REPLACE_OLLAMA_B:11434",
          "notes": "Secondary Ollama host"
        }
      ],
      "model_list": [
        {
          "model_name": "local-qwen",
          "provider": "ollama",
          "model": "qwen3.5:cloud",
          "ollama_backend_id": "ollama-a"
        },
        {
          "model_name": "lan-best-available",
          "provider": "ollama",
          "model": "qwen3.5:cloud",
          "ollama_backend_id": "ollama-a",
          "order": 1
        },
        {
          "model_name": "lan-best-available",
          "provider": "ollama",
          "model": "llama3.2:latest",
          "ollama_backend_id": "ollama-b",
          "order": 2
        },
        {
          "model_name": "claude-sonnet",
          "provider": "openrouter",
          "model": "anthropic/claude-sonnet-4"
        },
        {
          "model_name": "auto",
          "provider": "auto_router",
          "model": "complexity_router",
          "complexity_router_default_model": "local-qwen",
          "complexity_router_config": {
            "tiers": {
              "SIMPLE": "local-qwen",
              "MEDIUM": "lan-best-available",
              "COMPLEX": "lan-best-available",
              "REASONING": "claude-sonnet"
            }
          }
        }
      ],
      "router_settings": {
        "routing_strategy": "simple-shuffle",
        "routing_groups": [
          {
            "group_name": "lan-best-available",
            "models": ["lan-best-available"],
            "routing_strategy": "simple-shuffle"
          }
        ],
        "fallbacks": [{ "local-qwen": ["claude-sonnet"] }]
      },
      "litellm_settings": {
        "drop_params": true,
        "num_retries": 2
      },
      "mail": {
        "enabled": true,
        "from": "litellm@hdc.dukk.org"
      },
      "a2a_agents": [
        {
          "name": "hdc-runner",
          "url": "http://REPLACE_HDC_RUNNER:9120",
          "card_name": "hdc-agent-team",
          "description": "HDC runner task/approval A2A (first LiteLLM registry entry)",
          "protocol_version": "0.3"
        }
      ]
    },
    "install": {
      "enabled": true,
      "compose_dir": "/opt/litellm"
    }
  },
  "deployments": [
    {
      "system_id": "litellm-a",
      "proxmox": {
        "host_id": "hypervisor-a",
        "lxc": {
          "vmid": 0,
          "hostname": "litellm-a"
        }
      }
    }
  ]
}
