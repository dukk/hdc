# Copy to clumps/services/open-webui/.env in hdc-private (or hdc root; never commit).
# Values are optional unless the package manifest declares env_required.

# Open WebUI (`clumps/services/open-webui`) — JWT signing key (64+ random chars); prefer vault.
# node apps/hdc-cli/cli.mjs secrets set HDC_OPEN_WEBUI_SECRET_KEY
# HDC_OPEN_WEBUI_SECRET_KEY=

# LiteLLM master key when open_webui.openai_backends[] references it (shared with litellm package).
# node apps/hdc-cli/cli.mjs secrets set HDC_LITELLM_MASTER_KEY
# HDC_LITELLM_MASTER_KEY=
