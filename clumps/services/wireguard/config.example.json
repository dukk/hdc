{
  "schema_version": 2,
  "defaults": {
    "mode": "proxmox-lxc",
    "proxmox": {
      "lxc": {
        "ostemplate": "local:vztmpl/ubuntu-22.04-standard_22.04-1_amd64.tar.zst",
        "storage": "local-lvm",
        "rootfs_gb": 8,
        "memory_mb": 1024,
        "cores": 1,
        "bridge": "vmbr0",
        "ip_config": "dhcp",
        "unprivileged": 0,
        "onboot": 1
      }
    },
    "wireguard": {
      "interface_address": "10.7.0.1/24",
      "listen_port": 51820,
      "private_key_vault_key": "HDC_WIREGUARD_PRIVATE_KEY",
      "post_up": "",
      "post_down": "",
      "peers": [
        {
          "name": "laptop-a",
          "public_key_vault_key": "HDC_WIREGUARD_PEER_LAPTOP_A_PUBLIC_KEY",
          "preshared_key_vault_key": "HDC_WIREGUARD_PEER_LAPTOP_A_PRESHARED_KEY",
          "allowed_ips": ["10.7.0.2/32"]
        }
      ]
    },
    "install": {
      "enabled": true
    }
  },
  "deployments": [
    {
      "system_id": "wireguard-a",
      "proxmox": {
        "host_id": "REPLACE_PVE_NODE",
        "lxc": {
          "vmid": 0,
          "hostname": "wireguard-a"
        }
      }
    }
  ]
}
