{
  "schema_version": 2,
  "defaults": {
    "mode": "proxmox-lxc",
    "proxmox": {
      "network": { "gateway": "10.0.0.1" },
      "lxc": {
        "ostemplate": "local:vztmpl/ubuntu-22.04-standard_22.04-1_amd64.tar.zst",
        "storage": "local-lvm",
        "rootfs_gb": 20,
        "memory_mb": 2048,
        "cores": 2,
        "bridge": "vmbr0",
        "ip_config": "ip=REPLACE_STATIC_IP/24,gw=REPLACE_GATEWAY",
        "unprivileged": 0,
        "features": "nesting=1,keyctl=1",
        "onboot": 1
      }
    },
    "meshcentral": {
      "image_tag": "latest",
      "public_url": "https://meshcentral.example.invalid",
      "hostname": null,
      "trusted_proxies": ["10.0.0.40", "10.0.0.41"],
      "allow_new_accounts": false,
      "mongo_username": "meshcentral",
      "mongo_database": "meshcentral",
      "mongo_password_vault_key": "HDC_MESHCENTRAL_MONGO_PASSWORD"
    },
    "install": {
      "enabled": true,
      "compose_dir": "/opt/meshcentral"
    }
  },
  "deployments": [
    {
      "system_id": "meshcentral-a",
      "proxmox": {
        "host_id": "REPLACE_PVE_NODE",
        "lxc": {
          "vmid": 0,
          "hostname": "meshcentral-a"
        }
      }
    }
  ]
}
